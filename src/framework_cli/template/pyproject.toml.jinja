[project]
name = "{{ project_slug }}"
version = "0.1.0"
requires-python = ">={{ python_version }}"
dependencies = [
    "fastapi>=0.115",
    "uvicorn>=0.32",
    "pydantic-settings>=2.6",
    "structlog>=24.4",
    "opentelemetry-sdk>=1.27",
    "opentelemetry-exporter-otlp-proto-grpc>=1.27",
    "opentelemetry-instrumentation-fastapi>=0.48b0",
    "opentelemetry-instrumentation-sqlalchemy>=0.48b0",
    "sqlalchemy>=2.0",
    "alembic>=1.13",
    "psycopg[binary]>=3.2",
    "tenacity>=9.0",
    "pybreaker>=1.2",
{% if "graphql" in batteries %}    "strawberry-graphql[fastapi]>=0.235",
{% endif %}{% if "pgvector" in batteries %}    "pgvector>=0.3",
{% endif %}{% if "workers" in batteries %}    "celery[redis]>=5.4",
    "opentelemetry-instrumentation-celery>=0.48b0",
{% endif %}{% if "mongodb" in batteries %}    "pymongo>=4.9",
    "opentelemetry-instrumentation-pymongo>=0.48b0",
{% endif %}{% if "redis" in batteries %}    "redis>=5",
{% endif %}{% if "redis" in batteries or "workers" in batteries %}    "opentelemetry-instrumentation-redis>=0.48b0",
{% endif %}{% if "consumers" in batteries %}    "httpx>=0.28",
{% endif %}{% if "llm" in batteries %}    "litellm>=1.88.1",
{% endif %}]

[dependency-groups]
dev = [
    "pytest>=8.3",
    "pytest-cov>=6.0",
    "httpx>=0.28",
    "ruff>=0.8",
    "mypy>=1.13",
    "pre-commit>=4.0",
    "pip-audit>=2.7",
    "pyyaml>=6.0",
    "testcontainers[postgresql]>=4.8",
{% if "mongodb" in batteries %}    "testcontainers[mongodb]>=4.8",
{% endif %}{% if "redis" in batteries %}    "testcontainers[redis]>=4.8",
{% endif %}{% if "consumers" in batteries %}    "pact-python>=3.4",
{% endif %}]
{% if "docs" in batteries %}
docs = [
    "mkdocs-material>=9.7.6",
    "mkdocstrings[python]>=1.0.4",
    "mkdocs-render-swagger-plugin>=0.1.2",
    "mike>=2.1.3",
]
{% endif %}
[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

[tool.pytest.ini_options]
pythonpath = ["src"]
# Default collection = the in-process tiers only. The env-targeted suites (smoke/sniff/
# non_functional) run explicitly via their own tasks / the deploy workflows against a
# real target — collecting them under a bare `pytest` would fail (no target up).
testpaths = ["tests/unit", "tests/functional", "tests/e2e"]

[tool.coverage.run]
source = ["src"]
branch = true

[tool.coverage.report]
show_missing = true
skip_covered = false
{%- if "pgvector" in batteries %}

[[tool.mypy.overrides]]
# pgvector ships without PEP 561 type information; ignore its missing stubs.
module = ["pgvector", "pgvector.*"]
ignore_missing_imports = true
{%- endif %}
{%- if "workers" in batteries %}

[[tool.mypy.overrides]]
# celery ships without PEP 561 type information; ignore its missing stubs.
module = ["celery", "celery.*"]
ignore_missing_imports = true
{%- endif %}
{%- if "llm" in batteries %}

[[tool.mypy.overrides]]
# litellm ships without PEP 561 type information; ignore its missing stubs.
module = ["litellm", "litellm.*"]
ignore_missing_imports = true
{%- endif %}
