# Behind-edge overlay (FWK94/FWK95) — applied LAST by `task dev:edge`:
#   ./scripts/compose.sh -f base.yml -f observability.yml -f dev.yml -f edge.yml --profile dev ...
# It turns the stack into a discovery target for a shared box edge instead of binding its own
# Traefik :443: the per-stack `traefik` is dropped and the browsable obs UIs gain the same
# instance-parameterized Traefik discovery labels the `app` already carries (base.yml, the FWK88
# seam). Never merged by plain `task dev` — so `task dev` keeps R1 parity (its per-stack Traefik
# routes only the labeled `app`).
#
# Network membership (FWK95 — the master isolation control): only the edge-routed services
# (app + the obs UIs) join the FROZEN external network `swiftwater-shared-edge` so a shared box
# edge can reach them over the docker network (its --providers.docker.network uses that identical
# string). Each routed service ALSO lists `default` because a compose `networks:` key REPLACES
# default membership — drop it and app loses its `postgres`/`redis` connectivity. Data stores are
# deliberately NOT redeclared here, so they stay on the per-project `default` network exclusively:
# otherwise worktree A's app could reach worktree B's Postgres and the shared `postgres` alias
# would resolve ambiguously across instances (silent cross-instance data corruption — creds are a
# uniform app/app). `external: true` means compose never creates or removes the net — `task
# dev:edge` idempotently ensures it (scripts/edge_up.sh) and teardown leaves it intact (no
# active-endpoint deadlock; this stack's containers self-disconnect as they're removed). This
# whole overlay is edge-gated: plain `task dev` never references the shared net, so a standalone
# `docker compose up` (and prod/staging) is unaffected.
services:
  # Drop the per-stack Traefik (no `:443` bind) — TLS terminates at the box edge. A compose
  # overlay can't *remove* a service (profiles/ports merge by append), so `replicas: 0` is the
  # declarative drop: `docker compose up` honors it and starts zero traefik containers.
  traefik:
    deploy:
      replicas: 0

  # The app keeps default (for postgres/redis) and joins the shared edge net (for the box edge).
  app:
    networks: [default, shared-edge]

  # The browsable obs UIs become edge-routable. Same schema as base.yml's `app`: router/service
  # name carries `${STACK_INSTANCE:-{{ project_slug }}}` (collision-free behind one edge), the Host
  # rule is env-driven via `${<SVC>_ROUTE_HOST}` (the dev:edge task computes the per-tier host —
  # nested tier-1 `<svc>.<slug>.localhost` / flat tier-2 `<svc>-<slug>-<inst>.localhost`), and the
  # frozen `swiftwater.instance` constraint label rides ALONGSIDE the router/service labels (FWK97's
  # Traefik `constraints` only discover containers carrying it — labeling without it would silently
  # unroute the UI). Each `${...:-...}` default keeps a bare `docker compose` invocation resolvable.
  grafana:
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.grafana-${STACK_INSTANCE:-{{ project_slug }}}.rule=Host(`${GRAFANA_ROUTE_HOST:-grafana.{{ project_slug }}.localhost}`)"
      - "traefik.http.routers.grafana-${STACK_INSTANCE:-{{ project_slug }}}.entrypoints=websecure"
      - "traefik.http.routers.grafana-${STACK_INSTANCE:-{{ project_slug }}}.tls=true"
      - "traefik.http.services.grafana-${STACK_INSTANCE:-{{ project_slug }}}.loadbalancer.server.port=3000"
      - "swiftwater.instance=${STACK_INSTANCE:-{{ project_slug }}}"
    networks: [default, shared-edge]

  prometheus:
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.prometheus-${STACK_INSTANCE:-{{ project_slug }}}.rule=Host(`${PROMETHEUS_ROUTE_HOST:-prometheus.{{ project_slug }}.localhost}`)"
      - "traefik.http.routers.prometheus-${STACK_INSTANCE:-{{ project_slug }}}.entrypoints=websecure"
      - "traefik.http.routers.prometheus-${STACK_INSTANCE:-{{ project_slug }}}.tls=true"
      - "traefik.http.services.prometheus-${STACK_INSTANCE:-{{ project_slug }}}.loadbalancer.server.port=9090"
      - "swiftwater.instance=${STACK_INSTANCE:-{{ project_slug }}}"
    networks: [default, shared-edge]

  alertmanager:
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.alertmanager-${STACK_INSTANCE:-{{ project_slug }}}.rule=Host(`${ALERTMANAGER_ROUTE_HOST:-alertmanager.{{ project_slug }}.localhost}`)"
      - "traefik.http.routers.alertmanager-${STACK_INSTANCE:-{{ project_slug }}}.entrypoints=websecure"
      - "traefik.http.routers.alertmanager-${STACK_INSTANCE:-{{ project_slug }}}.tls=true"
      - "traefik.http.services.alertmanager-${STACK_INSTANCE:-{{ project_slug }}}.loadbalancer.server.port=9093"
      - "swiftwater.instance=${STACK_INSTANCE:-{{ project_slug }}}"
    networks: [default, shared-edge]

# The shared box edge's network. external: true → compose never creates or removes it; `task
# dev:edge` (scripts/edge_up.sh) idempotently ensures it on up. The name is the FROZEN cross-stream
# datum — the box edge's `--providers.docker.network` uses this identical string (FWK88 seam).
networks:
  shared-edge:
    name: swiftwater-shared-edge
    external: true
