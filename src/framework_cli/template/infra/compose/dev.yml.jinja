# dev profile: app (hot reload) + Traefik HTTPS. `dev:lite` runs the app alone.
services:
  app:
    profiles: ["dev", "lite"]
    # Run as the invoking host user so bind-mounted --reload writes (__pycache__ in /app/src)
    # are host-owned, not root-owned. UID/GID come from the env (task dev sets them); the
    # :-1000 default keeps a raw `docker compose` invocation working.
    user: "${UID:-1000}:${GID:-1000}"
    command: ["uvicorn", "--app-dir", "src", "--host", "0.0.0.0", "--port", "8000", "--reload", "{{ package_name }}.main:app"]
    ports:
      - "${HTTP_HOST_PORT:-8000}:8000"
    volumes:
      - ../../src:/app/src
    environment:
      WATCHFILES_FORCE_POLLING: "true"  # reliable reload on Windows/WSL bind mounts
      APP_OTEL_ENABLED: "true"
      APP_OTEL_EXPORTER_OTLP_ENDPOINT: "http://otel-collector:4317"
      APP_DATABASE_URL: "postgresql+psycopg://app:app@postgres:5432/app"
    depends_on:
      postgres:
        condition: service_healthy

  postgres:
{%- if uses_postgres_extension %}
    build:
      context: ../..
      dockerfile: infra/docker/postgres.Dockerfile
{%- else %}
    image: postgres:17
{%- endif %}
{%- set _preloads = [] %}
{%- if "timescaledb" in batteries %}{% set _ = _preloads.append("timescaledb") %}{% endif %}
{%- if "age" in batteries %}{% set _ = _preloads.append("age") %}{% endif %}
{%- if _preloads %}
    command: ["postgres", "-c", "shared_preload_libraries={{ _preloads | join(',') }}"]
{%- endif %}
    profiles: ["dev", "lite"]
    environment:
      POSTGRES_USER: app
      POSTGRES_PASSWORD: app
      POSTGRES_DB: app
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U app -d app"]
      interval: 5s
      timeout: 3s
      retries: 10
      start_period: 10s
    ports:
      # Published for host tooling (psql, `task db:migrate`). Remap if 5432 is taken locally.
      - "${POSTGRES_HOST_PORT:-5432}:5432"
    volumes:
      - "pgdata:/var/lib/postgresql/data"

  traefik:
    # v3.6+ required: it added Docker API auto-negotiation. Docker Engine 27+ raised the
    # minimum API to 1.44 and rejects Traefik <=v3.5's hardcoded API 1.24 ("client version
    # 1.24 is too old"). Do not downgrade below v3.6.
    image: traefik:v3.6
    profiles: ["dev"]
    command:
      - "--configfile=/etc/traefik/traefik.yml"
    ports:
      - "${TRAEFIK_HTTPS_PORT:-443}:443"
      - "${TRAEFIK_HTTP_PORT:-80}:80"
    volumes:
      - "/var/run/docker.sock:/var/run/docker.sock:ro"
      - "../traefik/traefik.yml:/etc/traefik/traefik.yml:ro"
      - "../traefik/dynamic:/etc/traefik/dynamic:ro"
      - "../traefik/certs:/etc/traefik/certs:ro"
    depends_on:
      app:
        condition: service_healthy

  grafana:
    profiles: ["dev"]
    environment:
      GF_AUTH_ANONYMOUS_ENABLED: "true"
      GF_AUTH_ANONYMOUS_ORG_ROLE: "Admin"
      GF_AUTH_DISABLE_LOGIN_FORM: "true"

{%- if "mongodb" in batteries %}

  mongo:
    image: mongo:7
    profiles: ["dev", "lite"]
    healthcheck:
      test: ["CMD-SHELL", "mongosh --quiet --eval \"db.adminCommand('ping').ok\" | grep -q 1"]
      interval: 5s
      timeout: 3s
      retries: 10
      start_period: 10s
    ports:
      - "${MONGO_HOST_PORT:-27017}:27017"
    volumes:
      - "mongodata:/data/db"

{%- endif %}
{%- if "workers" in batteries or "redis" in batteries %}

  redis:
    image: redis:7-alpine
    profiles: ["dev", "lite"]
    ports:
      - "${REDIS_HOST_PORT:-6379}:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 10
    volumes:
      - "redisdata:/data"
{%- endif %}
{%- if "react" in batteries %}

  frontend:
    image: node:22
    profiles: ["dev"]
    working_dir: /app/frontend
    command: ["sh", "-c", "npm ci && npm run dev -- --host"]
    ports:
      - "${FRONTEND_HOST_PORT:-5173}:5173"
    volumes:
      - ../../frontend:/app/frontend
      - frontend_node_modules:/app/frontend/node_modules
    depends_on:
      app:
        condition: service_healthy
{%- endif %}
{%- if "workers" in batteries %}

  worker:
    build:
      context: ../..
      dockerfile: infra/docker/Dockerfile
    profiles: ["dev"]
    # Run as the invoking host user so bind-mounted /app/src writes (__pycache__) are
    # host-owned, not root-owned (mirrors the app service). :-1000 keeps raw `compose` working.
    user: "${UID:-1000}:${GID:-1000}"
    command: ["celery", "-A", "{{ package_name }}.tasks.app", "worker", "--loglevel=info"]
    environment:
      # Only the app/migrate step runs migrations — workers share entrypoint.sh, so disable
      # its alembic-upgrade to avoid concurrent `upgrade head` racing the app on startup.
      APP_RUN_MIGRATIONS: "false"
      APP_REDIS_URL: "redis://redis:6379/0"
      APP_CELERY_BROKER_URL: "redis://redis:6379/0"
      APP_CELERY_RESULT_BACKEND: "redis://redis:6379/1"
      APP_DATABASE_URL: "postgresql+psycopg://app:app@postgres:5432/app"
      APP_OTEL_ENABLED: "true"
      APP_OTEL_EXPORTER_OTLP_ENDPOINT: "http://otel-collector:4317"
    volumes:
      - ../../src:/app/src
    healthcheck:
      test: ["CMD", "celery", "-A", "{{ package_name }}.tasks.app", "inspect", "ping"]
      interval: 15s
      timeout: 10s
      retries: 5
      start_period: 20s
    depends_on:
      redis:
        condition: service_healthy
      postgres:
        condition: service_healthy

  beat:
    build:
      context: ../..
      dockerfile: infra/docker/Dockerfile
    profiles: ["dev"]
    # Run as the invoking host user so bind-mounted /app/src writes (__pycache__) are
    # host-owned, not root-owned (mirrors the app service). :-1000 keeps raw `compose` working.
    user: "${UID:-1000}:${GID:-1000}"
    command: ["celery", "-A", "{{ package_name }}.tasks.app", "beat", "--loglevel=info"]
    environment:
      APP_RUN_MIGRATIONS: "false"  # shares entrypoint.sh; don't let beat run migrations
      APP_REDIS_URL: "redis://redis:6379/0"
      APP_CELERY_BROKER_URL: "redis://redis:6379/0"
      APP_CELERY_RESULT_BACKEND: "redis://redis:6379/1"
      APP_OTEL_ENABLED: "true"
      APP_OTEL_EXPORTER_OTLP_ENDPOINT: "http://otel-collector:4317"
    volumes:
      - ../../src:/app/src
    depends_on:
      redis:
        condition: service_healthy

{%- endif %}

volumes:
  pgdata: {}
{% if "mongodb" in batteries %}  mongodata: {}
{% endif %}{% if "workers" in batteries or "redis" in batteries %}  redisdata: {}
{% endif %}{% if "react" in batteries %}  frontend_node_modules: {}
{% endif -%}
