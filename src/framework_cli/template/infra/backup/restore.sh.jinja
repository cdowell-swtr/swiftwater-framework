#!/usr/bin/env bash
# Restore the LATEST encrypted dump into the LIVE stores. DESTRUCTIVE — requires typed confirmation.
set -euo pipefail
cd "$(dirname "$0")/../.."
# Load the project .env so a direct `task restore` sees BACKUP_DEST/BACKUP_IDENTITY (read by bash
# here, not by compose). No-op until the operator configures .env. See backup.sh for the rationale.
# shellcheck source=/dev/null
[ -f .env ] && { set -a; . ./.env; set +a; }
: "${BACKUP_DEST:=./backups}"
: "${BACKUP_IDENTITY:=$HOME/.config/{{ project_slug }}/backup-identity.txt}"
slug="{{ project_slug }}"

# ls -1t (newest-first by mtime) is exactly what we want here; the names are our own controlled
# timestamped dumps, so SC2012's non-alphanumeric-filename concern doesn't apply.
# shellcheck disable=SC2012
latest() { ls -1t "$BACKUP_DEST/${slug}-$1-"*.age 2>/dev/null | head -1; }

pg="$(latest postgres)"; [ -n "$pg" ] || { echo "no postgres dump in $BACKUP_DEST" >&2; exit 1; }
read -r -p "Restore $(basename "$pg") into the LIVE postgres? This OVERWRITES data. [type 'yes']: " ok < /dev/tty
[ "$ok" = "yes" ] || { echo "aborted"; exit 1; }
age -d -i "$BACKUP_IDENTITY" "$pg" \
  | ./scripts/compose.sh exec -T postgres pg_restore --clean --if-exists --no-owner --single-transaction -U app -d app
{% if "mongodb" in batteries %}
mg="$(latest mongo)"; if [ -n "$mg" ]; then
  age -d -i "$BACKUP_IDENTITY" "$mg" \
    | ./scripts/compose.sh exec -T mongo mongorestore --archive --gzip --drop --db app
fi
{% endif %}
echo "restore complete"
