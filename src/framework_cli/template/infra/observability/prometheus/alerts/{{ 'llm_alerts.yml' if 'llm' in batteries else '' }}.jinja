groups:
- name: llm
  rules:
  - alert: HighLLMCallFailureRate
    # Per-profile error + provider-exhaustion rate (share of that profile's calls). A wedged
    # or quota-exhausted provider is the failure mode that matters; tune the 0.1 threshold per app.
    expr: sum by (profile) (rate(app_llm_calls_total{outcome=~"error|exhausted"}[5m])) / clamp_min(sum by (profile) (rate(app_llm_calls_total[5m])), 1) > 0.1
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Over 10% of LLM calls are failing or hitting provider quota for an LLM profile (check the provider key, rate limits, and budget)
