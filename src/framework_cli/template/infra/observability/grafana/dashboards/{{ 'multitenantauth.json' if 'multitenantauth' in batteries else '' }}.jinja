{
  "uid": "multitenantauth",
  "title": "Multi-Tenant Auth",
  "tags": ["multitenantauth", "auth"],
  "schemaVersion": 39,
  "version": 1,
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Login attempts by outcome",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {"refId": "A", "expr": "sum by (outcome) (rate(app_auth_logins_total[5m]))", "legendFormat": "__auto"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "id": 2,
      "title": "Session create rate",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"refId": "A", "expr": "rate(app_auth_sessions_total[5m])", "legendFormat": "sessions/s"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "id": 3,
      "title": "Active sessions (DB count)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {"refId": "A", "expr": "app_auth_active_sessions", "legendFormat": "active sessions"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 4,
      "title": "AuthZ decisions by outcome and domain",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {"refId": "A", "expr": "sum by (decision, domain) (rate(app_authz_decisions_total[5m]))", "legendFormat": "__auto"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "id": 5,
      "title": "Role grant/revoke events by action and domain",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "targets": [
        {"refId": "A", "expr": "sum by (action, domain) (rate(app_authz_grants_total[5m]))", "legendFormat": "__auto"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    }
  ]
}
