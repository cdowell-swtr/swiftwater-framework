from functools import lru_cache

from pydantic_settings import BaseSettings, SettingsConfigDict


class Settings(BaseSettings):
    """All configuration, sourced from environment / .env. Never hardcode config."""

    model_config = SettingsConfigDict(
        env_prefix="APP_", env_file=".env", extra="ignore"
    )

    environment: str = "dev"
    service_name: str = "{{ package_name }}"
    # Explicit log-level override; if None, resolved_log_level derives it from environment.
    log_level: str | None = None

    # SLO thresholds (see observability/slo.py).
    slo_request_latency_p99_ms: float = 200.0
    slo_error_rate_pct: float = 1.0

    # OpenTelemetry tracing (off unless enabled; the dev Compose app turns it on).
    otel_enabled: bool = False
    otel_exporter_otlp_endpoint: str = "http://otel-collector:4317"

    # Database connection (SQLAlchemy URL). The Compose stack injects the in-network URL
    # via APP_DATABASE_URL; host tooling (alembic) uses the localhost form; tests use a
    # testcontainers Postgres (overridden per session).
    database_url: str = "postgresql+psycopg://app:app@postgres:5432/app"
{%- if "webhooks" in batteries %}

    # Webhook ingress: HMAC-SHA256 signing secret (read from APP_WEBHOOK_SIGNING_SECRET).
    webhook_signing_secret: str = ""
{%- endif %}
{%- if "workers" in batteries or "redis" in batteries %}

    # Redis connection (shared by the workers broker and the redis datastore battery).
    redis_url: str = "redis://redis:6379/0"
{%- endif %}
{%- if "workers" in batteries %}

    # Celery workers (broker + result backend).
    celery_broker_url: str = "redis://redis:6379/0"
    celery_result_backend: str = "redis://redis:6379/1"
{%- endif %}
{%- if "graphql" in batteries %}

    # GraphQL IDE (GraphiQL) + schema introspection: enabled outside production only.
    # Explicit override; if None, resolved_graphql_ide derives it from environment.
    graphql_ide_enabled: bool | None = None
{%- endif %}
{%- if "mongodb" in batteries %}

    # MongoDB connection URL (pymongo). The Compose stack injects the in-network URL
    # via APP_MONGO_URL; the default points to the mongo service in dev.
    mongo_url: str = "mongodb://mongo:27017/app"
{%- endif %}

    @property
    def resolved_log_level(self) -> str:
        if self.log_level is not None:
            return self.log_level.upper()
        return "DEBUG" if self.environment == "dev" else "INFO"
{%- if "graphql" in batteries %}

    @property
    def resolved_graphql_ide(self) -> bool:
        if self.graphql_ide_enabled is not None:
            return self.graphql_ide_enabled
        return self.environment != "production"
{%- endif %}


@lru_cache
def get_settings() -> Settings:
    return Settings()
