from functools import lru_cache

from pydantic_settings import BaseSettings, SettingsConfigDict
{%- if "llm" in batteries and "multitenantauth" in batteries %}
from pydantic import BaseModel, SecretStr, field_validator, model_validator
{%- elif "llm" in batteries %}
from pydantic import BaseModel, SecretStr
{%- elif "multitenantauth" in batteries %}
from pydantic import SecretStr, field_validator, model_validator
{%- endif %}


{%- if "llm" in batteries %}


class LLMProfile(BaseModel):
    """One named LLM config. Unset fields inherit the `default` profile (the llm_* settings).

    Defined as a JSON map in APP_LLM_PROFILES, e.g.
    APP_LLM_PROFILES='{"smart":{"provider":"anthropic","model":"claude-opus-4-8"},
                       "cheap":{"model":"claude-haiku-4-5-20251001"}}'
    """

    provider: str | None = None
    model: str | None = None
    api_key: SecretStr | None = None
    max_tokens: int | None = None
    temperature: float | None = None
{%- endif %}


class Settings(BaseSettings):
    """All configuration, sourced from environment / .env. Never hardcode config."""

    model_config = SettingsConfigDict(
        env_prefix="APP_", env_file=".env", extra="ignore"
    )

    environment: str = "dev"
    service_name: str = "{{ package_name }}"
    # Explicit log-level override; if None, resolved_log_level derives it from environment.
    log_level: str | None = None

    # SLO thresholds (see observability/slo.py).
    slo_request_latency_p99_ms: float = 200.0
    slo_error_rate_pct: float = 1.0

    # OpenTelemetry tracing (off unless enabled; the dev Compose app turns it on).
    otel_enabled: bool = False
    otel_exporter_otlp_endpoint: str = "http://otel-collector:4317"

    # Serve the built SPA (frontend/dist) at "/" when present (react battery). The mount is a
    # catch-all, so set this False in tests/headless that register routes after create_app()
    # to keep those routes from being shadowed.
    serve_spa: bool = True

    # Resolution precedence: APP_DATABASE_URL in the environment (set by the operator for a
    # managed/external store) > the compose file's ${APP_DATABASE_URL:-…} default (the
    # co-located container DSN) > this Settings default. The DSN is opaque — failover hosts
    # and ?sslmode=verify-full&sslrootcert=… all go in it.
    # Database connection (SQLAlchemy URL). The Compose stack injects the in-network URL
    # via APP_DATABASE_URL; host tooling (alembic) uses the localhost form; tests use a
    # testcontainers Postgres (overridden per session).
    database_url: str = "postgresql+psycopg://app:app@postgres:5432/app"
{%- if "multitenantauth" in batteries %}

    # ── multitenantauth: control-plane + auth settings ────────────────────────
    # Control-plane database. Defaults to database_url (co-located); set APP_CONTROL_DATABASE_URL
    # to separate the control-plane onto its own Postgres instance (the target DB must pre-exist).
    # OPS-F4: the co-located default runs two SQLAlchemy pools on one Postgres — see .env.example
    # for the connection-budget note so operators can size max_connections appropriately.
    # Sentinel "": model_validator fills from database_url when APP_CONTROL_DATABASE_URL is unset.
    control_database_url: str = ""

    # Session cookie configuration.
    # session_cookie_name: scoped to this service so multi-app setups don't collide.
    session_cookie_name: str = "{{ package_name }}_session"
    # B-F9: safe default — always True; override only for local dev (never in prod/staging).
    session_cookie_secure: bool = True
    # None = single-host default (safe); set to a parent domain for multi-subdomain deployments.
    session_cookie_domain: str | None = None

    # CSRF defence: exact origin allowlist (no wildcards — B-F4). Empty = same-origin only.
    # Each entry must be a netloc (e.g. "https://app.example.com"), not a pattern.
    csrf_allowed_origins: set[str] = set()

    # Password / session pepper (HMAC-SHA256 pre-hash). Defaults empty — NOT required by the
    # model; safety is the verify_runtime() startup guard below (raises in prod/staging if empty).
    # B-F8: pepper_version is a forward-compat seam ONLY — no live rotation in Phase 1.
    session_pepper: SecretStr = SecretStr("")
    password_pepper: SecretStr = SecretStr("")
    pepper_version: int = 1  # forward-compat only; no live rotation in Phase 1

    # Session / invite expiry (hours). Defaults: 14 days for sessions, 7 days for invites.
    session_ttl_hours: int = 336
    invite_ttl_hours: int = 168

    # Argon2id cost parameters (B-F10: floor validators below ensure minimum security).
    argon2_time_cost: int = 3
    argon2_memory_cost: int = 65536  # 64 MiB
    argon2_parallelism: int = 4

    # Role / signup policy.
    admin_role_name: str = "tenant.admin"
    # Signup allowlist: list of email addresses or domain suffixes (e.g. "@acme.com").
    # FAIL-CLOSED by default (unlike the reference) — semantics enforced in routes/auth.py:
    # prod → 404; staging + empty allowlist → 403; dev → open. Set this to opt into signups.
    signup_allowlist: list[str] = []
{%- endif %}
{%- if "webhooks" in batteries %}

    # Webhook ingress: HMAC-SHA256 signing secret (read from APP_WEBHOOK_SIGNING_SECRET).
    webhook_signing_secret: str = ""
    # Inbox dedup rows are pruned after this many days. Keep >= your provider's webhook
    # redelivery window, or a late retry could be processed twice.
    webhook_inbox_retention_days: int = 7
{%- endif %}
{%- if "workers" in batteries or "redis" in batteries %}

    # Redis connection URL (used by the workers broker and/or the redis datastore battery).
    redis_url: str = "redis://redis:6379/0"
{%- endif %}
{%- if "workers" in batteries %}

    # Celery workers (broker + result backend).
    celery_broker_url: str = "redis://redis:6379/0"
    celery_result_backend: str = "redis://redis:6379/1"
    # Dead-letter rows (terminal task failures) are pruned after this many days.
    dlq_retention_days: int = 30
{%- endif %}
{%- if "graphql" in batteries %}

    # GraphQL IDE (GraphiQL) + schema introspection: enabled only in the dev/test
    # environments (the Compose stack sets APP_ENVIRONMENT to prod/staging in the
    # production-like environments, so introspection is off there — fail-closed).
    # Explicit override; if None, resolved_graphql_ide derives it from environment.
    graphql_ide_enabled: bool | None = None
{%- endif %}
{%- if "mongodb" in batteries %}

    # MongoDB connection URL (pymongo). This default points to the co-located mongo service;
    # set APP_MONGO_URL in the environment to override to a managed/external instance (the
    # value is an opaque DSN — replica-set hosts, ?tls=true&… all go here).
    mongo_url: str = "mongodb://mongo:27017/app"
{%- endif %}
{%- if "consumers" in batteries %}

    # Downstream inventory service (Pact consumer demo). Override per environment.
    inventory_url: str = "http://inventory:8080"
{%- endif %}
{%- if "llm" in batteries %}

    # LLM runtime (read from APP_LLM_*). The key is passed explicitly to LiteLLM —
    # nothing is read out-of-band from provider-native env vars. `llm_provider` is the seam
    # the HotSwapLLM battery (subscription <-> API) plugs into.
    llm_provider: str = "anthropic"
    llm_model: str = "claude-sonnet-4-6"
    llm_max_tokens: int = 4096
    llm_temperature: float = 0.0
    llm_api_key: SecretStr = SecretStr("")
    # Additional named profiles (JSON in APP_LLM_PROFILES). "default" is reserved — it is
    # the llm_* fields above, not a key here. Each profile's unset fields inherit default.
    llm_profiles: dict[str, "LLMProfile"] = {}
{%- endif %}
{%- if "agents" in batteries %}

    # Agent tool-loop: hard cap on tool-calling rounds per run (APP_AGENT_MAX_ITERATIONS).
    agent_max_iterations: int = 5
{%- endif %}
{%- if "react" in batteries %}

    # Frontend RUM: query-string params captured for attribution (fail-closed allowlist).
    # Defaults to the UTM set; the backend re-applies this on ingest (never trusts the browser).
    # Adding a PII-bearing key here (e.g. "email") is flagged by review-privacy.
    frontend_rum_allowed_query_params: list[str] = [
        "utm_source",
        "utm_medium",
        "utm_campaign",
        "utm_term",
        "utm_content",
    ]
{%- endif %}

{%- if "multitenantauth" in batteries %}

    @field_validator("environment")
    @classmethod
    def _environment_in_set(cls, v: str) -> str:
        # Fail-closed: a typo ("stage", "production", "Prod") must NOT silently pass the env
        # checks that gate the prod pepper guard + tightened posture. The framework set is
        # {dev, test, staging, prod} — "stage" (Meridian's token) is intentionally excluded
        # so a verbatim Meridian config fails loudly here (B-F1: env-token remap).
        normalized = v.strip().lower()
        allowed = {"dev", "test", "staging", "prod"}
        if normalized not in allowed:
            raise ValueError(f"environment must be one of {sorted(allowed)}, got {v!r}")
        return normalized

    @field_validator("argon2_time_cost")
    @classmethod
    def _argon2_time_cost_floor(cls, v: int) -> int:
        if v < 3:
            raise ValueError("argon2_time_cost must be >= 3")
        return v

    @field_validator("argon2_memory_cost")
    @classmethod
    def _argon2_memory_cost_floor(cls, v: int) -> int:
        if v < 65536:
            raise ValueError("argon2_memory_cost must be >= 65536 (64 MiB)")
        return v

    @field_validator("argon2_parallelism")
    @classmethod
    def _argon2_parallelism_floor(cls, v: int) -> int:
        if v < 4:
            raise ValueError("argon2_parallelism must be >= 4")
        return v

    @model_validator(mode="after")
    def _fill_control_database_url(self) -> "Settings":
        # If APP_CONTROL_DATABASE_URL was not set (sentinel ""), fall back to database_url.
        # This allows the control-plane to co-locate on the same Postgres by default.
        if not self.control_database_url:
            self.control_database_url = self.database_url
        return self
{%- endif %}

    @property
    def resolved_log_level(self) -> str:
        if self.log_level is not None:
            return self.log_level.upper()
        return "DEBUG" if self.environment == "dev" else "INFO"
{%- if "graphql" in batteries %}

    @property
    def resolved_graphql_ide(self) -> bool:
        if self.graphql_ide_enabled is not None:
            return self.graphql_ide_enabled
        return self.environment in ("dev", "test")
{%- endif %}


@lru_cache
def get_settings() -> Settings:
    return Settings()
{%- if "multitenantauth" in batteries %}


def verify_runtime(settings: Settings) -> None:
    """Fail-fast startup guard: in prod/staging, both peppers MUST be set (a missing pepper
    silently weakens password/session hashing). Dev and test are exempt — empty peppers are
    fine for local dev. Wire into create_app() BEFORE router includes (OPS-F7).

    B-F2: peppers default SecretStr("") — not "required". This guard is the safety mechanism.
    B-F1: env-token remap — checks {"prod","staging"}, NOT {"prod","stage"} (Meridian's token).
    """
    if settings.environment in {"prod", "staging"} and (
        settings.session_pepper.get_secret_value() == ""
        or settings.password_pepper.get_secret_value() == ""
    ):
        raise RuntimeError(
            f"environment={settings.environment!r} requires non-empty "
            "APP_SESSION_PEPPER and APP_PASSWORD_PEPPER"
        )
{%- endif %}
