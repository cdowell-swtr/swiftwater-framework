"""Periodic retention: prune dead-letter rows (and, with webhooks, inbox dedup rows) past
their configured window. Scheduled daily in schedule.py. Deliberately NOT a BaseTask — a
pruning slip is operational, not work to dead-letter."""

from __future__ import annotations

from ..config.settings import get_settings
from ..db.engine import SessionLocal
from . import dead_letter
from .app import app


@app.task
def prune_expired_records() -> None:
    # prune_expired emits the audit log (dlq_pruned / webhook_inbox_pruned) itself, so the
    # accountability trail lives in one place with one schema — see dead_letter.prune_expired.
    settings = get_settings()
    with SessionLocal() as session:
        dead_letter.prune_expired(session, settings.dlq_retention_days)
{%- if "webhooks" in batteries %}

    from ..webhooks import inbox

    with SessionLocal() as session:
        inbox.prune_expired(session, settings.webhook_inbox_retention_days)
{%- endif %}
