from fastapi import APIRouter, Request
from fastapi.responses import JSONResponse, PlainTextResponse

from {{ package_name }}.observability.recoverability import recoverability
from {{ package_name }}.observability.slo import build_health_report

router = APIRouter()


@router.get("/heartbeat", response_class=PlainTextResponse)
def heartbeat() -> PlainTextResponse:
    """Liveness ping — the process is up. No dependency checks."""
    return PlainTextResponse("OK", status_code=200)


@router.get("/health")
def health(request: Request) -> JSONResponse:
    """Readiness + SLO status. Returns 200 with the structured SLO report.

    NOTE: the SLO figures are computed from THIS instance's in-process metrics — a per-instance
    judgement, correct for a load-balancer probe. The fleet-wide SLO view lives in Grafana
    (Prometheus aggregates every instance's /metrics), not here.
    """
    report = build_health_report(request.app.state.metrics, request.app.state.settings)
{% if "workers" in batteries %}
    import redis as _redis

    from {{ package_name }}.tasks import liveness as _liveness

    _client = _redis.Redis.from_url(request.app.state.settings.redis_url)
    try:
        report["workers"] = {"alive": _liveness.is_alive(_client)}  # type: ignore[arg-type]
    except Exception as exc:  # broker down — degrade, never 500 the probe
        from {{ package_name }}.logging_config import get_logger

        get_logger().warning(
            "health_probe_failed", dependency="workers", error=str(exc)
        )
        report["workers"] = {"alive": False}
    finally:
        _client.close()  # probe fires continuously — don't leak the connection pool
{% endif -%}
{% if "mongodb" in batteries %}
    from {{ package_name }}.mongo.client import get_client as _mongo_client

    try:
        _mongo_client().admin.command("ping")
        report["mongo"] = {"alive": True}
    except Exception as exc:  # mongo unreachable — degrade, never 500 the probe
        from {{ package_name }}.logging_config import get_logger

        get_logger().warning("health_probe_failed", dependency="mongo", error=str(exc))
        report["mongo"] = {"alive": False}
{% endif -%}
{% if "redis" in batteries %}
    from {{ package_name }}.cache.client import get_redis as _get_redis

    try:
        _get_redis().ping()
        report["redis"] = {"alive": True}
    except Exception as exc:  # redis unreachable — degrade, never 500 the probe
        from {{ package_name }}.logging_config import get_logger

        get_logger().warning("health_probe_failed", dependency="redis", error=str(exc))
        report["redis"] = {"alive": False}
{% endif %}
    return JSONResponse(report, status_code=200)


@router.get("/metrics", response_class=PlainTextResponse)
def metrics(request: Request) -> PlainTextResponse:
    """Prometheus exposition format from the in-process registry."""
    body = (
        request.app.state.metrics.render_prometheus()
        + recoverability.render_prometheus()
    )
{%- if "webhooks" in batteries %}

    from {{ package_name }}.webhooks.metrics import webhook_metrics

    body += webhook_metrics.render_prometheus()
{%- endif %}
{%- if "websockets" in batteries %}

    from {{ package_name }}.websockets.metrics import ws_metrics

    body += ws_metrics.render_prometheus()
{%- endif %}
{%- if "graphql" in batteries %}

    from {{ package_name }}.graphql.metrics import gql_metrics

    body += gql_metrics.render_prometheus()
{%- endif %}
{%- if "react" in batteries %}

    from {{ package_name }}.frontend_rum.metrics import frontend_metrics

    body += frontend_metrics.render_prometheus()
{%- endif %}
{%- if "llm" in batteries %}

    from {{ package_name }}.llm.metrics import llm_metrics

    body += llm_metrics.render_prometheus()
{%- endif %}
{%- if "agents" in batteries %}

    from {{ package_name }}.agents.metrics import agent_metrics

    body += agent_metrics.render_prometheus()
{%- endif %}
{%- if "multitenantauth" in batteries %}

    from {{ package_name }}.multitenantauth.metrics import (
        auth_metrics,
        render_active_sessions_gauge,
    )
    from {{ package_name }}.db.control import engine as _ctrl_engine

    body += auth_metrics.render_prometheus()
    try:
        with _ctrl_engine.control_session_factory()() as _cs:
            body += render_active_sessions_gauge(_cs)
    except Exception as _exc:  # control DB unreachable — omit gauge, never 500 /metrics
        from {{ package_name }}.logging_config import get_logger

        get_logger().warning(
            "auth_metrics_active_sessions_unavailable", error=str(_exc)
        )

    from {{ package_name }}.multitenantauth.tenancy.engine_registry import tenant_engines
    from {{ package_name }}.multitenantauth.tenancy.metrics import tenant_engine_metrics

    body += tenant_engines.render_pool_gauges()
    body += tenant_engine_metrics.render_prometheus()
{%- endif %}
{% if "workers" in batteries %}
    from {{ package_name }}.db.engine import SessionLocal
    from {{ package_name }}.tasks import dead_letter as _dead_letter

    try:
        with SessionLocal() as _session:
            body += _dead_letter.render_dlq_metrics(_session)
    except (
        Exception
    ) as _exc:  # DB unreachable — omit the DLQ gauge rather than 500 the endpoint
        from {{ package_name }}.logging_config import get_logger

        get_logger().warning("dlq_metrics_unavailable", error=str(_exc))
{% endif %}
    return PlainTextResponse(
        body,
        status_code=200,
        media_type="text/plain; version=0.0.4",
    )
