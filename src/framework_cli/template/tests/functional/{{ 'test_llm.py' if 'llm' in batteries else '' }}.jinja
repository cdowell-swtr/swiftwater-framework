"""LLM battery — functional tests for the /llm/complete route (mocked LiteLLM, no DB)."""

import litellm
import pytest
from fastapi.testclient import TestClient

from {{ package_name }}.config.settings import Settings
from {{ package_name }}.main import create_app


class _Msg:
    content = "the answer is 42"
    tool_calls = None


class _Choice:
    message = _Msg()


class _Usage:
    prompt_tokens = 5
    completion_tokens = 3
    prompt_tokens_details = None


class _Resp:
    choices = [_Choice()]
    usage = _Usage()


@pytest.fixture
def client(monkeypatch):
    monkeypatch.setattr(litellm, "completion", lambda **_: _Resp())
    monkeypatch.setattr(litellm, "completion_cost", lambda **_: 0.0)
    app = create_app(Settings(llm_api_key="k", serve_spa=False))
    with TestClient(app) as c:
        yield c


def test_complete_route_returns_text_and_usage(client):
    r = client.post("/llm/complete", json={"prompt": "what is the answer?"})
    assert r.status_code == 200
    body = r.json()
    assert body["text"] == "the answer is 42"
    assert body["usage"] == {"input": 5, "output": 3, "cache_read": 0}


def test_complete_route_exhaustion_maps_to_503(client, monkeypatch):
    def boom(**_):
        raise litellm.exceptions.RateLimitError(
            message="quota", model="m", llm_provider="anthropic"
        )

    monkeypatch.setattr(litellm, "completion", boom)
    r = client.post("/llm/complete", json={"prompt": "hi"})
    assert r.status_code == 503


def test_complete_route_provider_error_maps_to_502(client, monkeypatch):
    def boom(**_):
        raise litellm.exceptions.InternalServerError(
            message="down", model="m", llm_provider="anthropic"
        )

    monkeypatch.setattr(litellm, "completion", boom)
    r = client.post("/llm/complete", json={"prompt": "hi"})
    assert r.status_code == 502


def test_metrics_endpoint_includes_llm_series(client):
    client.post("/llm/complete", json={"prompt": "hi"})
    body = client.get("/metrics").text
    assert "app_llm_calls_total" in body
    assert "app_llm_cost_usd_total" in body
