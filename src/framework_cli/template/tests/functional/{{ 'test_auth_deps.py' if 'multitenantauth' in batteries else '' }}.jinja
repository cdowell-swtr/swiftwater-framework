# ── resource-scoped guard (A-F1) ─────────────────────────────────────────────────


def test_resource_grant_discrete_path_params(probe_app, control_engine):  # type: ignore[no-untyped-def]
    """A-F1: resource:view on a specific resource_id resolves via (membership, resource_id) —
    discrete path params, never re-parsed from a concatenated string. Member with a resource
    role → 200; member WITHOUT the resource role → 403; non-member → 404."""
    from {{ package_name }}.multitenantauth.authz.service import add_membership, assign_resource_role

    with Session(control_engine) as s:
        _seed_vocab(s)
        s.add(m.Tenant(id="acme", name="Acme", slug="acme", status="active", dsn="x"))
        s.flush()

        # User with resource role on widget-1.
        u_granted = _user(s, "rgranted@x.com")
        mem = add_membership(
            s,
            user_id=u_granted.id,
            tenant_id="acme",
            role_name="tenant.member",
            actor_id=None,
            invited=False,
        )
        assign_resource_role(
            s,
            membership_id=mem.id,
            resource_id="widget-1",
            role_name="resource.viewer",
            actor_id=None,
        )
        granted_token = _session_token(s, u_granted.id)

        # User with tenant membership but NO resource role.
        u_no_res = _user(s, "rnores@x.com")
        add_membership(
            s,
            user_id=u_no_res.id,
            tenant_id="acme",
            role_name="tenant.member",
            actor_id=None,
            invited=False,
        )
        no_res_token = _session_token(s, u_no_res.id)

        # Outsider with no membership.
        u_out = _user(s, "rout@x.com")
        out_token = _session_token(s, u_out.id)

    assert (
        _client(probe_app, granted_token)
        .get("/t/acme/resource/widget-1/view")
        .status_code
        == 200
    )  # has resource role
    assert (
        _client(probe_app, no_res_token)
        .get("/t/acme/resource/widget-1/view")
        .status_code
        == 403
    )  # member but no resource role
    assert (
        _client(probe_app, out_token).get("/t/acme/resource/widget-1/view").status_code
        == 404
    )  # non-member → 404-before-403


# ── single control_session per request ───────────────────────────────────────────


def test_single_control_session_across_chain(probe_app, control_engine):  # type: ignore[no-untyped-def]
    """FastAPI dependency caching means control_session is instantiated ONCE per request even
    though current_user, active_tenant (via guard), and guard all declare it as a dep. Verify
    the override fixture is only called once per probe request by counting instantiations."""
    call_count = {"n": 0}

    def _counting_cs():
        call_count["n"] += 1
        with Session(control_engine) as s:
            yield s

    # Overlay the counting override on top of the probe_app's existing override.
    probe_app.dependency_overrides[control_session] = _counting_cs

    from {{ package_name }}.multitenantauth.authz.service import add_membership

    with Session(control_engine) as s:
        _seed_vocab(s)
        s.add(m.Tenant(id="acme", name="Acme", slug="acme", status="active", dsn="x"))
        s.flush()
        u = _user(s, "cache@x.com")
        add_membership(
            s,
            user_id=u.id,
            tenant_id="acme",
            role_name="tenant.member",
            actor_id=None,
            invited=False,
        )
        token = _session_token(s, u.id)

    call_count["n"] = 0
    resp = _client(probe_app, token).get("/t/acme/probe")
    assert resp.status_code == 200
    assert call_count["n"] == 1, (
        f"control_session called {call_count['n']} times — expected 1 (FastAPI cache)"
    )

    # Restore original override.
    from {{ package_name }}.multitenantauth.deps import control_session as _cs_orig

    probe_app.dependency_overrides[control_session] = (
        probe_app.dependency_overrides.get(_cs_orig)
        or (
            lambda: (
                yield from probe_app.dependency_overrides.get(
                    control_session, _cs_orig
                )()
            )
        )
    )


# ── A-F10 guard: single inert subtree_exists ─────────────────────────────────────


def test_af10_single_inert_subtree_exists_construction_site():
    """A-F10: the battery has EXACTLY ONE construction site for subtree_exists in deps.py and
    its value is the deny lambda — it cannot be locally overridden to allow. This is a static
    grep guard verified at test time."""
    import re
    from pathlib import Path

    deps_src = (
        Path(__file__).parent.parent.parent
        / "src"
        / "{{ package_name }}"
        / "multitenantauth"
        / "deps.py"
    )
    text_content = deps_src.read_text()

    # Count occurrences of 'subtree_exists' as a dict key assignment.
    assignments = re.findall(r'"subtree_exists"\s*:', text_content)
    assert len(assignments) == 1, (
        f"Expected exactly 1 'subtree_exists' construction site in deps.py, found {len(assignments)}"
    )

    # The value must be the deny lambda (lambda that always returns False).
    # Find the subtree_exists line and assert it is the inert form.
    lines = text_content.splitlines()
    subtree_line = next(
        (ln for ln in lines if '"subtree_exists"' in ln and ":" in ln), None
    )
    assert subtree_line is not None
    assert "lambda" in subtree_line and "False" in subtree_line, (
        f"subtree_exists must be assigned the deny lambda (returns False), got: {subtree_line!r}"
    )
