def test_existing_tenant_but_nonmember_is_404_not_403(  # type: ignore[no-untyped-def]
    probe_app, control_engine
):
    """The leak case: the tenant EXISTS and is active, but the user has no membership. Must be
    404 (existence not leaked), never 403 — existence-not-leaked even when guard fires (A-F8)."""
    with Session(control_engine) as s:
        _seed_vocab(s)
        s.add(
            m.Tenant(id="acme", name="Acme", slug="acme", status="active", dsn="x")
        )  # exists + active
        s.flush()
        u = _user(s, "outsider@x.com")  # no membership in acme
        token = _session_token(s, u.id)
    assert _client(probe_app, token).get("/t/acme/probe").status_code == 404


