def test_consumer_resolver_receives_the_bare_resource_id(  # type: ignore[no-untyped-def]
    probe_app, control_engine
):
    """The tenant-free per-call contract: the consumer's resolver receives the BARE resource id as
    its second arg — exactly ``"widget-1"``, NOT the path dict and NOT a tenant-qualified composite
    (which would make the resolver pattern-blind / re-derive path-tenant). Assert the exact string,
    not truthiness, so a leaked path-dict or composite would fail this."""
    seen: dict[str, object] = {}
    with Session(control_engine) as s:
        token = _seed_acme_member(s, "bare-rid@x.com")

    def factory(cs, user, active_tenant_id):  # type: ignore[no-untyped-def]
        def grant(name, resource_id):  # type: ignore[no-untyped-def]
            seen["name"] = name
            seen["resource_id"] = resource_id
            return True

        return {"resource_grant": grant}

    register_authz_resolver_factory(factory)
    assert _status(probe_app, token, "/t/acme/resource/widget-1/view") == 200
    assert seen["name"] == "resource:view"
    # bare id — no dict, no "acme/" tenant segment
    assert seen["resource_id"] == "widget-1"


def test_nonmember_is_404_before_the_factory_is_ever_consulted(  # type: ignore[no-untyped-def]
    probe_app, control_engine
):
    """A registered factory NEVER sees an unresolved tenant: a non-member is 404 at the membership
    precondition, BEFORE the ctx/factory is built. Even a grant-all factory cannot rescue a
    non-member — the 404 precedes the GRANT path entirely."""
    called = {"n": 0}
    with Session(control_engine) as s:
        _seed_vocab(s)
        s.add(m.Tenant(id="acme", name="Acme", slug="acme", status="active", dsn="x"))
        s.flush()
        u = _user(s, "outsider-factory@x.com")  # NO membership in acme
        token = _session_token(s, u.id)

    def factory(cs, user, active_tenant_id):  # type: ignore[no-untyped-def]
        called["n"] += 1
        # grants if ever consulted
        return {"resource_grant": lambda name, resource_id: True}

    register_authz_resolver_factory(factory)
    assert _status(probe_app, token, "/t/acme/resource/widget-1/view") == 404
    assert called["n"] == 0  # the factory was never built for a non-member


