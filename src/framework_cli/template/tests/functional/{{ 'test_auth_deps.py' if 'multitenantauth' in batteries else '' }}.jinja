def test_registered_factory_grants_a_resource_leaf_through_the_guard(  # type: ignore[no-untyped-def]
    probe_app, control_engine
):
    """The core seam proof: a registered factory's resource_grant GRANTS a leaf the flat default
    DENIES. A bare member (no resource role) is 403 by default; after registering a factory that
    grants, the SAME request is 200 — the consumer's resolver runs THROUGH the battery guard."""
    with Session(control_engine) as s:
        # bare member, no resource role
        token = _seed_acme_member(s, "factory-grant@x.com")
    # baseline: the flat default denies (proves the 200 below comes from the factory).
    assert _status(probe_app, token, "/t/acme/resource/widget-1/view") == 403

    def factory(cs, user, active_tenant_id):  # type: ignore[no-untyped-def]
        # Tenant-free per-call contract: the resolver gets (perm_name, resource_id) only — the
        # tenant binds via the closure (active_tenant_id), never per call.
        def grant(name, resource_id):  # type: ignore[no-untyped-def]
            return name == "resource:view" and resource_id == "widget-1"

        return {"resource_grant": grant}

    register_authz_resolver_factory(factory)
    assert _status(probe_app, token, "/t/acme/resource/widget-1/view") == 200


