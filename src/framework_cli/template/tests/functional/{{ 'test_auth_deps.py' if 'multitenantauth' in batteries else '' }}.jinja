# ── shared vocabulary: minimum roles + permissions for tests ─────────────────────


def _seed_vocab(s: Session) -> None:
    """Seed minimum permission + role + bundle rows needed by the test suite.

    Task 17 (seed_authz) is deferred — create the vocabulary inline here.
    Roles: tenant.member (tenant:read), tenant.admin (tenant:read + tenant:manage-members),
           platform.admin (platform-tenant:provision), resource.viewer (resource:view).
    """
    from uuid import uuid4  # local import: only needed inside this helper

    # Permissions
    perms = [
        ("tenant:read", "tenant"),
        ("tenant:manage-members", "tenant"),
        ("platform-tenant:provision", "platform"),
        ("resource:view", "resource"),
    ]
    for name, domain in perms:
        s.execute(
            text(
                "INSERT INTO permission (name, domain, description, is_active) "
                "VALUES (:name, :domain, :desc, true) ON CONFLICT DO NOTHING"
            ),
            {"name": name, "domain": domain, "desc": name},
        )

    # Roles
    roles_def = [
        ("tenant.member", "tenant", {"tenant:read"}),
        ("tenant.admin", "tenant", {"tenant:read", "tenant:manage-members"}),
        ("platform.admin", "platform", {"platform-tenant:provision"}),
        ("resource.viewer", "resource", {"resource:view"}),
    ]
    role_ids: dict[str, object] = {}
    for rname, rdomain, _ in roles_def:
        rid = uuid4()
        s.execute(
            text(
                "INSERT INTO role (id, name, domain, description, is_builtin) "
                "VALUES (:id, :name, :domain, :desc, true) ON CONFLICT (name) DO NOTHING"
            ),
            {"id": rid, "name": rname, "domain": rdomain, "desc": rname},
        )
        # Re-read surviving id (may have lost ON CONFLICT race).
        row = s.execute(
            text("SELECT id FROM role WHERE name=:name"), {"name": rname}
        ).scalar_one()
        role_ids[rname] = row

    # Role–permission bundles
    for rname, _, grants in roles_def:
        rid = role_ids[rname]
        for pname in grants:
            s.execute(
                text(
                    "INSERT INTO role_permission (role_id, permission_name) "
                    "VALUES (:rid, :pname) ON CONFLICT DO NOTHING"
                ),
                {"rid": rid, "pname": pname},
            )
    s.flush()


