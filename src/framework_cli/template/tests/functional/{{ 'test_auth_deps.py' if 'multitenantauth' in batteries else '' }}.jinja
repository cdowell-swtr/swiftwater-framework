# ── 404-before-403 tests ──────────────────────────────────────────────────────────


def test_existing_tenant_but_nonmember_is_404_not_403(  # type: ignore[no-untyped-def]
    probe_app, control_engine
):
    """The leak case: the tenant EXISTS and is active, but the user has no membership. Must be
    404 (existence not leaked), never 403 — existence-not-leaked even when guard fires (A-F8)."""
    with Session(control_engine) as s:
        _seed_vocab(s)
        s.add(
            m.Tenant(id="acme", name="Acme", slug="acme", status="active", dsn="x")
        )  # exists + active
        s.flush()
        u = _user(s, "outsider@x.com")  # no membership in acme
        token = _session_token(s, u.id)
    assert _client(probe_app, token).get("/t/acme/probe").status_code == 404


def test_guard_only_route_nonmember_is_404(probe_app, control_engine):  # type: ignore[no-untyped-def]
    """A-F8: guard-only route (no active_tenant dep) must still return 404 to a non-member of an
    existing tenant — the inline membership re-check inside guard is load-bearing."""
    with Session(control_engine) as s:
        _seed_vocab(s)
        s.add(m.Tenant(id="acme", name="Acme", slug="acme", status="active", dsn="x"))
        s.flush()
        u = _user(s, "outsider2@x.com")  # no membership
        token = _session_token(s, u.id)
    # /guard-only/{tenant_id}/action does NOT depend on active_tenant — guard must enforce 404 itself.
    assert _client(probe_app, token).get("/guard-only/acme/action").status_code == 404


