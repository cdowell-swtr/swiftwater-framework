"""The request authorization chain (deps.py): current_user (401), active_tenant/guard membership
precondition (404 before 403), domain-scoped permission evaluation (403/200). Exercised via a probe
app over the control plane — no tenant DB needed (tenant_db is Phase 2).

Security properties asserted:
- 401 on missing/expired/disabled session (authn gate).
- 404-before-403: a non-member of an EXISTING active tenant gets 404, NEVER 403 (existence leak).
- A-F7: a member of a suspended/provisioning tenant gets 404.
- A-F8: a guard-only route (binds {tenant_id} but does NOT depend on active_tenant) still returns
  404 to a non-member — the inline membership-404 re-check in guard is load-bearing.
- 403 on a valid member who lacks the required permission.
- A single control_session is shared across the dep chain (FastAPI caches it per-request).
"""

from datetime import datetime, timedelta, timezone

import pytest
from fastapi import Depends, FastAPI
from fastapi.testclient import TestClient
from sqlalchemy import Engine, create_engine, make_url, text
from sqlalchemy.orm import Session

from {{ package_name }}.db.control import models as m
from {{ package_name }}.db.control.base import ControlBase
from {{ package_name }}.multitenantauth.authz.expr import Perm
from {{ package_name }}.multitenantauth.authn.tokens import mint
from {{ package_name }}.multitenantauth.deps import control_session, guard

pytestmark = pytest.mark.usefixtures("_clean_control")


