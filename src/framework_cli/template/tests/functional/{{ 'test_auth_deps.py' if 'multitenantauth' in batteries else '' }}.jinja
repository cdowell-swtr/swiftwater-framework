    @app.get(
        "/t/{tenant_id}/resource/{resource_id}/view",
        dependencies=[
            Depends(
                guard(
                    Perm(
                        "resource:view",
                        on="tenant:{tenant_id}/resource:{resource_id}",
                    )
                )
            )
        ],
    )
    def _resource_view() -> dict:
        return {"ok": True}

    yield app
    get_settings.cache_clear()


# ── helpers ───────────────────────────────────────────────────────────────────────


def _user(s: Session, email: str, **kw) -> m.AppUser:
    u = m.AppUser(email=email, email_canonical=email, born="operator", **kw)
    s.add(u)
    s.flush()
    return u


def _session_token(s: Session, user_id, *, ttl: timedelta = timedelta(hours=1)) -> str:
    raw, token_hash = mint()
    s.add(
        m.Session(
            token_hash=token_hash,
            user_id=user_id,
            expires_at=datetime.now(timezone.utc) + ttl,
        )
    )
    s.commit()
    return raw


def _client(app: FastAPI, token: str | None = None) -> TestClient:
    c = TestClient(app)
    if token:
        c.headers["authorization"] = f"Bearer {token}"
    return c


