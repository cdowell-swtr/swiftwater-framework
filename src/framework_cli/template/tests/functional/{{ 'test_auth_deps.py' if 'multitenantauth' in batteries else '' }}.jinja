    monkeypatch.setenv("APP_SESSION_PEPPER", "deps-test-pepper")
    from {{ package_name }}.config.settings import get_settings

    get_settings.cache_clear()

    app = FastAPI()

    def _cs():
        with Session(control_engine) as s:
            yield s

    app.dependency_overrides[control_session] = _cs

    # Standard tenant-scoped read (needs tenant:read).
    @app.get(
        "/t/{tenant_id}/probe",
        dependencies=[Depends(guard(Perm("tenant:read", on="tenant:{tenant_id}")))],
    )
    def _probe() -> dict:
        return {"ok": True}

    # Tenant-scoped admin action (needs tenant:manage-members).
    @app.get(
        "/t/{tenant_id}/admin",
        dependencies=[
            Depends(guard(Perm("tenant:manage-members", on="tenant:{tenant_id}")))
        ],
    )
