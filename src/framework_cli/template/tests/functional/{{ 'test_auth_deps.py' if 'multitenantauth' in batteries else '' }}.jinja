    # Platform-scoped action.
    @app.get(
        "/platform/probe",
        dependencies=[Depends(guard(Perm("platform-tenant:provision", on="platform")))],
    )
    def _plat() -> dict:
        return {"ok": True}

    # Guard-only route: binds {tenant_id} but does NOT depend on active_tenant (A-F8).
    @app.get(
        "/guard-only/{tenant_id}/action",
        dependencies=[Depends(guard(Perm("tenant:read", on="tenant:{tenant_id}")))],
    )
    def _guard_only() -> dict:
