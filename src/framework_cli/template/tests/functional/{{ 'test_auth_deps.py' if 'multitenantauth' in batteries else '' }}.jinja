# ── helpers ───────────────────────────────────────────────────────────────────────


def _user(s: Session, email: str, **kw) -> m.AppUser:
    u = m.AppUser(email=email, email_canonical=email, born="operator", **kw)
    s.add(u)
    s.flush()
    return u


def _session_token(s: Session, user_id, *, ttl: timedelta = timedelta(hours=1)) -> str:
    raw, token_hash = mint()
    s.add(
        m.Session(
            token_hash=token_hash,
            user_id=user_id,
            expires_at=datetime.now(timezone.utc) + ttl,
        )
    )
    s.commit()
    return raw


def _client(app: FastAPI, token: str | None = None) -> TestClient:
    c = TestClient(app)
    if token:
        c.headers["authorization"] = f"Bearer {token}"
    return c


def _status(app: FastAPI, token: str | None, url: str) -> int:
    """GET ``url`` as ``token`` and return the status code (keeps the seam-test asserts short)."""
    return _client(app, token).get(url).status_code


def _seed_acme_member(s: Session, email: str, *, resource_role: bool = False) -> str:
    """Seed the shared vocab + an active 'acme' tenant + a bare tenant.member (optionally also a
    resource.viewer on 'widget-1'); return that member's session token. Used by the DV-5 seam
    tests, where a bare member is denied by the flat default and a resource-role member is granted
    — so 'fail-closed' tests can prove the deny comes from the seam, not from a missing grant."""
    from {{ package_name }}.multitenantauth.authz.service import (
        add_membership,
        assign_resource_role,
    )

    _seed_vocab(s)
    s.add(m.Tenant(id="acme", name="Acme", slug="acme", status="active", dsn="x"))
    s.flush()
    u = _user(s, email)
    mem = add_membership(
        s,
        user_id=u.id,
        tenant_id="acme",
        role_name="tenant.member",
        actor_id=None,
        invited=False,
    )
    if resource_role:
        assign_resource_role(
            s,
            membership_id=mem.id,
            resource_id="widget-1",
            role_name="resource.viewer",
            actor_id=None,
        )
    return _session_token(s, u.id)


