# ── Route allowlists ───────────────────────────────────────────────────────────

# Routes that legitimately carry NO permission guard. Each entry is a deliberate, reviewed decision:
# truly-public (no auth) OR authenticated-self (current_user, returns the caller's own data).
PUBLIC = {
    "/auth/signup",
    "/auth/login",
    "/auth/logout",
    "/auth/set-password",  # pre-auth: invite token redemption
    "/auth/me",  # authenticated-self (requires current_user, no resource permission)
    "/heartbeat",
    "/health",
    "/ready",  # liveness/readiness probes
    "/metrics",  # observability
    "/openapi.json",
    "/docs",
    "/docs/oauth2-redirect",
    "/redoc",  # framework defaults
    # Scaffold demo route — unguarded by design; remove or guard before going to production.
    # GET only — a POST/PUT /items would also be exempted; guard or remove before production.
    "/items",
    # ── Sibling-battery routes (contributed by OTHER batteries, not multitenantauth) ──
    # The auth-fitness suite does NOT assert authz on these: the auth battery doesn't own them and
    # can't guard them, and each sibling battery carries its own security model (e.g. webhooks
    # verify an HMAC signature). If one of these handles sensitive data in YOUR app, add your own
    # guard — the auth battery cannot do it for you. Gated per battery so only the routes that
    # actually render are exempted.
{%- if "agents" in batteries %}
    "/agents/run",
{%- endif %}
{%- if "react" in batteries %}
    "/internal/rum",
{%- endif %}
{%- if "graphql" in batteries %}
    "/graphql",
{%- endif %}
{%- if "llm" in batteries %}
    "/llm/complete",
{%- endif %}
{%- if "webhooks" in batteries %}
    "/webhooks",
{%- endif %}
}

# Routes that use an INLINE permission check instead of a guard dependency. Each is a deliberate,
# reviewed decision: the inline path is required to enforce visibility-before-permission ordering
# (e.g. hidden resources must 404, not 403, for unauthenticated callers).
INLINE_AUTHZ: set[tuple[str, str]] = set()  # the tenant_db arm re-arms in Phase 2


# ── Helpers ────────────────────────────────────────────────────────────────────


def _api_routes(app: FastAPI) -> list[APIRoute]:
    out: list[APIRoute] = []

    def walk(routes) -> None:  # type: ignore[type-arg]
        for r in routes:
            if isinstance(r, APIRoute):
                out.append(r)
            elif isinstance(r, _IncludedRouter):
                walk(r.original_router.routes)

    walk(app.routes)
    return out


def _authorized(route: APIRoute) -> Authorized | None:
    for d in route.dependant.dependencies:
        a = getattr(getattr(d, "call", None), "__authorized__", None)
        if a is not None:
            return a
    return None


def _requires(route: APIRoute, target: object) -> bool:
    def walk(dependant) -> bool:  # type: ignore[type-arg]
        return any(d.call is target or walk(d) for d in dependant.dependencies)

    return walk(route.dependant)


def _is_inline_exempt(route: APIRoute) -> bool:
    """True iff every non-implicit method on this route is explicitly listed in INLINE_AUTHZ.
    Keyed by (method, path) so a future PUT at the same path is NOT silently exempted."""
    real_methods = (route.methods or set()) - {"HEAD", "OPTIONS"}
    return bool(real_methods) and all(
        (meth, route.path) in INLINE_AUTHZ for meth in real_methods
    )


