# ── T1: deny-by-default ────────────────────────────────────────────────────────


def test_T1_no_unguarded_route(app: FastAPI) -> None:
    """Deny-by-default: a route is compliant iff it is guarded, requires current_user, or is in the
    reviewed PUBLIC allowlist. A new route that is none of these fails — you cannot forget authz."""
    offenders = []
    for route in _api_routes(app):
        if route.path in PUBLIC:
            continue
        if _authorized(route) is not None or _requires(route, current_user):
            continue
        offenders.append(f"{sorted(route.methods or [])} {route.path}")
    assert offenders == [], (
        f"unguarded routes (add a guard or allowlist with justification): {offenders}"
    )


# ── T1b: tenant-data routes must be guarded ───────────────────────────────────


def test_T1b_tenant_data_routes_must_be_guarded(app: FastAPI) -> None:
    """Stronger than T1: any route whose dependency tree includes ``active_tenant`` MUST carry a
    permission guard — ``current_user`` alone is not enough. Catches a future tenant-data route that
    wired the session but forgot ``guard(...)``.

    Note: the tenant_db arm (for routes using the per-tenant DB session) re-arms in Phase 2 when
    physical per-tenant routing is introduced.
    """
    offenders = []
    for route in _api_routes(app):
        touches_tenant = _requires(route, active_tenant)
        if not touches_tenant:
            continue
        if _authorized(route) is None and not _is_inline_exempt(route):
            offenders.append(f"{sorted(route.methods or [])} {route.path}")
    assert offenders == [], (
        f"tenant-data routes without a permission guard: {offenders}"
    )


# ── T2: tenant routes bind {tenant_id} ────────────────────────────────────────


def test_T2_tenant_routes_bind_tenant_id(app: FastAPI) -> None:
    """Every route with {tenant_id} must be guarded AND bind {tenant_id} in its expression (catches a
    constant/foreign tenant). Routes in INLINE_AUTHZ are exempt — they check tenant binding inline."""
    offenders = []
    for route in _api_routes(app):
        if "{tenant_id}" not in route.path:
            continue
        if _is_inline_exempt(route):
            continue
        auth = _authorized(route)
        if auth is None or "tenant_id" not in auth.resource_params():
            offenders.append(route.path)
    assert offenders == [], f"tenant routes not bound to {{tenant_id}}: {offenders}"


# ── T3: response models must not carry the authz AST ──────────────────────────


def _collect_field_types(model: type, seen: set | None = None) -> set:  # type: ignore[type-arg]
    seen = seen or set()
    if model in seen:
        return set()
    seen.add(model)
    types: set = set()  # type: ignore[type-arg]
    for field in getattr(model, "model_fields", {}).values():
        ann = field.annotation
        types.add(ann)
        for arg in getattr(ann, "__args__", ()):  # unwrap list[X], Optional[X], etc.
            types.add(arg)
            if hasattr(arg, "model_fields"):
                types |= _collect_field_types(arg, seen)
        if hasattr(ann, "model_fields"):
            types |= _collect_field_types(ann, seen)
    return types


def test_T3_response_models_never_carry_policy(app: FastAPI) -> None:
    """No response model on any route should reference the internal authz AST types."""
    forbidden = {Authorized, Perm, ALL, ANY}
    bad = []
    for route in _api_routes(app):
        model = route.response_model
        if model is None:
            continue
        if forbidden & ({model} | _collect_field_types(model)):
            bad.append(route.path)
    assert bad == [], f"response model carries the authz AST: {bad}"


# ── T4: policy vocabulary absent from OpenAPI ─────────────────────────────────


def test_T4_policy_vocabulary_absent_from_openapi(app: FastAPI) -> None:
    """The permission/role vocabulary must never appear ANYWHERE in the OpenAPI document.

    The full document (descriptions included) is served on PUBLIC endpoints — /openapi.json,
    /docs, /redoc — so a permission/role string in a route's docstring OR in a request-body
    schema default is world-readable and lets a client enumerate the internal access-control
    policy. We scan the WHOLE document (no description-stripping); a faithful suite fixes the
    leak at the source (the routes), it never blinds the check.
    """
    import json

    blob = json.dumps(app.openapi())
    # Vocabulary = every permission name referenced in a guard expression, PLUS the seeded
    # role names. We scan guard Perm leaves + the known builtin roles rather than importing a
    # static registry, because the battery has no permissions.py / roles catalog yet.
    # Task-17 follow-up: import permissions.ALL_NAMES + roles.BUILTIN_BUNDLES once the seed
    # catalog ships, for complete static vocab coverage.
    vocab: set[str] = {"tenant.admin", "tenant.member", "platform.admin"}
    for route in _api_routes(app):
        auth = _authorized(route)
        if auth is not None:
            for leaf in auth.perm_leaves():
                vocab.add(leaf.name)
    leaked = [token for token in vocab if token in blob]
    assert leaked == [], (
        f"access-control vocabulary leaked into public OpenAPI: {leaked}"
    )


# ── T4b: 403 body is the generic constant ─────────────────────────────────────


def test_T4b_403_body_is_the_generic_constant(
    probe: FastAPI, fitness_engine: Engine, monkeypatch: pytest.MonkeyPatch
) -> None:
    """A real 403 must carry exactly AUTHZ_FORBIDDEN_DETAIL and never echo the required permission."""
    _seed_vocab(Session(fitness_engine))

    with Session(fitness_engine) as s:
        # Truncate only what matters so we're clean for this test.
        s.execute(
            text(
                "TRUNCATE TABLE session, authz_event, platform_role_assignment, "
                "resource_role_assignment, tenant_role_assignment, tenant_membership, "
                "app_user, tenant, tenant_slug_history RESTART IDENTITY CASCADE"
            )
        )
        s.commit()
        _seed_vocab(s)

        s.add(m.Tenant(id="acme", name="Acme", slug="acme", status="active", dsn="x"))
        s.flush()
        user = m.AppUser(
            email="probe@example.com",
            email_canonical="probe@example.com",
            born="operator",
        )
        s.add(user)
        s.flush()
        # Add user as tenant.member (NOT tenant.admin → lacks tenant:manage-members).
        from {{ package_name }}.multitenantauth.authz.service import add_membership

        add_membership(
            s,
            user_id=user.id,
            tenant_id="acme",
            role_name="tenant.member",
            actor_id=None,
            invited=False,
        )
        raw, token_hash = mint()
        s.add(
            m.Session(
                token_hash=token_hash,
                user_id=user.id,
                expires_at=datetime.now(timezone.utc) + timedelta(hours=1),
            )
        )
        s.commit()

    c = TestClient(probe)
    c.headers["authorization"] = f"Bearer {raw}"
    r = c.get("/t/acme/x")
    assert r.status_code == 403
    assert r.json()["detail"] == AUTHZ_FORBIDDEN_DETAIL
    assert "tenant:manage-members" not in r.text
