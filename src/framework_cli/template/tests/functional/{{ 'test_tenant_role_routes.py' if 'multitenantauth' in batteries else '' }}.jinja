_CONTROL_TABLES = (
    "invite_token, session, authz_event, platform_role_assignment, "
    "resource_role_assignment, tenant_role_assignment, tenant_membership, "
    "role_permission, permission, role, app_user, tenant, tenant_slug_history"
)


@pytest.fixture
def _clean_tr(tr_engine: Engine) -> Iterator[None]:
    yield
    with tr_engine.begin() as conn:
        conn.execute(text(f"TRUNCATE TABLE {_CONTROL_TABLES} CASCADE"))


def _seed_vocab(s: Session) -> None:
    """Seed the minimum roles/permissions the routes need."""
    from uuid import uuid4

    perms = [
        ("tenant:read", "tenant"),
        ("tenant:manage-members", "tenant"),
        ("platform:provision-tenant", "platform"),
    ]
    for name, domain in perms:
        s.execute(
            text(
                "INSERT INTO permission (name, domain, description, is_active) "
                "VALUES (:name, :domain, :desc, true) ON CONFLICT DO NOTHING"
            ),
            {"name": name, "domain": domain, "desc": name},
        )
    roles_def = [
        ("tenant.member", "tenant", {"tenant:read"}),
        ("tenant.admin", "tenant", {"tenant:read", "tenant:manage-members"}),
        ("platform.admin", "platform", {"platform:provision-tenant"}),
    ]
    role_ids: dict[str, object] = {}
    for rname, rdomain, _ in roles_def:
        s.execute(
            text(
                "INSERT INTO role (id, name, domain, description, is_builtin) "
                "VALUES (:id, :name, :domain, :desc, true) ON CONFLICT (name) DO NOTHING"
            ),
            {"id": uuid4(), "name": rname, "domain": rdomain, "desc": rname},
        )
        role_ids[rname] = s.execute(
            text("SELECT id FROM role WHERE name=:name"), {"name": rname}
        ).scalar_one()
    for rname, _, grants in roles_def:
        for pname in grants:
            s.execute(
                text(
                    "INSERT INTO role_permission (role_id, permission_name) "
                    "VALUES (:rid, :pname) ON CONFLICT DO NOTHING"
                ),
                {"rid": role_ids[rname], "pname": pname},
            )


def _build_probe(tr_engine: Engine, monkeypatch) -> TestClient:
    monkeypatch.setenv("APP_ENVIRONMENT", "dev")
    monkeypatch.setenv("APP_SESSION_PEPPER", "tr-session-pepper")
    monkeypatch.setenv("APP_PASSWORD_PEPPER", "tr-password-pepper")
    monkeypatch.setenv("APP_SESSION_COOKIE_SECURE", "false")
    from {{ package_name }}.config.settings import get_settings

    get_settings.cache_clear()

    with Session(tr_engine) as s:
        _seed_vocab(s)
        s.commit()

    app = FastAPI()
    app.include_router(auth_router)
    app.include_router(tenants_router)
    app.include_router(roles_router)

    def _cs() -> Iterator[Session]:
        with Session(tr_engine) as s:
            yield s

    app.dependency_overrides[control_session] = _cs
    return TestClient(app)


@pytest.fixture
def probe(tr_engine: Engine, monkeypatch) -> Iterator[TestClient]:
    client = _build_probe(tr_engine, monkeypatch)
    try:
        yield client
    finally:
        client.close()
        from {{ package_name }}.config.settings import get_settings

        get_settings.cache_clear()


# ── helpers ───────────────────────────────────────────────────────────────────


def _signup_and_login(client: TestClient, email: str, slug: str) -> tuple[str, str]:
    """Signup a founder+tenant and return (tenant_id, cookie_header)."""
    r = client.post(
        "/auth/signup",
        json={
            "email": email,
            "password": "a-secure-password-12",
            "tenant_name": slug.title(),
            "slug": slug,
        },
    )
    assert r.status_code == 201, r.text
    tenant_id: str = r.json()["tenant_id"]
    cookie = r.headers["set-cookie"].split(";")[0]
    return tenant_id, cookie


def _headers(cookie: str) -> dict:
    return {"Cookie": cookie}


# A no-cookie header dict: overrides the TestClient's persistent cookie jar so the request
# is treated as unauthenticated (used by the 401 test cases below).
_NO_COOKIE: dict = {"Cookie": ""}


def _user_id(tr_engine: Engine, email_canonical: str) -> object:
    """Return the app_user.id for *email_canonical*."""
    with Session(tr_engine) as s:
        return s.execute(
            text("SELECT id FROM app_user WHERE email_canonical=:e"),
            {"e": email_canonical},
        ).scalar_one()


def _grant_platform_admin(tr_engine: Engine, email_canonical: str) -> None:
    """Grant the seeded ``platform.admin`` role to the user with *email_canonical*."""
    from {{ package_name }}.multitenantauth.authz.service import add_platform_role

    uid = _user_id(tr_engine, email_canonical)
    with Session(tr_engine) as s:
        add_platform_role(s, user_id=uid, role_name="platform.admin", actor_id=None)
        s.commit()


def _make_plain_member(
    probe: TestClient, admin_cookie: str, tenant_id: str, user_id: object
) -> str:
    """Admin adds *user_id* as a plain ``tenant.member`` of *tenant_id*; return membership_id."""
    r = probe.post(
        f"/tenants/{tenant_id}/members",
        headers=_headers(admin_cookie),
        json={"user_id": str(user_id), "role_name": "tenant.member"},
    )
    assert r.status_code == 201, r.text
    return r.json()["membership_id"]


