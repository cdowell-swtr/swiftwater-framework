# ── Layer-2 error-surface regressions ─────────────────────────────────────────


def test_provision_tenant_duplicate_slug_is_generic_409(
    probe: TestClient, tr_engine: Engine
) -> None:
    """A duplicate slug → a GENERIC 409 that never reveals the colliding tenant's opaque id
    (Layer-2 finding A)."""
    _, cookie = _signup_and_login(probe, "dupadmin@prov.com", "dupadmin")
    _grant_platform_admin(tr_engine, "dupadmin@prov.com")
    r1 = probe.post(
        "/tenants",
        headers=_headers(cookie),
        json={"name": "First", "slug": "dup-slug"},
    )
    assert r1.status_code == 201, r1.text
    first_id = r1.json()["tenant_id"]
    r2 = probe.post(
        "/tenants",
        headers=_headers(cookie),
        json={"name": "Second", "slug": "dup-slug"},
    )
    assert r2.status_code == 409
    assert first_id not in r2.text  # the colliding tenant's opaque id must NOT leak
    assert r2.json()["detail"] == "Tenant slug unavailable"


