def test_grant_role_wrong_domain_is_400(probe: TestClient, tr_engine: Engine) -> None:
    """Granting a platform-domain role via the tenant role route → 400 (DomainMismatchError),
    not an uncaught 500 (Layer-2 finding D)."""
    admin_tid, admin_cookie = _signup_and_login(probe, "wdadmin@rho2.com", "wdadmin")
    _signup_and_login(probe, "wdmem@sigma2.com", "wdmem")
    new_uid = _user_id(tr_engine, "wdmem@sigma2.com")
    r_add = probe.post(
        f"/tenants/{admin_tid}/members",
        headers=_headers(admin_cookie),
        json={"user_id": str(new_uid), "role_name": "tenant.member"},
    )
    assert r_add.status_code == 201
    mid = r_add.json()["membership_id"]
    r = probe.post(
        f"/tenants/{admin_tid}/members/{mid}/roles",
        headers=_headers(admin_cookie),
        json={"role_name": "platform.admin"},  # platform-domain role on a tenant route
    )
    assert r.status_code == 400
