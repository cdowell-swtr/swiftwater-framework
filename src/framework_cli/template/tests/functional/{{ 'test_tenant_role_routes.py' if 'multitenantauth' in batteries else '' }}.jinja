def test_add_member_missing_perm_gets_403(probe: TestClient, tr_engine: Engine) -> None:
    """A tenant.member (no manage-members) gets 403 on POST /members."""
    admin_tid, admin_cookie = _signup_and_login(probe, "admin@theta.com", "theta")
    # Create a second user in the same tenant with member role
    member_tid, member_cookie = _signup_and_login(probe, "member@iota.com", "iota")
    with Session(tr_engine) as s:
        member_user = s.execute(
            text("SELECT id FROM app_user WHERE email_canonical='member@iota.com'")
        ).scalar_one()
    # Admin adds the other user as a plain member of theta
    probe.post(
        f"/tenants/{admin_tid}/members",
        headers=_headers(admin_cookie),
        json={"user_id": str(member_user), "role_name": "tenant.member"},
    )
    # Now that member tries to add someone else — they lack manage-members → 403
    r = probe.post(
        f"/tenants/{admin_tid}/members",
        headers=_headers(member_cookie),
        json={"user_id": str(uuid.uuid4()), "role_name": "tenant.member"},
    )
    assert r.status_code == 403


