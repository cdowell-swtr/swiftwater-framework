"""Tenancy control-plane model tests: Tenant registry, slug history, and membership.

Ported from meridian tests/functional/test_tenancy.py (model-schema portion only;
provisioning/cross-tenant-isolation tests are Phase 2 and import modules not present
in this battery).

Key invariants under test:
- `tenant.id` is opaque and NOT derived from slug.
- `tenant.slug` is UNIQUE + DNS-label-safe (RFC-1123 label CHECK).
- `tenant.status` rejects invalid values.
- `tenant_membership` enforces UNIQUE(user_id, tenant_id).
- `tenant_slug_history` maps a retired slug to its tenant.
- `invite_token.membership_id` FK to `tenant_membership` round-trips (Task-4 deferral).
"""

from __future__ import annotations

import re
from datetime import datetime, timezone

import pytest
from sqlalchemy import Engine, create_engine, inspect, make_url, text
from sqlalchemy.exc import IntegrityError
from sqlalchemy.orm import Session

from {{ package_name }}.db.control import models as m
from {{ package_name }}.db.control.base import ControlBase


