# ── helpers ───────────────────────────────────────────────────────────────────


def _tenant(s: Session, *, slug: str = "acme", name: str = "Acme Inc") -> m.Tenant:
    t = m.Tenant(name=name, slug=slug, dsn=f"postgresql+psycopg://x/{slug}")
    s.add(t)
    s.flush()
    return t


def _user(s: Session, email: str = "a@x.io") -> m.AppUser:
    u = m.AppUser(email=email, email_canonical=email.lower(), born="operator")
    s.add(u)
    s.flush()
    return u


# ── tests — table existence ───────────────────────────────────────────────────


def test_tenancy_tables_exist(control_engine: Engine) -> None:
    names = set(inspect(control_engine).get_table_names())
    assert {"tenant", "tenant_membership", "tenant_slug_history"} <= names


# ── tests — Tenant.id is opaque (not derived from slug) ──────────────────────


def test_tenant_id_is_opaque_not_derived_from_slug(control_engine: Engine) -> None:
    """Tenant.id must be auto-generated and NEVER contain or equal the slug.

    We pass only name+slug (no explicit id) to exercise the generator. The id must:
    - match the safe charset ^[a-z0-9_]+$ (DB-name component safe)
    - not equal the slug
    - not contain the slug as a substring
    """
    with Session(control_engine) as s:
        t = _tenant(s, slug="acme")
        s.commit()
        tid, tslug = t.id, t.slug

    assert tid != tslug, "id must not equal slug"
    assert tslug not in tid, "id must not contain the slug"
    assert re.fullmatch(r"[a-z0-9_]+", tid), f"id charset violation: {tid!r}"


def test_tenant_id_is_immutable_across_slug_change(control_engine: Engine) -> None:
    """Changing the slug must not affect the id."""
    with Session(control_engine) as s:
        t = _tenant(s, slug="original")
        s.commit()
        original_id = t.id

    with Session(control_engine) as s:
        t = s.get(m.Tenant, original_id)
        assert t is not None
        t.slug = "renamed"
        s.commit()

    with Session(control_engine) as s:
        t = s.get(m.Tenant, original_id)
        assert t is not None
        assert t.id == original_id, "id changed after slug rename"
        assert t.slug == "renamed"


# ── tests — Tenant.slug DNS-label CHECK ──────────────────────────────────────


def test_slug_unique_constraint(control_engine: Engine) -> None:
    with Session(control_engine) as s:
        _tenant(s, slug="acme")
        s.commit()
    with Session(control_engine) as s, pytest.raises(IntegrityError):
        _tenant(s, slug="acme", name="Acme Dupe")
        s.commit()


def test_slug_rejects_uppercase(control_engine: Engine) -> None:
    with Session(control_engine) as s, pytest.raises(IntegrityError):
        _tenant(s, slug="Acme")
        s.commit()


def test_slug_rejects_underscore_and_bad_chars(control_engine: Engine) -> None:
    """Bad_Slug has an underscore — valid id charset but invalid DNS label."""
    with Session(control_engine) as s, pytest.raises(IntegrityError):
        _tenant(s, slug="Bad_Slug")
        s.commit()


def test_slug_rejects_leading_hyphen(control_engine: Engine) -> None:
    with Session(control_engine) as s, pytest.raises(IntegrityError):
        _tenant(s, slug="-x")
        s.commit()


def test_slug_rejects_trailing_hyphen(control_engine: Engine) -> None:
    with Session(control_engine) as s, pytest.raises(IntegrityError):
        _tenant(s, slug="x-")
        s.commit()


def test_slug_allows_hyphen_in_middle(control_engine: Engine) -> None:
    with Session(control_engine) as s:
        _tenant(s, slug="my-tenant")
        s.commit()  # must not raise


def test_slug_rejects_over_63_chars(control_engine: Engine) -> None:
    """The DNS-label CHECK enforces ≤63 chars (char_length check, not varchar truncation)."""
    long_slug = "a" * 64
    with Session(control_engine) as s, pytest.raises(IntegrityError):
        _tenant(s, slug=long_slug)
        s.commit()


# ── tests — Tenant.status CHECK ──────────────────────────────────────────────


def test_status_accepts_valid_values(control_engine: Engine) -> None:
    for status in ("provisioning", "active", "suspended"):
        with Session(control_engine) as s:
            t = m.Tenant(
                name=f"T-{status}",
                slug=f"t-{status}",
                dsn=f"postgresql+psycopg://x/{status}",
                status=status,
            )
            s.add(t)
            s.commit()  # must not raise
        with control_engine.begin() as conn:
            conn.execute(text("TRUNCATE TABLE tenant CASCADE"))


def test_status_rejects_invalid_value(control_engine: Engine) -> None:
    with Session(control_engine) as s, pytest.raises(IntegrityError):
        s.add(
            m.Tenant(
                name="Bad Status",
                slug="bad-status",
                dsn="postgresql+psycopg://x/bad",
                status="deleted",  # not in the allowed set
            )
        )
        s.commit()


# ── tests — TenantMembership uniqueness ──────────────────────────────────────


def test_membership_unique_user_tenant(control_engine: Engine) -> None:
    """UNIQUE(user_id, tenant_id) — duplicate membership is rejected."""
    with Session(control_engine) as s:
        t = _tenant(s)
        u = _user(s)
        s.add(m.TenantMembership(user_id=u.id, tenant_id=t.id))
        s.commit()
        saved_tid = t.id
        saved_uid = u.id

    with Session(control_engine) as s:
        t2 = s.get(m.Tenant, saved_tid)
        u2 = s.get(m.AppUser, saved_uid)
        assert t2 is not None and u2 is not None
        s.add(m.TenantMembership(user_id=u2.id, tenant_id=t2.id))
        with pytest.raises(IntegrityError):
            s.commit()


def test_membership_allows_same_user_in_different_tenants(
    control_engine: Engine,
) -> None:
    """A user CAN join multiple tenants — only (user_id, tenant_id) pairs must be unique."""
    with Session(control_engine) as s:
        t1 = _tenant(s, slug="alpha", name="Alpha")
        t2 = _tenant(s, slug="beta", name="Beta")
        u = _user(s)
        s.add(m.TenantMembership(user_id=u.id, tenant_id=t1.id))
        s.add(m.TenantMembership(user_id=u.id, tenant_id=t2.id))
        s.commit()  # must not raise


# ── tests — TenantSlugHistory ─────────────────────────────────────────────────


def test_slug_history_maps_retired_slug_to_tenant(control_engine: Engine) -> None:
    """A retired slug row maps back to the tenant that held it (for 301 redirects)."""
    with Session(control_engine) as s:
        t = _tenant(s, slug="newslug")
        s.commit()
        tenant_id = t.id

    with Session(control_engine) as s:
        hist = m.TenantSlugHistory(
            slug="oldslug",
            tenant_id=tenant_id,
            reserved_until=datetime(2099, 1, 1, tzinfo=timezone.utc),
        )
        s.add(hist)
        s.commit()

    with Session(control_engine) as s:
        row = s.get(m.TenantSlugHistory, "oldslug")
        assert row is not None
        assert row.tenant_id == tenant_id
        assert row.reserved_until is not None


def test_slug_history_retired_at_defaults_to_now(control_engine: Engine) -> None:
    with Session(control_engine) as s:
        t = _tenant(s)
        s.commit()
        tenant_id = t.id

    with Session(control_engine) as s:
        hist = m.TenantSlugHistory(slug="old-acme", tenant_id=tenant_id)
        s.add(hist)
        s.commit()

    with Session(control_engine) as s:
        row = s.get(m.TenantSlugHistory, "old-acme")
        assert row is not None
        assert row.retired_at is not None


# ── tests — InviteToken FK to TenantMembership (Task-4 deferral) ─────────────


def test_invite_token_membership_fk_round_trips(control_engine: Engine) -> None:
    """InviteToken.membership_id (nullable) FKs tenant_membership.id.

    This closes the Task-4 deferral: now that TenantMembership exists, the FK
    can be exercised end-to-end. Tests the platform (membership_id=None) and
    tenant-invite (membership_id set) cases.
    """
    with Session(control_engine) as s:
        t = _tenant(s)
        u = _user(s)
        s.flush()
        membership = m.TenantMembership(user_id=u.id, tenant_id=t.id)
        s.add(membership)
        s.flush()

        # Platform invite — no membership.
        platform_tok = m.InviteToken(
            token_hash="p" * 64,
            user_id=u.id,
            membership_id=None,
            expires_at=datetime(2099, 1, 1, tzinfo=timezone.utc),
        )
        # Tenant invite — membership_id set.
        tenant_tok = m.InviteToken(
            token_hash="t" * 64,
            user_id=u.id,
            membership_id=membership.id,
            expires_at=datetime(2099, 1, 1, tzinfo=timezone.utc),
        )
        s.add_all([platform_tok, tenant_tok])
        s.commit()  # must not raise

    with Session(control_engine) as s:
        from sqlalchemy import select

        rows = s.scalars(select(m.InviteToken)).all()
        assert len(rows) == 2
        platform_rows = [r for r in rows if r.membership_id is None]
        tenant_rows = [r for r in rows if r.membership_id is not None]
        assert len(platform_rows) == 1
        assert len(tenant_rows) == 1
