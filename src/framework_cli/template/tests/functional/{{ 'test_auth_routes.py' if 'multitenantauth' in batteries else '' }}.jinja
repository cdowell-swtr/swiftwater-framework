# ── set-password: single-use + invalidates ALL sessions ──────────────────────────


def test_set_password_single_use_and_invalidates_sessions(auth_client, control_engine):
    signup = auth_client.post(
        "/auth/signup",
        json={
            "email": "invitee@x.com",
            "password": "pw-placeholder",
            "tenant_name": "Inv",
            "slug": "invco",
        },
    )
    assert signup.status_code == 201

    raw, token_hash = mint()
    with Session(control_engine) as s:
        user = s.scalar(
            select(m.AppUser).where(m.AppUser.email_canonical == "invitee@x.com")
        )
        assert user is not None
        membership = s.scalar(
            select(m.TenantMembership).where(m.TenantMembership.user_id == user.id)
        )
        s.add(
            m.InviteToken(
                token_hash=token_hash,
                user_id=user.id,
                membership_id=membership.id,
                expires_at=datetime.now(timezone.utc) + timedelta(hours=1),
            )
        )
        s.commit()

    # Redeem → 204; sets the password, stamps accepted_at, invalidates the founder's live session.
    r = auth_client.post(
        "/auth/set-password", json={"token": raw, "password": "new-pw-placeholder"}
    )
    assert r.status_code == 204
    # The pre-existing signup session is now dead (all sessions invalidated).
    assert auth_client.get("/auth/me").status_code == 401
    # The new password works.
    assert (
        auth_client.post(
            "/auth/login",
            json={"email": "invitee@x.com", "password": "new-pw-placeholder"},
        ).status_code
        == 200
    )
    # Second redemption of the same token is rejected (single-use).
    second = auth_client.post(
        "/auth/set-password", json={"token": raw, "password": "another-pw-placeholder"}
    )
    assert second.status_code == 400
    # The membership's accepted_at was stamped.
    with Session(control_engine) as s:
        membership = s.scalar(
            select(m.TenantMembership)
            .join(m.AppUser, m.TenantMembership.user_id == m.AppUser.id)
            .where(m.AppUser.email_canonical == "invitee@x.com")
        )
        assert membership.accepted_at is not None


def test_set_password_unknown_token_is_400(auth_client):
    r = auth_client.post(
        "/auth/set-password",
        json={"token": "not-a-real-token", "password": "pw-placeholder"},
    )
