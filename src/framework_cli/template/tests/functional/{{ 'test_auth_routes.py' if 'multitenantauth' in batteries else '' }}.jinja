@pytest.fixture
def _clean_control(control_engine: Engine) -> Iterator[None]:
    """Truncate control tables after each test (function-scoped isolation)."""
    yield
    with control_engine.begin() as conn:
        conn.execute(text(f"TRUNCATE TABLE {_CONTROL_TABLES} CASCADE"))


def _seed_vocab(s: Session) -> None:
    """Seed the minimum roles/permissions signup needs (Task 17 seed_authz deferred).

    Signup assigns ``tenant.admin`` to the founder, so that role (+ its grants) must exist.
    """
    from uuid import uuid4

    perms = [("tenant:read", "tenant"), ("tenant:manage-members", "tenant")]
    for name, domain in perms:
        s.execute(
            text(
                "INSERT INTO permission (name, domain, description, is_active) "
                "VALUES (:name, :domain, :desc, true) ON CONFLICT DO NOTHING"
            ),
            {"name": name, "domain": domain, "desc": name},
        )
    roles_def = [
        ("tenant.member", "tenant", {"tenant:read"}),
        ("tenant.admin", "tenant", {"tenant:read", "tenant:manage-members"}),
    ]
    role_ids: dict[str, object] = {}
    for rname, rdomain, _ in roles_def:
        s.execute(
            text(
                "INSERT INTO role (id, name, domain, description, is_builtin) "
                "VALUES (:id, :name, :domain, :desc, true) ON CONFLICT (name) DO NOTHING"
            ),
            {"id": uuid4(), "name": rname, "domain": rdomain, "desc": rname},
        )
        role_ids[rname] = s.execute(
            text("SELECT id FROM role WHERE name=:name"), {"name": rname}
        ).scalar_one()
    for rname, _, grants in roles_def:
        for pname in grants:
            s.execute(
                text(
                    "INSERT INTO role_permission (role_id, permission_name) "
                    "VALUES (:rid, :pname) ON CONFLICT DO NOTHING"
                ),
                {"rid": role_ids[rname], "pname": pname},
            )


def _build_client(control_engine: Engine, monkeypatch, env: str = "dev") -> TestClient:
    """Build a TestClient over a probe app mounting the auth router, with control_session
    overridden onto *control_engine* and the env/peppers set for *env*."""
    monkeypatch.setenv("APP_ENVIRONMENT", env)
    monkeypatch.setenv("APP_SESSION_PEPPER", "authroutes-session-pepper")
    monkeypatch.setenv("APP_PASSWORD_PEPPER", "authroutes-password-pepper")
    monkeypatch.setenv("APP_SESSION_COOKIE_SECURE", "false")
    from {{ package_name }}.config.settings import get_settings

    get_settings.cache_clear()

    with Session(control_engine) as s:
        _seed_vocab(s)
        s.commit()

    app = FastAPI()
    app.include_router(auth_router)

    def _cs() -> Iterator[Session]:
        with Session(control_engine) as s:
            yield s

    app.dependency_overrides[control_session] = _cs
    return TestClient(app)


@pytest.fixture
def auth_client(control_engine: Engine, monkeypatch) -> Iterator[TestClient]:
    """A dev-env client (signup open) over the test control plane."""
    client = _build_client(control_engine, monkeypatch, env="dev")
    try:
        yield client
    finally:
        client.close()
        from {{ package_name }}.config.settings import get_settings

        get_settings.cache_clear()


# ── happy path + identity ────────────────────────────────────────────────────────


def test_signup_creates_tenant_founder_and_me(auth_client):
    r = auth_client.post(
        "/auth/signup",
        json={
            "email": "ceo@acme.com",
            "password": "pw-placeholder",
            "tenant_name": "Acme",
            "slug": "acme",
        },
    )
    assert r.status_code == 201
    tenant_id = r.json()["tenant_id"]
    assert tenant_id  # opaque, auto-generated — NOT the slug
    assert r.json()["slug"] == "acme"
    assert auth_client.cookies.get("{{ package_name }}_session")
    # The session cookie carries the security flags (set in cookies.py): httpOnly + SameSite=Lax.
    set_cookie = r.headers["set-cookie"].lower()
    assert "httponly" in set_cookie
    assert "samesite=lax" in set_cookie
    me = auth_client.get("/auth/me")
    assert me.status_code == 200
    body = me.json()
    assert body["email"] == "ceo@acme.com"
    # Founder is tenant.admin on the freshly-created (opaque-id) tenant.
    assert any(
        mem["tenant_id"] == tenant_id and "tenant.admin" in mem["roles"]
        for mem in body["memberships"]
    )


