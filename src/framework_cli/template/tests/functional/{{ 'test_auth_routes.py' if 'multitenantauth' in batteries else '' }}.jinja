def test_disabled_user_cannot_login(auth_client, control_engine):
    auth_client.post(
        "/auth/signup",
        json={
            "email": "disabled@x.com",
            "password": "pw-placeholder",
            "tenant_name": "Dis",
            "slug": "disco",
        },
    )
    auth_client.post("/auth/logout")
    with Session(control_engine) as s:
        user = s.scalar(
            select(m.AppUser).where(m.AppUser.email_canonical == "disabled@x.com")
        )
        user.disabled_at = datetime.now(timezone.utc)
        s.commit()
    r = auth_client.post(
        "/auth/login", json={"email": "disabled@x.com", "password": "pw-placeholder"}
    )
    assert r.status_code == 401  # disabled → same generic 401 (no enumeration)


# ── login mints a FRESH session (fixation prevented) ─────────────────────────────


def test_login_mints_fresh_session_not_caller_supplied(auth_client):
    """Session fixation: a caller-supplied (junk) session cookie is NEVER adopted. After a valid
    login the issued token differs from the junk, and the junk cookie does not authenticate."""
    auth_client.post(
        "/auth/signup",
        json={
            "email": "fix@x.com",
            "password": "pw-placeholder",
            "tenant_name": "Fix",
            "slug": "fixco",
        },
    )
    auth_client.post("/auth/logout")

    junk = "attacker-fixated-session-value"
    # A fresh client carrying ONLY the attacker-supplied (junk) session cookie.
    attacker = TestClient(auth_client.app)
    attacker.cookies.set("{{ package_name }}_session", junk)
    r = attacker.post(
        "/auth/login", json={"email": "fix@x.com", "password": "pw-placeholder"}
    )
    assert r.status_code == 200
    # Read the issued token from the login response's Set-Cookie header (deterministic — the jar
    # may transiently hold both the junk and the issued cookie under different domains).
    issued = r.cookies.get("{{ package_name }}_session")
    assert issued and issued != junk  # a brand-new token, not the attacker's value

    # The junk value never authenticates (it was never registered as a session).
    bad = TestClient(auth_client.app)
    bad.cookies.set("{{ package_name }}_session", junk)
    assert bad.get("/auth/me").status_code == 401


# ── signup collisions: one generic 409, no enumeration ───────────────────────────


def test_signup_duplicate_email_is_409_without_enumeration(auth_client):
    first = auth_client.post(
        "/auth/signup",
        json={
            "email": "dup@x.com",
            "password": "pw-placeholder",
            "tenant_name": "Dup",
            "slug": "dupco",
        },
    )
    assert first.status_code == 201
    auth_client.post("/auth/logout")
    # Same email, different slug → email collision; the response must not reveal which collided.
    second = auth_client.post(
        "/auth/signup",
        json={
            "email": "dup@x.com",
            "password": "pw-placeholder",
            "tenant_name": "Other",
            "slug": "otherco",
        },
    )
    assert second.status_code == 409
    assert "email" not in second.text.lower() and "slug" not in second.text.lower()


def test_signup_duplicate_slug_is_409_no_orphan(auth_client, control_engine):
    """A second signup reusing a live slug → generic 409 (slug collision). The attacker gets no
    user and no membership — and reusing a slug never joins the victim's tenant."""
    first = auth_client.post(
        "/auth/signup",
        json={
            "email": "founder@acme.com",
            "password": "pw-placeholder",
            "tenant_name": "Acme",
            "slug": "acme",
        },
    )
    assert first.status_code == 201
    attacker = auth_client.post(
        "/auth/signup",
        json={
            "email": "attacker@evil.com",
            "password": "pw-placeholder",
            "tenant_name": "Evil",
            "slug": "acme",  # reuse the live slug
        },
    )
    assert attacker.status_code == 409
    assert "email" not in attacker.text.lower() and "slug" not in attacker.text.lower()
    with Session(control_engine) as s:
        # No attacker user was created (rejected before any write).
        assert (
            s.scalar(
                select(m.AppUser.id).where(
                    m.AppUser.email_canonical == "attacker@evil.com"
                )
            )
            is None
        )
        # Exactly one tenant owns the slug (no orphan second tenant).
        tenant_count = s.scalar(
            select(text("count(*)"))
            .select_from(m.Tenant)
            .where(m.Tenant.slug == "acme")
        )
        assert tenant_count == 1


