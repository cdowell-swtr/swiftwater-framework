def test_login_then_me_roundtrip(auth_client):
    auth_client.post(
        "/auth/signup",
        json={
            "email": "b@x.com",
            "password": "pw-placeholder",
            "tenant_name": "B",
            "slug": "bco",
        },
    )
    auth_client.post("/auth/logout")
    assert auth_client.get("/auth/me").status_code == 401  # logged out
    assert (
        auth_client.post(
            "/auth/login", json={"email": "b@x.com", "password": "pw-placeholder"}
        ).status_code
        == 200
    )
    assert auth_client.get("/auth/me").status_code == 200


