from fastapi import FastAPI, HTTPException
from fastapi.testclient import TestClient
from pydantic import BaseModel, field_validator

from {{ package_name }}.main import create_app
from {{ package_name }}.observability.recoverability import recoverability


class _Positive(BaseModel):
    n: int

    @field_validator("n")
    @classmethod
    def _must_be_positive(cls, value: int) -> int:
        if value <= 0:
            raise ValueError("must be positive")
        return value


def _app_with_failing_routes() -> FastAPI:
    from {{ package_name }}.config.settings import Settings

    # serve_spa=False so the SPA "/" catch-all is never mounted — otherwise a built
    # frontend/dist (e.g. from a prior `npm run build` in this tree) would shadow the
    # routes registered below.
    app = create_app(Settings(serve_spa=False))

    @app.get("/boom")
    def boom() -> None:
        raise RuntimeError("kaboom-internal-detail")

    @app.get("/teapot")
    def teapot() -> None:
        raise HTTPException(status_code=418, detail="I'm a teapot")

    @app.get("/needs-int")
    def needs_int(n: int) -> dict[str, int]:
        return {"n": n}

    @app.post("/positive")
    def positive(body: _Positive) -> dict[str, int]:
        return {"n": body.n}

    return app


def test_built_spa_does_not_shadow_error_routes(tmp_path, monkeypatch):
    # Regression: the SPA static mount is a "/" catch-all that, if present, would shadow API
    # and error routes registered on the app. Gating it on settings.serve_spa keeps the
    # handlers reachable even when a built frontend/dist exists (e.g. build-then-test in one
    # tree). Simulate a built SPA, then confirm error handling still resolves.
    (tmp_path / "frontend" / "dist").mkdir(parents=True)
    (tmp_path / "frontend" / "dist" / "index.html").write_text("<!doctype html>")
    monkeypatch.chdir(tmp_path)
    client = TestClient(_app_with_failing_routes(), raise_server_exceptions=False)
    assert client.get("/boom").status_code == 500


def test_unhandled_exception_returns_problem_json():
    client = TestClient(_app_with_failing_routes(), raise_server_exceptions=False)
    r = client.get("/boom")
    assert r.status_code == 500
    assert r.headers["content-type"].startswith("application/problem+json")
    body = r.json()
    assert body["status"] == 500
    assert body["title"] == "Internal Server Error"
    assert body["instance"] == "/boom"
    assert body["correlation_id"]  # populated from request.state by the middleware
    assert "kaboom-internal-detail" not in r.text  # internal detail never leaked


def test_http_exception_uses_problem_json():
    client = TestClient(_app_with_failing_routes())
    r = client.get("/teapot")
    assert r.status_code == 418
    assert r.headers["content-type"].startswith("application/problem+json")
    assert r.json()["detail"] == "I'm a teapot"


def test_validation_error_uses_problem_json():
    client = TestClient(_app_with_failing_routes())
    r = client.get("/needs-int", params={"n": "not-an-int"})
    assert r.status_code == 422
    assert r.headers["content-type"].startswith("application/problem+json")
    assert "errors" in r.json()


def test_unhandled_exception_increments_metric_and_is_on_metrics_endpoint():
    client = TestClient(_app_with_failing_routes(), raise_server_exceptions=False)
    client.get("/boom")
    assert recoverability.snapshot()["unhandled"] == 1
    metrics_body = client.get("/metrics").text
    assert "app_unhandled_exceptions_total 1" in metrics_body


def test_custom_validator_error_stays_422_and_does_not_increment_unhandled():
    client = TestClient(_app_with_failing_routes())
    r = client.post("/positive", json={"n": -5})
    assert r.status_code == 422
    assert r.headers["content-type"].startswith("application/problem+json")
    assert "errors" in r.json()
    # The crash bug turned this into a 500 + falsely incremented the counter.
    assert recoverability.snapshot()["unhandled"] == 0
