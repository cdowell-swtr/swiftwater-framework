"""TenantLifecycleEvent: append-only audit for tenant-lifecycle mutations.

Tests confirm:
- record_lifecycle_event() inserts a row with the correct fields.
- The DB-level CHECK constraint rejects unknown action values.
"""

from __future__ import annotations

import pytest
from sqlalchemy import Engine, create_engine, make_url, text
from sqlalchemy.exc import IntegrityError
from sqlalchemy.orm import Session

from {{ package_name }}.db.control import models as m
from {{ package_name }}.db.control.base import ControlBase
from {{ package_name }}.multitenantauth.tenancy.registry import record_lifecycle_event


# ── fixtures ──────────────────────────────────────────────────────────────────


@pytest.fixture(scope="module")
def control_engine(pg_url: str) -> Engine:  # type: ignore[return]
    """Control-plane engine for lifecycle-event tests.

    Creates the tables needed by these tests (app_user, tenant, tenant_lifecycle_event)
    in an isolated test database. Uses create_all — no alembic needed here.
    """
    _ctrl_db = "{{ package_name }}_lifecycle_test"
    base = make_url(pg_url)
    ctrl_url = base.set(database=_ctrl_db).render_as_string(hide_password=False)
    maint_url = base.set(database="postgres").render_as_string(hide_password=False)
    maint = create_engine(maint_url, isolation_level="AUTOCOMMIT")
    with maint.connect() as c:
        if not c.execute(
            text(f"SELECT 1 FROM pg_database WHERE datname='{_ctrl_db}'")
        ).scalar():
            c.execute(text(f'CREATE DATABASE "{_ctrl_db}"'))
    maint.dispose()

    engine = create_engine(ctrl_url)
    ControlBase.metadata.create_all(
        engine,
        tables=[
            m.AppUser.__table__,
            m.Tenant.__table__,
            m.TenantLifecycleEvent.__table__,
        ],
    )
    yield engine
    engine.dispose()


@pytest.fixture
def control_session(control_engine: Engine) -> Session:  # type: ignore[return]
    """Provide a function-scoped Session; truncate lifecycle and tenant tables after each test."""
    with Session(control_engine) as s:
        yield s
    with control_engine.begin() as conn:
        conn.execute(text("TRUNCATE TABLE tenant_lifecycle_event, tenant CASCADE"))


# ── tests ─────────────────────────────────────────────────────────────────────


def test_records_a_lifecycle_event(control_session: Session) -> None:
    """record_lifecycle_event inserts one TenantLifecycleEvent row with correct fields."""
    s = control_session
    s.add(m.Tenant(id="acme", name="Acme", slug="acme", status="active", dsn="x"))
    s.flush()
    record_lifecycle_event(s, actor_id=None, tenant_id="acme", action="suspend")
    s.flush()
    ev = s.query(m.TenantLifecycleEvent).filter_by(tenant_id="acme").one()
    assert ev.action == "suspend" and ev.detail is None


def test_action_check_rejects_unknown(control_session: Session) -> None:
    """The DB CHECK constraint rejects an action value not in the allowed set."""
    s = control_session
    s.add(m.Tenant(id="acme", name="Acme", slug="acme", status="active", dsn="x"))
    s.flush()
    s.add(m.TenantLifecycleEvent(tenant_id="acme", action="frobnicate"))
    with pytest.raises(IntegrityError):
        s.flush()
