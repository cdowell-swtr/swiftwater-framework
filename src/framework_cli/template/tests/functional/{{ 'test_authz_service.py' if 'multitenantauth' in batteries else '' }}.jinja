# ── resource-role tests ───────────────────────────────────────────────────────


def test_assign_resource_role_is_idempotent_and_audited(control_engine: Engine) -> None:
    """assign_resource_role is idempotent; repeated call produces one row and one audit event."""
    with Session(control_engine) as s:
        _seed(s)
        u = _user(s, "d@x.io")
        mem = m.TenantMembership(user_id=u.id, tenant_id="acme")
        s.add(mem)
        s.flush()
        service.assign_resource_role(
            s,
            membership_id=mem.id,
            resource_id="widget-42",
            role_name="resource.admin",
            actor_id=None,
        )
        service.assign_resource_role(
            s,
            membership_id=mem.id,
            resource_id="widget-42",
            role_name="resource.admin",
            actor_id=None,
        )
        s.commit()
        assigns = s.scalars(select(m.ResourceRoleAssignment)).all()
        assert len(assigns) == 1
        events = s.scalars(
            select(m.AuthzEvent).where(m.AuthzEvent.action == "grant")
        ).all()
        assert len(events) == 1  # audited once, only on real change


def test_revoke_resource_role_removes_and_audits(control_engine: Engine) -> None:
    """revoke_resource_role removes the assignment and records a revoke event."""
    with Session(control_engine) as s:
        _seed(s)
        u = _user(s, "e@x.io")
        mem = m.TenantMembership(user_id=u.id, tenant_id="acme")
        s.add(mem)
        s.flush()
        service.assign_resource_role(
            s,
            membership_id=mem.id,
            resource_id="widget-42",
            role_name="resource.admin",
            actor_id=None,
        )
        service.revoke_resource_role(
            s,
            membership_id=mem.id,
            resource_id="widget-42",
            role_name="resource.admin",
            actor_id=None,
        )
        s.commit()
        assert s.scalars(select(m.ResourceRoleAssignment)).all() == []
        assert (
            s.scalar(select(m.AuthzEvent).where(m.AuthzEvent.action == "revoke"))
            is not None
        )


