def test_noop_revoke_appends_no_authz_event(control_engine: Engine) -> None:
    """Revoking a role the membership never held is a no-op — records NO authz_event.

    Otherwise an admin could fabricate phantom ``revoke`` audit history via a PATCH
    with an arbitrary from_role the member doesn't hold.
    """
    with Session(control_engine) as s:
        _seed(s)
        u = _user(s, "noop@x.com")
        mem = service.add_membership(
            s,
            user_id=u.id,
            tenant_id="acme",
            role_name="tenant.member",
            actor_id=u.id,
            invited=False,
        )
        s.commit()
        baseline = s.query(m.AuthzEvent).count()
        # Revoke a role the member does NOT hold — a no-op.
        service.revoke_role(
            s, membership_id=mem.id, role_name="tenant.admin", actor_id=u.id
        )
        s.commit()
        assert s.query(m.AuthzEvent).count() == baseline  # no phantom revoke


