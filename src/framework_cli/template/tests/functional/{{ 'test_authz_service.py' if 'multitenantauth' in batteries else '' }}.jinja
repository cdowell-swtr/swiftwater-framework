"""AuthZ grant/revoke service: ≥1-admin TOCTOU invariant, idempotent audit, domain checks.

Ported from meridian tests/functional/test_auth_service.py + test_product_role_service.py
(MDN34/MDN36) with the following transformations:
- product_id/assign_product_role/revoke_product_role → resource_id/assign_resource_role/
  revoke_resource_role (sec-review A-F5: generic battery has no 'product' domain).
- seed_authz removed — roles are seeded inline (Task 17 deferred).
- Tenant requires slug + status (framework tenant model differs from Meridian's).
- admin_role_name read from settings (not a module constant).
- A-F4 fix verified: repeated add_platform_role records NO second authz_event.
"""

from __future__ import annotations

import threading

import pytest
from sqlalchemy import Engine, create_engine, make_url, select, text
from sqlalchemy.orm import Session

from {{ package_name }}.db.control import models as m
from {{ package_name }}.db.control.base import ControlBase
from {{ package_name }}.multitenantauth.authz import service
from {{ package_name }}.multitenantauth.errors import DomainMismatchError, LastAdminError


# ── fixture ───────────────────────────────────────────────────────────────────


@pytest.fixture(scope="module")
def control_engine(pg_url: str) -> Engine:  # type: ignore[return]
    """Control-plane engine for authz-service tests.

    Creates the full set of tables needed by the service (all six control tables).
    No alembic — Task 7 (migrations) is deferred.
    """
    _ctrl_db = "{{ package_name }}_authz_service_test"
    base = make_url(pg_url)
    ctrl_url = base.set(database=_ctrl_db).render_as_string(hide_password=False)
    maint_url = base.set(database="postgres").render_as_string(hide_password=False)
    maint = create_engine(maint_url, isolation_level="AUTOCOMMIT")
    with maint.connect() as c:
        if not c.execute(
            text(f"SELECT 1 FROM pg_database WHERE datname='{_ctrl_db}'")
        ).scalar():
            c.execute(text(f'CREATE DATABASE "{_ctrl_db}"'))
    maint.dispose()

    engine = create_engine(ctrl_url)
    ControlBase.metadata.create_all(
        engine,
        tables=[
            m.AppUser.__table__,
            m.Tenant.__table__,
            m.TenantMembership.__table__,
            m.Role.__table__,
            m.Permission.__table__,
            m.TenantRoleAssignment.__table__,
            m.PlatformRoleAssignment.__table__,
            m.ResourceRoleAssignment.__table__,
            m.AuthzEvent.__table__,
        ],
    )
    yield engine
    engine.dispose()


@pytest.fixture(autouse=True)
def _clean_control(control_engine: Engine) -> None:  # type: ignore[return]
    """Truncate all authz tables after each test (tests commit; no rollback isolation)."""
    yield
    with control_engine.begin() as conn:
        conn.execute(
            text(
                "TRUNCATE TABLE authz_event, resource_role_assignment, "
                "platform_role_assignment, tenant_role_assignment, "
                "tenant_membership, role, tenant, app_user CASCADE"
            )
        )


# ── helpers ───────────────────────────────────────────────────────────────────


def _seed(s: Session) -> None:
    """Seed the minimal role catalog + one tenant (no seed_authz; Task 17 deferred)."""
    s.add(
        m.Tenant(
            id="acme",
            name="Acme",
            slug="acme",
            dsn="postgresql+psycopg://x/acme",
            status="active",
        )
    )
    # Tenant-domain roles
    s.add(
        m.Role(name="tenant.admin", domain="tenant", description="Tenant administrator")
    )
    s.add(m.Role(name="tenant.member", domain="tenant", description="Tenant member"))
    # Platform-domain role
    s.add(
        m.Role(
            name="platform.admin",
            domain="platform",
            description="Platform administrator",
        )
    )
    # Resource-domain role
    s.add(
        m.Role(
            name="resource.admin",
            domain="resource",
            description="Resource administrator",
        )
    )
    s.flush()


def _user(s: Session, email: str) -> m.AppUser:
    u = m.AppUser(email=email, email_canonical=email, born="operator")
    s.add(u)
    s.flush()
    return u


# ── admin invariant tests ─────────────────────────────────────────────────────


def test_cannot_revoke_last_admin(control_engine: Engine) -> None:
    """Revoking the sole admin role raises LastAdminError."""
    with Session(control_engine) as s:
        _seed(s)
        u = _user(s, "a@x.com")
        mem = service.add_membership(
            s,
            user_id=u.id,
            tenant_id="acme",
            role_name="tenant.admin",
            actor_id=u.id,
            invited=False,
        )
        s.commit()
        with pytest.raises(LastAdminError):
            service.revoke_role(
                s, membership_id=mem.id, role_name="tenant.admin", actor_id=u.id
            )


def test_demote_allowed_with_second_admin_and_audited(control_engine: Engine) -> None:
    """With two admins, demoting one succeeds and records a single revoke event."""
    with Session(control_engine) as s:
        _seed(s)
        a = _user(s, "a@x.com")
        b = _user(s, "b@x.com")
        ma = service.add_membership(
            s,
            user_id=a.id,
            tenant_id="acme",
            role_name="tenant.admin",
            actor_id=a.id,
            invited=False,
        )
        service.add_membership(
            s,
            user_id=b.id,
            tenant_id="acme",
            role_name="tenant.admin",
            actor_id=a.id,
            invited=False,
        )
        s.commit()
        service.revoke_role(
            s, membership_id=ma.id, role_name="tenant.admin", actor_id=a.id
        )
        s.commit()
        assert s.query(m.AuthzEvent).filter_by(action="revoke").count() == 1
        assert s.query(m.AuthzEvent).filter_by(action="grant").count() == 2


