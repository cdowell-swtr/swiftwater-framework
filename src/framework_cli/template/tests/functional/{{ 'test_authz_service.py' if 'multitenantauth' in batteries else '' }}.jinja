# ── TOCTOU concurrent test ────────────────────────────────────────────────────


def test_concurrent_double_demote_keeps_one_admin(control_engine: Engine) -> None:
    """Two admins, two threads each revoking one concurrently — exactly one must fail (LastAdminError);
    the tenant must retain >=1 admin. Proves the FOR UPDATE lock serializes the check-then-delete."""
    with Session(control_engine) as s:
        _seed(s)
        a = _user(s, "ta@x.com")
        b = _user(s, "tb@x.com")
        ma = service.add_membership(
            s,
            user_id=a.id,
            tenant_id="acme",
            role_name="tenant.admin",
            actor_id=a.id,
            invited=False,
        )
        mb = service.add_membership(
            s,
            user_id=b.id,
            tenant_id="acme",
            role_name="tenant.admin",
            actor_id=a.id,
            invited=False,
        )
        s.commit()
        ma_id, mb_id = ma.id, mb.id

    eng = create_engine(
        control_engine.url.render_as_string(hide_password=False),
        pool_size=2,
    )
    results: list[str] = []
    barrier = threading.Barrier(2)

    def worker(mid: object) -> None:
        with Session(eng) as s:
            barrier.wait()
            try:
                service.revoke_role(
                    s, membership_id=mid, role_name="tenant.admin", actor_id=None
                )
                s.commit()
                results.append("ok")
            except LastAdminError:
                s.rollback()
                results.append("blocked")

    t1 = threading.Thread(target=worker, args=(ma_id,))
    t2 = threading.Thread(target=worker, args=(mb_id,))
    t1.start()
    t2.start()
    t1.join()
    t2.join()
    eng.dispose()

    assert sorted(results) == ["blocked", "ok"]  # exactly one succeeded
    with Session(control_engine) as s:
        admin_role_id = s.scalar(select(m.Role.id).where(m.Role.name == "tenant.admin"))
        remaining = (
            s.query(m.TenantRoleAssignment).filter_by(role_id=admin_role_id).count()
        )
        assert remaining == 1


