"""AuthZ grant/revoke service: ≥1-admin TOCTOU invariant, idempotent audit, domain checks.

Ported from meridian tests/functional/test_auth_service.py + test_product_role_service.py
(MDN34/MDN36) with the following transformations:
- product_id/assign_product_role/revoke_product_role → resource_id/assign_resource_role/
  revoke_resource_role (sec-review A-F5: generic battery has no 'product' domain).
- seed_authz removed — roles are seeded inline (Task 17 deferred).
- Tenant requires slug + status (framework tenant model differs from Meridian's).
- admin_role_name read from settings (not a module constant).
- A-F4 fix verified: repeated add_platform_role records NO second authz_event.
"""

from __future__ import annotations

import threading

import pytest
from sqlalchemy import Engine, create_engine, make_url, select, text
from sqlalchemy.orm import Session

from {{ package_name }}.db.control import models as m
from {{ package_name }}.db.control.base import ControlBase
from {{ package_name }}.multitenantauth.authz import service
from {{ package_name }}.multitenantauth.errors import DomainMismatchError, LastAdminError


