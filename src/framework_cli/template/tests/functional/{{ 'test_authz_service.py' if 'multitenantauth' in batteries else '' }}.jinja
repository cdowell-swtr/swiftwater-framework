def test_cannot_revoke_last_admin(control_engine: Engine) -> None:
    """Revoking the sole admin role raises LastAdminError."""
    with Session(control_engine) as s:
        _seed(s)
        u = _user(s, "a@x.com")
        mem = service.add_membership(
            s,
            user_id=u.id,
