def test_repeated_add_platform_role_no_phantom_audit(control_engine: Engine) -> None:
    """A-F4 fix: calling add_platform_role twice records exactly ONE grant event.

    The reference implementation (Meridian) placed _record_event OUTSIDE the
    ``if existing is None`` block, so every idempotent repeat wrote a second audit row.
    The framework version fixes this — a repeated grant is a structural no-op AND an
    audit no-op.
    """
    with Session(control_engine) as s:
        _seed(s)
        u = _user(s, "plat@x.com")
        s.commit()
        user_id = u.id  # capture before session closes

    with Session(control_engine) as s:
        # Grant once — real state change → one event.
        service.add_platform_role(
            s, user_id=user_id, role_name="platform.admin", actor_id=None
        )
        s.commit()

    with Session(control_engine) as s:
        # Grant again (idempotent) — no new assignment, no new event.
        service.add_platform_role(
            s, user_id=user_id, role_name="platform.admin", actor_id=None
        )
        s.commit()
        assignments = s.scalars(select(m.PlatformRoleAssignment)).all()
        events = s.scalars(
            select(m.AuthzEvent).where(m.AuthzEvent.action == "grant")
        ).all()
        assert len(assignments) == 1  # still one row
        assert len(events) == 1  # exactly one audit event — NOT two (A-F4 fix)


