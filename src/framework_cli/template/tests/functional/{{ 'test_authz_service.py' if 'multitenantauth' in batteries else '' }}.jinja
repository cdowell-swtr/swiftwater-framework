@pytest.fixture(scope="module")
def control_engine(pg_url: str) -> Engine:  # type: ignore[return]
    """Control-plane engine for authz-service tests.

    Creates the full set of tables needed by the service (all six control tables).
    No alembic — Task 7 (migrations) is deferred.
    """
    _ctrl_db = "{{ package_name }}_authz_service_test"
    base = make_url(pg_url)
    ctrl_url = base.set(database=_ctrl_db).render_as_string(hide_password=False)
    maint_url = base.set(database="postgres").render_as_string(hide_password=False)
    maint = create_engine(maint_url, isolation_level="AUTOCOMMIT")
    with maint.connect() as c:
        if not c.execute(
            text(f"SELECT 1 FROM pg_database WHERE datname='{_ctrl_db}'")
        ).scalar():
            c.execute(text(f'CREATE DATABASE "{_ctrl_db}"'))
    maint.dispose()

    engine = create_engine(ctrl_url)
    ControlBase.metadata.create_all(
        engine,
        tables=[
            m.AppUser.__table__,
            m.Tenant.__table__,
            m.TenantMembership.__table__,
            m.Role.__table__,
            m.Permission.__table__,
            m.TenantRoleAssignment.__table__,
            m.PlatformRoleAssignment.__table__,
            m.ResourceRoleAssignment.__table__,
            m.AuthzEvent.__table__,
        ],
    )
    yield engine
    engine.dispose()


@pytest.fixture(autouse=True)
def _clean_control(control_engine: Engine) -> None:  # type: ignore[return]
    """Truncate all authz tables after each test (tests commit; no rollback isolation)."""
    yield
    with control_engine.begin() as conn:
        conn.execute(
            text(
                "TRUNCATE TABLE authz_event, resource_role_assignment, "
                "platform_role_assignment, tenant_role_assignment, "
                "tenant_membership, role, tenant, app_user CASCADE"
            )
        )


# ── helpers ───────────────────────────────────────────────────────────────────


def _seed(s: Session) -> None:
    """Seed the minimal role catalog + one tenant (no seed_authz; Task 17 deferred)."""
    s.add(
        m.Tenant(
            id="acme",
            name="Acme",
            slug="acme",
            dsn="postgresql+psycopg://x/acme",
            status="active",
        )
    )
    # Tenant-domain roles
    s.add(
        m.Role(name="tenant.admin", domain="tenant", description="Tenant administrator")
    )
    s.add(m.Role(name="tenant.member", domain="tenant", description="Tenant member"))
    # Platform-domain role
    s.add(
        m.Role(
            name="platform.admin",
            domain="platform",
            description="Platform administrator",
        )
    )
    # Resource-domain role
    s.add(
        m.Role(
            name="resource.admin",
            domain="resource",
            description="Resource administrator",
        )
    )
    s.flush()


def _user(s: Session, email: str) -> m.AppUser:
    u = m.AppUser(email=email, email_canonical=email, born="operator")
    s.add(u)
    s.flush()
    return u


