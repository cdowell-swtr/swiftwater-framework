# ── idempotent / no-phantom-audit tests ──────────────────────────────────────


def test_noop_revoke_appends_no_authz_event(control_engine: Engine) -> None:
    """Revoking a role the membership never held is a no-op — records NO authz_event.

    Otherwise an admin could fabricate phantom ``revoke`` audit history via a PATCH
    with an arbitrary from_role the member doesn't hold.
    """
    with Session(control_engine) as s:
        _seed(s)
        u = _user(s, "noop@x.com")
        mem = service.add_membership(
            s,
            user_id=u.id,
            tenant_id="acme",
            role_name="tenant.member",
            actor_id=u.id,
            invited=False,
        )
        s.commit()
        baseline = s.query(m.AuthzEvent).count()
        # Revoke a role the member does NOT hold — a no-op.
        service.revoke_role(
            s, membership_id=mem.id, role_name="tenant.admin", actor_id=u.id
        )
        s.commit()
        assert s.query(m.AuthzEvent).count() == baseline  # no phantom revoke


def test_noop_grant_appends_no_authz_event(control_engine: Engine) -> None:
    """Re-granting an already-held role is idempotent — records NO additional grant event."""
    with Session(control_engine) as s:
        _seed(s)
        u = _user(s, "noopg@x.com")
        mem = service.add_membership(
            s,
            user_id=u.id,
            tenant_id="acme",
            role_name="tenant.member",
            actor_id=u.id,
            invited=False,
        )
        s.commit()
        baseline = s.query(m.AuthzEvent).count()
        service.assign_role(
            s, membership_id=mem.id, role_name="tenant.member", actor_id=u.id
        )
        s.commit()
        assert s.query(m.AuthzEvent).count() == baseline  # no phantom grant


def test_repeated_add_platform_role_no_phantom_audit(control_engine: Engine) -> None:
    """A-F4 fix: calling add_platform_role twice records exactly ONE grant event.

    The reference implementation (Meridian) placed _record_event OUTSIDE the
    ``if existing is None`` block, so every idempotent repeat wrote a second audit row.
    The framework version fixes this — a repeated grant is a structural no-op AND an
    audit no-op.
    """
    with Session(control_engine) as s:
        _seed(s)
        u = _user(s, "plat@x.com")
        s.commit()
        user_id = u.id  # capture before session closes

    with Session(control_engine) as s:
        # Grant once — real state change → one event.
        service.add_platform_role(
            s, user_id=user_id, role_name="platform.admin", actor_id=None
        )
        s.commit()

    with Session(control_engine) as s:
        # Grant again (idempotent) — no new assignment, no new event.
        service.add_platform_role(
            s, user_id=user_id, role_name="platform.admin", actor_id=None
        )
        s.commit()
        assignments = s.scalars(select(m.PlatformRoleAssignment)).all()
        events = s.scalars(
            select(m.AuthzEvent).where(m.AuthzEvent.action == "grant")
        ).all()
        assert len(assignments) == 1  # still one row
        assert len(events) == 1  # exactly one audit event — NOT two (A-F4 fix)


