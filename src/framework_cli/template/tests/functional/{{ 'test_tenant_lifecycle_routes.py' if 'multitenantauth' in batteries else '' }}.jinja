def _seed_vocab(s: Session) -> None:
    """Seed the minimum roles/permissions the lifecycle routes need.

    ``tenant.admin`` includes ``tenant:deactivate`` (Task 4 grant bundled here
    for isolation — the generated project's real roles DB migration owns this
    in production).
    ``platform.admin`` includes ``platform:manage-tenant-lifecycle`` (Task 4)
    for the operator suspend/reactivate routes.
    """
    from uuid import uuid4

    perms = [
        ("tenant:read", "tenant"),
        ("tenant:manage-members", "tenant"),
        ("tenant:deactivate", "tenant"),
        ("tenant:rename-slug", "tenant"),
        ("platform:manage-tenant-lifecycle", "platform"),
    ]
    for name, domain in perms:
        s.execute(
            text(
                "INSERT INTO permission (name, domain, description, is_active) "
                "VALUES (:name, :domain, :desc, true) ON CONFLICT DO NOTHING"
            ),
            {"name": name, "domain": domain, "desc": name},
        )
    roles_def = [
        ("tenant.member", "tenant", {"tenant:read"}),
        (
            "tenant.admin",
            "tenant",
            {
                "tenant:read",
                "tenant:manage-members",
                "tenant:deactivate",
                "tenant:rename-slug",
            },
        ),
        ("platform.admin", "platform", {"platform:manage-tenant-lifecycle"}),
    ]
    role_ids: dict[str, object] = {}
    for rname, rdomain, _ in roles_def:
        s.execute(
            text(
                "INSERT INTO role (id, name, domain, description, is_builtin) "
                "VALUES (:id, :name, :domain, :desc, true) ON CONFLICT (name) DO NOTHING"
            ),
            {"id": uuid4(), "name": rname, "domain": rdomain, "desc": rname},
        )
        role_ids[rname] = s.execute(
            text("SELECT id FROM role WHERE name=:name"), {"name": rname}
        ).scalar_one()
    for rname, _, grants in roles_def:
        for pname in grants:
            s.execute(
                text(
                    "INSERT INTO role_permission (role_id, permission_name) "
                    "VALUES (:rid, :pname) ON CONFLICT DO NOTHING"
                ),
                {"rid": role_ids[rname], "pname": pname},
            )


def _build_probe(lc_engine: Engine, monkeypatch) -> TestClient:
    monkeypatch.setenv("APP_ENVIRONMENT", "dev")
    monkeypatch.setenv("APP_SESSION_PEPPER", "lc-session-pepper")
    monkeypatch.setenv("APP_PASSWORD_PEPPER", "lc-password-pepper")
    monkeypatch.setenv("APP_SESSION_COOKIE_SECURE", "false")
    from {{ package_name }}.config.settings import get_settings

    get_settings.cache_clear()

    with Session(lc_engine) as s:
        _seed_vocab(s)
        s.commit()

    app = FastAPI()
    app.include_router(auth_router)
    app.include_router(tenants_router)

    def _cs() -> Iterator[Session]:
        with Session(lc_engine) as s:
            yield s

    app.dependency_overrides[control_session] = _cs
    return TestClient(app)


@pytest.fixture
def probe(lc_engine: Engine, monkeypatch) -> Iterator[TestClient]:
    client = _build_probe(lc_engine, monkeypatch)
    try:
        yield client
    finally:
        client.close()
        from {{ package_name }}.config.settings import get_settings

        get_settings.cache_clear()


# ── helpers ───────────────────────────────────────────────────────────────────


def _signup_and_login(client: TestClient, email: str, slug: str) -> tuple[str, str]:
    """Signup a founder+tenant and return (tenant_id, cookie_header)."""
    r = client.post(
        "/auth/signup",
        json={
            "email": email,
            "password": "a-secure-password-12",
            "tenant_name": slug.title(),
            "slug": slug,
        },
    )
    assert r.status_code == 201, r.text
    tenant_id: str = r.json()["tenant_id"]
    cookie = r.headers["set-cookie"].split(";")[0]
    return tenant_id, cookie


def _headers(cookie: str) -> dict:
    return {"Cookie": cookie}


def _make_plain_member(
    probe: TestClient, admin_cookie: str, tenant_id: str, user_id: object
) -> str:
    """Admin adds *user_id* as a plain ``tenant.member`` of *tenant_id*; return membership_id."""
    r = probe.post(
        f"/tenants/{tenant_id}/members",
        headers=_headers(admin_cookie),
        json={"user_id": str(user_id), "role_name": "tenant.member"},
    )
    assert r.status_code == 201, r.text
    return r.json()["membership_id"]


# ── POST /tenants/{tenant_id}/deactivate ─────────────────────────────────────


def test_tenant_admin_can_self_deactivate(probe: TestClient, lc_engine: Engine) -> None:
    """Founder (tenant.admin, holds tenant:deactivate) → 204; tenant status flips to
    'suspended' and a TenantLifecycleEvent with action='suspend' is recorded."""
    tenant_id, cookie = _signup_and_login(probe, "admin@acme-lc.com", "acme-lc")

    r = probe.post(f"/tenants/{tenant_id}/deactivate", headers=_headers(cookie))

    assert r.status_code == 204

    with Session(lc_engine) as s:
        from {{ package_name }}.db.control import models as m

        tenant = s.get(m.Tenant, tenant_id)
        assert tenant is not None
        assert tenant.status == "suspended"

        events = list(
            s.scalars(
                select(m.TenantLifecycleEvent)
                .where(m.TenantLifecycleEvent.tenant_id == tenant_id)
                .order_by(m.TenantLifecycleEvent.at)
            ).all()
        )
        assert len(events) == 1
        assert events[0].action == "suspend"


def test_member_without_perm_cannot_deactivate(
    probe: TestClient, lc_engine: Engine
) -> None:
    """A plain tenant.member (no tenant:deactivate) → 403."""
    admin_tid, admin_cookie = _signup_and_login(probe, "admin@acme2-lc.com", "acme2-lc")
    _, member_cookie = _signup_and_login(probe, "member@acme2m-lc.com", "acme2m-lc")

    with Session(lc_engine) as s:
        member_uid = s.execute(
            text("SELECT id FROM app_user WHERE email_canonical='member@acme2m-lc.com'")
        ).scalar_one()

    _make_plain_member(probe, admin_cookie, admin_tid, member_uid)

    r = probe.post(f"/tenants/{admin_tid}/deactivate", headers=_headers(member_cookie))
    assert r.status_code == 403


# ── helpers for operator (platform-scoped) routes ─────────────────────────────


def _grant_platform_admin(lc_engine: Engine, email_canonical: str) -> None:
    """Grant ``platform.admin`` to the user with *email_canonical* (no actor audit)."""
    from {{ package_name }}.multitenantauth.authz.service import add_platform_role

    with Session(lc_engine) as s:
        uid = s.execute(
            text("SELECT id FROM app_user WHERE email_canonical=:e"),
            {"e": email_canonical},
        ).scalar_one()
        add_platform_role(s, user_id=uid, role_name="platform.admin", actor_id=None)
        s.commit()


# ── rename-slug helpers ───────────────────────────────────────────────────────


def _tenant_slug(lc_engine: Engine, tenant_id: str) -> str:
    """Return the current slug for tenant_id (direct DB read)."""
    with Session(lc_engine) as s:
        return s.execute(
            text("SELECT slug FROM tenant WHERE id = :tid"), {"tid": tenant_id}
        ).scalar_one()


def _slug_history_has(lc_engine: Engine, slug: str) -> bool:
    """Return True if tenant_slug_history has a row for slug."""
    with Session(lc_engine) as s:
        row = s.execute(
            text("SELECT 1 FROM tenant_slug_history WHERE slug = :slug"), {"slug": slug}
        ).scalar_one_or_none()
        return row is not None


def _lifecycle_actions(lc_engine: Engine, tenant_id: str) -> list[str]:
    """Return list of actions from tenant_lifecycle_event for tenant_id, ordered by at."""
    with Session(lc_engine) as s:
        rows = (
            s.execute(
                text(
                    "SELECT action FROM tenant_lifecycle_event "
                    "WHERE tenant_id = :tid ORDER BY at"
                ),
                {"tid": tenant_id},
            )
            .scalars()
            .all()
        )
        return list(rows)


def _retire_slug(lc_engine: Engine, slug: str, tenant_id: str, days: int) -> None:
    """Insert a tenant_slug_history row directly (FK: tenant must already exist).

    days > 0  → cooling (reserved_until in the future)
    days < 0  → expired (reserved_until in the past)
    """
    reserved_until = datetime.now(timezone.utc) + timedelta(days=days)
    with Session(lc_engine) as s:
        s.execute(
            text(
                "INSERT INTO tenant_slug_history (slug, tenant_id, reserved_until) "
                "VALUES (:slug, :tid, :ru) ON CONFLICT (slug) DO UPDATE "
                "SET tenant_id = excluded.tenant_id, reserved_until = excluded.reserved_until"
            ),
            {"slug": slug, "tid": tenant_id, "ru": reserved_until},
        )
        s.commit()


# ── POST /tenants/suspend ─────────────────────────────────────────────────────


def test_nonmember_operator_can_suspend(probe: TestClient, lc_engine: Engine) -> None:
    """Platform operator (not a member of target) → POST /tenants/suspend → 204; T suspended."""
    # Operator O: founder of their own tenant (NOT T)
    _, op_cookie = _signup_and_login(probe, "op@op-suspend.com", "op-suspend")
    _grant_platform_admin(lc_engine, "op@op-suspend.com")

    # Target tenant T
    target_tid, _ = _signup_and_login(
        probe, "owner@target-suspend.com", "target-suspend"
    )

    r = probe.post(
        "/tenants/suspend",
        headers=_headers(op_cookie),
        json={"tenant_id": target_tid},
    )
    assert r.status_code == 204

    with Session(lc_engine) as s:
        from {{ package_name }}.db.control import models as m

        tenant = s.get(m.Tenant, target_tid)
        assert tenant is not None
        assert tenant.status == "suspended"


def test_resuspend_already_suspended_is_409_no_phantom_audit(
    probe: TestClient, lc_engine: Engine
) -> None:
    """Re-suspending an already-suspended tenant → 409 (symmetric with reactivate);
    no second 'suspend' TenantLifecycleEvent is written (audit on real change only)."""
    _, op_cookie = _signup_and_login(probe, "op@op-resuspend.com", "op-resuspend")
    _grant_platform_admin(lc_engine, "op@op-resuspend.com")

    target_tid, _ = _signup_and_login(
        probe, "owner@target-resuspend.com", "target-resuspend"
    )

    # First suspend: 204 + exactly one 'suspend' audit row.
    r1 = probe.post(
        "/tenants/suspend",
        headers=_headers(op_cookie),
        json={"tenant_id": target_tid},
    )
    assert r1.status_code == 204
    assert _lifecycle_actions(lc_engine, target_tid) == ["suspend"]

    # Second suspend on the now-suspended tenant: 409, audit trail unchanged.
    r2 = probe.post(
        "/tenants/suspend",
        headers=_headers(op_cookie),
        json={"tenant_id": target_tid},
    )
    assert r2.status_code == 409
    assert _lifecycle_actions(lc_engine, target_tid) == ["suspend"]


