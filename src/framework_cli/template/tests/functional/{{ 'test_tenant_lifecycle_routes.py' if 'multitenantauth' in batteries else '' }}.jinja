def test_rename_records_history_and_event(probe: TestClient, lc_engine: Engine) -> None:
    """Founder renames slug: 200 + new slug set + old slug in history + lifecycle event."""
    # RED: no PATCH route or tenant:rename-slug perm → will 404/405/403 before this passes.
    a_tid, a_cookie = _signup_and_login(probe, "founder@acme-rename.com", "acme-orig")

    r = probe.patch(
        f"/tenants/{a_tid}/slug",
        headers=_headers(a_cookie),
        json={"slug": "acme-corp"},
    )
    assert r.status_code == 200, r.text
    body = r.json()
    assert body["tenant_id"] == a_tid
    assert body["slug"] == "acme-corp"

    assert _tenant_slug(lc_engine, a_tid) == "acme-corp"
    assert _slug_history_has(lc_engine, "acme-orig") is True
    assert _lifecycle_actions(lc_engine, a_tid)[-1] == "rename"


def test_rename_to_cooling_slug_is_409(probe: TestClient, lc_engine: Engine) -> None:
    """Attempting to rename to a cooling (reserved) slug → 409."""
    # RED: no route → 404/405 before this passes.
    a_tid, a_cookie = _signup_and_login(probe, "founder@acme-src.com", "acme-src")
    # Signup B so the FK tenant_id constraint is satisfied for the slug history row.
    b_tid, _ = _signup_and_login(probe, "founder@acme-b-cooling.com", "acme-b-cooling")

    _retire_slug(lc_engine, "reserved-x", b_tid, days=30)  # still cooling

    r = probe.patch(
        f"/tenants/{a_tid}/slug",
        headers=_headers(a_cookie),
        json={"slug": "reserved-x"},
    )
    assert r.status_code == 409, r.text


def test_rename_lazy_deletes_own_expired_history(
    probe: TestClient, lc_engine: Engine
) -> None:
    """Reclaiming an expired history row for new_slug lazy-deletes that row on commit."""
    # RED: no route or lazy-delete logic → row persists / 404 before this passes.
    a_tid, a_cookie = _signup_and_login(probe, "founder@acme-expired.com", "acme-orig2")

    # Insert an EXPIRED history row for the slug we want to reclaim (A's own old slug).
    _retire_slug(lc_engine, "want-back", a_tid, days=-1)

    r = probe.patch(
        f"/tenants/{a_tid}/slug",
        headers=_headers(a_cookie),
        json={"slug": "want-back"},
    )
    assert r.status_code == 200, r.text
    assert _tenant_slug(lc_engine, a_tid) == "want-back"
    # Expired row must be gone — lazy-deleted on reclaim.
    assert _slug_history_has(lc_engine, "want-back") is False


def test_rename_missing_tenant_is_404(probe: TestClient, lc_engine: Engine) -> None:
    """PATCH with a bogus tenant_id (non-member) → 404, never 500.

    The guard returns 404 for a non-member/unknown tenant — which is the desired
    behaviour: proves the old brief's .slug-on-None AttributeError 500 never fires.
    """
    # RED: no route → 404 (method-not-found) or 405 before this passes.
    _, a_cookie = _signup_and_login(probe, "founder@acme-bogus.com", "acme-bogus")

    r = probe.patch(
        "/tenants/ffffffffffffffffffffffffffffffff/slug",
        headers=_headers(a_cookie),
        json={"slug": "whatever-slug"},
    )
    assert r.status_code == 404, r.text


def test_old_slug_does_not_route_after_rename(
    probe: TestClient, lc_engine: Engine
) -> None:
    """After rename A→B, using the OLD slug as a path id returns 404 (id↔slug-desync)."""
    # RED: no route → 405; after route added confirms slugs are never treated as ids.
    a_tid, a_cookie = _signup_and_login(probe, "founder@acme-desync.com", "acme-desync")

    # Rename successfully first.
    r = probe.patch(
        f"/tenants/{a_tid}/slug",
        headers=_headers(a_cookie),
        json={"slug": "acme-desync-new"},
    )
    assert r.status_code == 200, r.text

    # Now attempt to use the OLD slug as a tenant_id path segment.
    r = probe.patch(
        "/tenants/acme-desync/slug",
        headers=_headers(a_cookie),
        json={"slug": "anything"},
    )
    assert r.status_code == 404, r.text
