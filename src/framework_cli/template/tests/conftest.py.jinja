@pytest.fixture(scope="session")
def pg_url() -> Iterator[str]:
    """A real Postgres started for the test session. Fails (not skips) without Docker.

    The image build + container start is retried with backoff so a transient
    image-registry / apt-mirror hiccup (Docker Hub pull or PGDG apt 5xx/timeout) doesn't
    flake CI — only a persistent failure (no Docker, broken image) actually fails."""
    from testcontainers.postgres import PostgresContainer
{%- if uses_postgres_extension %}
    from testcontainers.core.image import DockerImage
{%- endif %}

    def _build_and_start() -> PostgresContainer:
{%- if uses_postgres_extension %}
        # Build the same custom image the compose stack uses, so tests exercise the real
        # extension install (not a prebuilt pull). cwd is the project root under pytest.
        image = DockerImage(
            path=".",
            dockerfile_path="infra/docker/postgres.Dockerfile",
            tag="{{ package_name }}-postgres:test",
        )
        image.build()  # tag persists for Docker layer cache; fine for a test image
        container = PostgresContainer(str(image), driver="psycopg")
{%- set _preloads = [] %}
{%- if "timescaledb" in batteries %}{% set _ = _preloads.append("timescaledb") %}{% endif %}
{%- if "age" in batteries %}{% set _ = _preloads.append("age") %}{% endif %}
{%- if _preloads %}
        preload = "{{ _preloads | join(',') }}"
        container = container.with_command(
            f"postgres -c shared_preload_libraries={preload}"
        )
{%- endif %}
{%- else %}
        container = PostgresContainer("postgres:17", driver="psycopg")
{%- endif %}
        container.start()
        return container

    container = None
    last_exc: Exception | None = None
    for attempt in range(3):
        try:
            container = _build_and_start()
            break
        except Exception as exc:  # transient registry/apt hiccup — back off and retry
            last_exc = exc
            time.sleep(2**attempt)
    if container is None:
        pytest.fail(
            "Database tests need Docker (a Postgres test container). "
            f"Install/start Docker and retry. Underlying error: {last_exc}"
        )
    try:
        yield container.get_connection_url()
    finally:
        container.stop()


