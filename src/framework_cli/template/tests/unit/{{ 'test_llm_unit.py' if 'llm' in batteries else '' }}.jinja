def _new_metrics():
    from {{ package_name }}.llm.metrics import LLMMetrics

    return LLMMetrics()


def test_exhausted_is_an_llm_error():
    assert issubclass(LLMExhausted, LLMError)


def test_metrics_record_call_outcomes():
    m = LLMMetrics()
    m.record_call("success", "default")
    m.record_call("success", "default")
    m.record_call("error", "default")
    out = m.render_prometheus()
    assert 'app_llm_calls_total{profile="default",outcome="success"} 2' in out
    assert 'app_llm_calls_total{profile="default",outcome="error"} 1' in out
    assert "# TYPE app_llm_calls_total counter" in out


def test_metrics_record_tokens_and_cost():
    m = LLMMetrics()
    m.record_tokens("default", input=10, output=5, cache_read=3)
    m.record_cost("default", 0.0021)
    out = m.render_prometheus()
    assert 'app_llm_tokens_total{profile="default",kind="input"} 10' in out
    assert 'app_llm_tokens_total{profile="default",kind="output"} 5' in out
    assert 'app_llm_tokens_total{profile="default",kind="cache_read"} 3' in out
    assert 'app_llm_cost_usd_total{profile="default"} 0.002100' in out


def test_metrics_latency_p99_gauge_present():
    m = LLMMetrics()
    for v in (10.0, 20.0, 30.0):
        m.record_latency_ms(v)
    out = m.render_prometheus()
    assert "# TYPE app_llm_call_latency_p99_ms gauge" in out
    assert "app_llm_call_latency_p99_ms " in out


def test_metrics_cost_avoids_scientific_notation():
    m = LLMMetrics()
    m.record_cost("default", 0.0000123)
    cost_line = [
        ln
        for ln in m.render_prometheus().splitlines()
        if ln.startswith("app_llm_cost_usd_total{")
    ][0]
    value_part = cost_line.split(" ", 1)[1]
    assert "e" not in value_part  # no scientific notation in the value
    assert cost_line == 'app_llm_cost_usd_total{profile="default"} 0.000012'


def test_metrics_reset_clears_all():
    m = LLMMetrics()
    m.record_call("success", "default")
    m.record_tokens("default", input=5)
    m.record_cost("default", 0.01)
    m.record_latency_ms(12.0)
    m.reset()
    out = m.render_prometheus()
    assert "app_llm_calls_total{" not in out
    assert "app_llm_tokens_total{" not in out
    assert "app_llm_cost_usd_total{" not in out
    assert "app_llm_call_latency_p99_ms 0" in out


def test_unknown_outcome_is_ignored():
    m = LLMMetrics()
    m.record_call("bogus")
    out = m.render_prometheus()
    # unknown outcome is silently dropped; no series for "bogus"
    assert "bogus" not in out


def test_metrics_label_by_profile():
    m = _new_metrics()
    m.record_call("success", "default")
    m.record_call("success", "cheap")
    m.record_call("error", "cheap")
    m.record_tokens("cheap", input=10, output=5, cache_read=3)
    m.record_cost("cheap", 0.0021)
    out = m.render_prometheus()
    assert 'app_llm_calls_total{profile="default",outcome="success"} 1' in out
    assert 'app_llm_calls_total{profile="cheap",outcome="success"} 1' in out
    assert 'app_llm_calls_total{profile="cheap",outcome="error"} 1' in out
    assert 'app_llm_tokens_total{profile="cheap",kind="input"} 10' in out
    assert 'app_llm_cost_usd_total{profile="cheap"} 0.002100' in out


def test_metrics_reset_clears_all_new():
    m = _new_metrics()
    m.record_call("success", "cheap")
    m.record_cost("cheap", 0.01)
    m.reset()
    assert m.render_prometheus().count("app_llm_calls_total{") == 0
    assert "app_llm_call_latency_p99_ms 0" in m.render_prometheus()


class _Msg:
    def __init__(self, content):
        self.content = content
        self.tool_calls = None


class _Choice:
    def __init__(self, content):
        self.message = _Msg(content)


class _Usage:
    def __init__(self):
        self.prompt_tokens = 12
        self.completion_tokens = 7
        self.prompt_tokens_details = type("D", (), {"cached_tokens": 4})()


class _Resp:
    def __init__(self, content):
        self.choices = [_Choice(content)]
        self.usage = _Usage()


def _settings() -> Settings:
    return Settings(
        llm_api_key="k", llm_model="claude-sonnet-4-6", llm_provider="anthropic"
    )


def _psettings(**over):
    from {{ package_name }}.config.settings import Settings

    base = dict(
        llm_provider="anthropic",
        llm_model="claude-sonnet-4-6",
        llm_api_key="defkey",
        llm_max_tokens=4096,
        llm_temperature=0.0,
    )
    base.update(over)
    return Settings(**base)


def test_complete_returns_text_and_usage(monkeypatch):
    captured = {}

    def fake_completion(**kwargs):
        captured.update(kwargs)
        return _Resp("hello there")

    monkeypatch.setattr(litellm, "completion", fake_completion)
    monkeypatch.setattr(litellm, "completion_cost", lambda **_: 0.0009)

    metrics = LLMMetrics()
    svc = LLMService(_settings(), metrics=metrics)
    result = svc.complete([{"role": "user", "content": "hi"}], system="be brief")

    assert isinstance(result, CompletionResult)
    assert result.text == "hello there"
    assert result.usage == {"input": 12, "output": 7, "cache_read": 4}
    assert captured["model"] == "anthropic/claude-sonnet-4-6"
    assert captured["api_key"] == "k"
    assert captured["messages"][0] == {"role": "system", "content": "be brief"}
    out = metrics.render_prometheus()
    assert 'app_llm_calls_total{profile="default",outcome="success"} 1' in out
    assert 'app_llm_tokens_total{profile="default",kind="input"} 12' in out
    assert 'app_llm_cost_usd_total{profile="default"} 0.000900' in out


def test_complete_maps_rate_limit_to_exhausted(monkeypatch):
    def boom(**_):
        raise litellm.exceptions.RateLimitError(
            message="slow down", model="claude-sonnet-4-6", llm_provider="anthropic"
        )

    monkeypatch.setattr(litellm, "completion", boom)
    metrics = LLMMetrics()
    svc = LLMService(_settings(), metrics=metrics)

    with pytest.raises(LLMExhausted):
        svc.complete([{"role": "user", "content": "hi"}])
    assert (
        'app_llm_calls_total{profile="default",outcome="exhausted"} 1'
        in metrics.render_prometheus()
    )


def test_complete_maps_generic_error(monkeypatch):
    def boom(**_):
        raise litellm.exceptions.InternalServerError(
            message="kaboom", model="m", llm_provider="anthropic"
        )

    monkeypatch.setattr(litellm, "completion", boom)
    metrics = LLMMetrics()
    svc = LLMService(_settings(), metrics=metrics)

    with pytest.raises(LLMError):
        svc.complete([{"role": "user", "content": "hi"}])
    assert (
        'app_llm_calls_total{profile="default",outcome="error"} 1'
        in metrics.render_prometheus()
    )


@pytest.fixture()
def service() -> LLMService:
    return LLMService(_settings(), metrics=LLMMetrics())


class Person(BaseModel):
    name: str
    age: int


def test_complete_structured_parses_into_schema(monkeypatch):
    monkeypatch.setattr(
        litellm, "completion", lambda **_: _Resp('{"name": "Ada", "age": 36}')
    )
    monkeypatch.setattr(litellm, "completion_cost", lambda **_: 0.0)

    svc = LLMService(_settings(), metrics=LLMMetrics())
    person = svc.complete_structured([{"role": "user", "content": "x"}], Person)
    assert person == Person(name="Ada", age=36)


def test_complete_structured_bad_json_raises_llm_error(monkeypatch, service):
    monkeypatch.setattr(litellm, "completion", lambda **kw: _Resp("not json"))
    with pytest.raises(LLMError):
        service.complete_structured([{"role": "user", "content": "x"}], Person)


def test_complete_no_system_omits_system_message(monkeypatch, service):
    captured: dict = {}

    def fake_completion(**kw: object) -> _Resp:
        captured.update(kw)
        return _Resp("hi")

    monkeypatch.setattr(litellm, "completion", fake_completion)
    service.complete([{"role": "user", "content": "hello"}])
    msgs = captured["messages"]
    assert msgs[0]["role"] == "user"
    assert msgs[0]["content"] == "hello"
    assert all(m["role"] != "system" for m in msgs)


