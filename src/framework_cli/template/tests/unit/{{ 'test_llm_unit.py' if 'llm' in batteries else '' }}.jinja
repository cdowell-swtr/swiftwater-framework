def test_falsy_but_valid_overrides_are_kept():
    from {{ package_name }}.config.settings import LLMProfile
    from {{ package_name }}.llm.profiles import resolve_profile

    s = _psettings(llm_profiles={"z": LLMProfile(temperature=0.0, max_tokens=1)})
    r = resolve_profile(_psettings(llm_temperature=0.7, llm_max_tokens=4096))
    assert r.temperature == 0.7  # default kept
    r2 = resolve_profile(s, "z")
    assert (
        r2.temperature == 0.0 and r2.max_tokens == 1
    )  # falsy-but-valid profile values kept


