"""Unit tests for {{ package_name }}.multitenantauth.authn.passwords — argon2id + pepper hashing."""

import hashlib
import hmac

import pytest

from {{ package_name }}.config.settings import get_settings


@pytest.fixture(autouse=True)
def _clear_settings_cache():
    """Ensure each test starts with a fresh settings cache."""
    get_settings.cache_clear()
    yield
    get_settings.cache_clear()


@pytest.fixture()
def _set_pepper(monkeypatch):
    """Set a stable pepper for tests that need one."""
    monkeypatch.setenv("APP_PASSWORD_PEPPER", "test-pepper-for-unit-tests")
    get_settings.cache_clear()


def test_hash_is_not_plaintext(_set_pepper):
    """The stored hash must never equal the plaintext password."""
    from {{ package_name }}.multitenantauth.authn.passwords import hash_password

    password = "pw-placeholder"
    encoded = hash_password(password)
    assert encoded != password


def test_hash_is_unique_per_call(_set_pepper):
    """Two hashes of the same password differ (per-row salt is embedded)."""
    from {{ package_name }}.multitenantauth.authn.passwords import hash_password

    h1 = hash_password("pw-placeholder")
    h2 = hash_password("pw-placeholder")
    assert h1 != h2


def test_verify_correct_password(_set_pepper):
    """verify_password returns True for the correct password."""
    from {{ package_name }}.multitenantauth.authn.passwords import hash_password, verify_password

    encoded = hash_password("pw-placeholder")
    assert verify_password("pw-placeholder", encoded) is True


def test_verify_wrong_password(_set_pepper):
    """verify_password returns False for an incorrect password."""
    from {{ package_name }}.multitenantauth.authn.passwords import hash_password, verify_password

    encoded = hash_password("pw-placeholder")
    assert verify_password("wrong-password", encoded) is False


def test_verify_invalid_hash_returns_false(_set_pepper):
    """verify_password returns False (not raises) for a completely invalid hash string."""
    from {{ package_name }}.multitenantauth.authn.passwords import verify_password

    assert verify_password("pw-placeholder", "not-a-valid-argon2-hash") is False


def test_verify_wrong_pepper_returns_false(monkeypatch):
    """verify_password returns False when the pepper has changed (wrong-pepper failure)."""
    monkeypatch.setenv("APP_PASSWORD_PEPPER", "pepper-alpha")
    get_settings.cache_clear()

    from {{ package_name }}.multitenantauth.authn.passwords import hash_password, verify_password

    encoded = hash_password("pw-placeholder")

    # Switch to a different pepper — the stored hash was made with pepper-alpha.
    monkeypatch.setenv("APP_PASSWORD_PEPPER", "pepper-beta")
    get_settings.cache_clear()

    assert verify_password("pw-placeholder", encoded) is False


def test_pepper_is_read_from_settings(monkeypatch):
    """The pepper comes from settings (not hardcoded): different peppers → different hashed inputs."""
    from {{ package_name }}.multitenantauth.authn.passwords import _peppered

    monkeypatch.setenv("APP_PASSWORD_PEPPER", "pepper-one")
    get_settings.cache_clear()
    h1 = _peppered("pw-placeholder")

    monkeypatch.setenv("APP_PASSWORD_PEPPER", "pepper-two")
    get_settings.cache_clear()
    h2 = _peppered("pw-placeholder")

    assert h1 != h2


def test_peppered_is_hmac_sha256(monkeypatch):
    """_peppered produces HMAC-SHA256(password, pepper) in hex — the exact algorithm."""
    pepper = "test-pepper-for-unit-tests"
    monkeypatch.setenv("APP_PASSWORD_PEPPER", pepper)
    get_settings.cache_clear()

    from {{ package_name }}.multitenantauth.authn.passwords import _peppered

    password = "pw-placeholder"
    expected = hmac.new(pepper.encode(), password.encode(), hashlib.sha256).hexdigest()
    assert _peppered(password) == expected


def test_needs_rehash_after_cost_increase(monkeypatch):
    """needs_rehash returns True when a cost parameter increases from the hash's original."""
    monkeypatch.setenv("APP_PASSWORD_PEPPER", "test-pepper-for-unit-tests")
    monkeypatch.setenv("APP_ARGON2_TIME_COST", "3")
    get_settings.cache_clear()

    from {{ package_name }}.multitenantauth.authn.passwords import hash_password, needs_rehash

    old_hash = hash_password("pw-placeholder")

    # Now raise the time cost — same pepper, higher cost → needs_rehash should be True.
    monkeypatch.setenv("APP_ARGON2_TIME_COST", "4")
    get_settings.cache_clear()

    assert needs_rehash(old_hash) is True


def test_needs_rehash_false_for_current_params(monkeypatch):
    """needs_rehash returns False when the hash was created with the current params."""
    monkeypatch.setenv("APP_PASSWORD_PEPPER", "test-pepper-for-unit-tests")
    monkeypatch.setenv("APP_ARGON2_TIME_COST", "3")
    get_settings.cache_clear()

    from {{ package_name }}.multitenantauth.authn.passwords import hash_password, needs_rehash

    current_hash = hash_password("pw-placeholder")
    assert needs_rehash(current_hash) is False


def test_needs_rehash_invalid_hash_returns_true(_set_pepper):
    """needs_rehash returns True (not raises) for an invalid/garbage hash string."""
    from {{ package_name }}.multitenantauth.authn.passwords import needs_rehash

    assert needs_rehash("not-a-valid-argon2-hash") is True
