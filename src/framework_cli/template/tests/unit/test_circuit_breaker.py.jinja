import pybreaker
import pytest

from {{ package_name }}.observability.recoverability import recoverability
from {{ package_name }}.resilience.circuit_breaker import build_breaker


def test_new_breaker_reports_closed_state():
    build_breaker(name="svc-a", fail_max=2, reset_timeout=60)
    assert recoverability.circuit_state("svc-a") == 0  # closed


def test_breaker_opens_after_fail_max_and_gauge_reflects_it():
    # fail_max=3: the first two calls raise RuntimeError (failures counted),
    # the third call is the trip — pybreaker raises CircuitBreakerError on the
    # failure that opens the breaker, not the original exception.
    breaker = build_breaker(name="svc-b", fail_max=3, reset_timeout=60)

    def boom() -> None:
        raise RuntimeError("dependency down")

    # First two failures are counted but the breaker stays closed.
    for _ in range(2):
        with pytest.raises(RuntimeError):
            breaker.call(boom)

    # Third call trips the breaker; pybreaker raises CircuitBreakerError on the trip.
    with pytest.raises(pybreaker.CircuitBreakerError):
        breaker.call(boom)

    assert recoverability.circuit_state("svc-b") == 1  # open

    # While open, calls fail fast with CircuitBreakerError (the dependency isn't called).
    with pytest.raises(pybreaker.CircuitBreakerError):
        breaker.call(boom)


def test_metrics_render_includes_breaker_gauge_line():
    build_breaker(name="svc-c", fail_max=1, reset_timeout=60)
    rendered = recoverability.render_prometheus()
    assert 'app_circuit_breaker_state{name="svc-c"} 0' in rendered
