def test_tenant_routing_settings_defaults() -> None:
    from {{ package_name }}.config.settings import Settings

    s = Settings()
    assert s.tenant_pool_size == 2
    assert s.tenant_max_overflow == 3
    assert s.max_cached_engines == 12
    assert s.control_pool_size == 5
    assert s.control_max_overflow == 10
    assert s.db_pool_safety_factor == 0.8
    assert s.tenant_dsn_cache_ttl_seconds == 300
    assert s.tenant_db_name_prefix  # non-empty; defaults to "<package>_tenant"


def test_tenant_db_name_prefix_env_override(monkeypatch) -> None:
    from {{ package_name }}.config.settings import Settings

    monkeypatch.setenv("APP_TENANT_DB_NAME_PREFIX", "acme_t")
    assert Settings().tenant_db_name_prefix == "acme_t"


def test_max_cached_engines_floor_rejects_zero() -> None:
    """Fix 3: max_cached_engines=0 would make _evict_if_full spin forever; Field(ge=1) prevents it."""
    from pydantic import ValidationError

    with pytest.raises(ValidationError):
        Settings(max_cached_engines=0)


def test_db_pool_safety_factor_bounded_to_unit_interval() -> None:
    """Layer-2 P3 (I-BUDGET): a safety factor > 1 inflates the budget past the live ceiling so
    BudgetExceeded never fires; <= 0 refuses every endpoint. Bound to (0, 1] — the budget must
    not be defeasible by a config value."""
    from pydantic import ValidationError

    with pytest.raises(ValidationError):
        Settings(db_pool_safety_factor=1.5)
    with pytest.raises(ValidationError):
        Settings(db_pool_safety_factor=0.0)


def test_pool_and_overflow_knobs_reject_unlimited_sentinels() -> None:
    """Layer-2 P4 (I-BUDGET): SQLAlchemy treats pool_size=0 as unbounded and max_overflow=-1 as
    unlimited — either builds an infinite pool behind a passing budget estimate. ge=1 / ge=0
    floors keep required_connections a true upper bound."""
    from pydantic import ValidationError

    for field in ("tenant_pool_size", "control_pool_size"):
        with pytest.raises(ValidationError):
            Settings(**{field: 0})
    for field in ("tenant_max_overflow", "control_max_overflow"):
        with pytest.raises(ValidationError):
            Settings(**{field: -1})
