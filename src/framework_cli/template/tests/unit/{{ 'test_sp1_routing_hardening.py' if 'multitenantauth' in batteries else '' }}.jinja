"""Layer-2 SP1 routing-core hardening regressions (multitenantauth battery).

Guards the two confirmed High findings from the SP1 Layer-2 adversarial security review:
- P1 (I-CRED): migrate_tenant must not let a tenant DSN reach a stdlib ConfigParser
  interpolation error message (credential disclosure), while the DSN still round-trips intact.
- P10 (I-IDEMP): the app alembic env must register the control-plane tables so an app
  `--autogenerate` EXCLUDES them instead of emitting drop_table for the entire control plane.
"""

from pathlib import Path

import {{ package_name }}.multitenantauth.tenancy.provision as provision_mod
from {{ package_name }}.multitenantauth.tenancy.provision import migrate_tenant


def test_migrate_tenant_does_not_leak_dsn_via_configparser_interpolation(monkeypatch):
    """P1: a '%' in the DSN (a BYO literal '%', or a %XX-percent-encoded special char in the
    app password) must NOT raise a ConfigParser ValueError whose message embeds the plaintext
    credentials — and the DSN must still round-trip to alembic intact."""
    captured: dict[str, str | None] = {}

    def _capture_upgrade(cfg, rev):  # type: ignore[no-untyped-def]
        captured["url"] = cfg.get_main_option("sqlalchemy.url")

    monkeypatch.setattr(provision_mod.command, "upgrade", _capture_upgrade)
    dsn = "postgresql+psycopg://app:p%40ss@db:5432/tenants_abc"
    migrate_tenant(dsn)  # must not raise ValueError from interpolation
    # the interpolating get_main_option un-escapes %%->% so alembic sees the original DSN
    assert captured["url"] == dsn


def test_app_alembic_env_registers_control_tables_for_exclusion():
    """P10: importing the control models (as the app env.py now does) populates
    ControlBase.metadata, so the app autogenerate's _include_object can exclude them. Also assert
    the rendered env.py source still carries the import — guarding against its removal (the
    original silently-empty-exclusion-set bug)."""
    from {{ package_name }}.db.control import models  # noqa: F401  (registers control tables)
    from {{ package_name }}.db.control.base import ControlBase

    tables = set(ControlBase.metadata.tables.keys())
    assert tables, (
        "control table exclusion set is empty — app autogenerate would DROP them"
    )
    assert {"tenant", "app_user"} <= tables

    env_src = (provision_mod._project_root() / "migrations" / "env.py").read_text()
    assert "from {{ package_name }}.db.control import models" in env_src
