"""The authorization expression evaluator — the security decision core. These tests pin the
domain-scope isolation, the empty/wildcard construction guards, short-circuit, and the
deny-not-crash behaviour on a missing path param."""

import pytest

from {{ package_name }}.multitenantauth.authz.expr import ALL, ANY, Authorized, Perm, evaluate


def _ctx(
    *,
    tenant=(),
    platform=(),
    path=None,
    subtree=lambda name, res: False,
    resource_grant=lambda name, res: False,
):
    return {
        "tenant_perms": set(tenant),
        "platform_perms": set(platform),
        "path": path if path is not None else {},
        "subtree_exists": subtree,
        "resource_grant": resource_grant,
    }


def test_tenant_leaf_checks_tenant_perms_bound_to_path():
    e = Perm("tenant:read", on="tenant:{tenant_id}")
    assert evaluate(e, _ctx(tenant=["tenant:read"], path={"tenant_id": "acme"}))
    assert not evaluate(e, _ctx(tenant=[], path={"tenant_id": "acme"}))


def test_platform_leaf_checks_platform_perms():
    e = Perm("platform-tenant:provision", on="platform")
    assert evaluate(e, _ctx(platform=["platform-tenant:provision"]))
    assert not evaluate(e, _ctx(platform=[]))


def test_domain_scopes_never_cross():
    # a tenant-named perm on the platform resource checks ONLY platform grants → deny
    assert not evaluate(
        Perm("tenant:read", on="platform"),
        _ctx(tenant=["tenant:read"], platform=[]),
    )
    # a platform-named perm on a tenant resource checks ONLY tenant grants → deny
    assert not evaluate(
        Perm("platform-tenant:provision", on="tenant:{tenant_id}"),
        _ctx(platform=["platform-tenant:provision"], path={"tenant_id": "acme"}),
    )


def test_nested_all_any_short_circuit():
    e = ALL(
        Perm("a", on="tenant:{tenant_id}"),
        ANY(Perm("b", on="tenant:{tenant_id}"), Perm("c", on="tenant:{tenant_id}")),
    )
    assert evaluate(e, _ctx(tenant=["a", "c"], path={"tenant_id": "t"}))
    assert not evaluate(
        ALL(Perm("a", on="tenant:{tenant_id}"), Perm("z", on="tenant:{tenant_id}")),
        _ctx(tenant=["a"], path={"tenant_id": "t"}),
    )


def test_empty_quantifiers_raise():
    with pytest.raises(ValueError, match="ALL"):
        ALL()
    with pytest.raises(ValueError, match="ANY"):
        ANY()


def test_wildcard_perm_rejected_as_direct_child_of_all():
    with pytest.raises(ValueError, match="wildcard"):
        ALL(
            Perm("tenant:read", on="tenant:{tenant_id}"),
            Perm("resource:view", on="tenant:{tenant_id}/resource:*"),
        )


def test_wildcard_inside_any_is_inert_and_falls_back():
    e = ANY(
        Perm("tenant:read", on="tenant:{tenant_id}"),
        Perm("resource:view", on="tenant:{tenant_id}/resource:*"),
    )
    # tenant term carries it
    assert evaluate(e, _ctx(tenant=["tenant:read"], path={"tenant_id": "t"}))
    # resource wildcard is inert (subtree_exists → False) → whole ANY denies
    assert not evaluate(e, _ctx(tenant=[], path={"tenant_id": "t"}))


def test_missing_path_param_denies_not_crashes():
    e = Perm("tenant:read", on="tenant:{tenant_id}")
    assert evaluate(e, _ctx(tenant=["tenant:read"], path={})) is False  # no KeyError


def test_path_value_star_does_not_flip_a_concrete_leaf_to_wildcard():
    """A '*' injected into a path VALUE must not reclassify a concrete leaf as a wildcard subtree —
    wildcard-ness comes from the authored pattern, not the bound value."""
    e = Perm("resource:view", on="tenant:{tenant_id}/resource:{resource_id}")
    subtree_permissive = lambda name, res: True  # noqa: E731 — would grant if (wrongly) routed to the subtree
    # resource_id="*" must NOT route to subtree_exists; resource_grant denies here → no branch flip.
    assert not evaluate(
        e,
        _ctx(
            path={"tenant_id": "acme", "resource_id": "*"},
            subtree=subtree_permissive,
            resource_grant=lambda name, res: False,
        ),
    )
    # held perm via resource_grant + injected '*' still resolves as a resource-grant check (no subtree flip).
    assert evaluate(
        e,
        _ctx(
            path={"tenant_id": "acme", "resource_id": "*"},
            subtree=subtree_permissive,
            resource_grant=lambda name, res: True,
        ),
    )


def test_authored_wildcard_uses_subtree_resolver():
    """A genuinely-authored wildcard leaf DOES consult subtree_exists (and grants when it returns True)."""
    e = ANY(Perm("resource:view", on="tenant:{tenant_id}/resource:*"))
    assert evaluate(
        e, _ctx(tenant=[], path={"tenant_id": "t"}, subtree=lambda n, r: True)
    )
    assert not evaluate(
        e, _ctx(tenant=[], path={"tenant_id": "t"}, subtree=lambda n, r: False)
    )


def test_all_rejects_wildcard_nested_under_any():
    """The ALL wildcard guard is recursive — ALL(ANY(wild)) must raise, not just direct children."""
    with pytest.raises(ValueError, match="wildcard"):
        ALL(
            ANY(Perm("resource:view", on="tenant:{tenant_id}/resource:*")),
            Perm("tenant:read", on="tenant:{tenant_id}"),
        )


def test_platform_prefix_not_equal_does_not_get_platform_grants():
    """Only the exact resource 'platform' consults platform grants; a 'platform-...'-shaped resource
    is not the platform scope and fails closed (routes to the tenant check → deny)."""
    e = Perm("x", on="platform-thing:{y}")
    assert not evaluate(e, _ctx(platform=["x"], path={"y": "1"}))


def test_authorized_introspection():
    e = ALL(
        Perm("tenant:read", on="tenant:{tenant_id}"),
        ANY(Perm("resource:view", on="tenant:{tenant_id}/resource:{resource_id}")),
    )
    a = Authorized(e)
    assert a.expr is e
    assert a.resource_params() == {"tenant_id", "resource_id"}
    assert {leaf.name for leaf in a.perm_leaves()} == {"tenant:read", "resource:view"}
