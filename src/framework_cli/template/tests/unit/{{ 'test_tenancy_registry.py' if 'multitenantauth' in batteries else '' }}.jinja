# ── tests: no create_engine / tenant_session in registry ──────────────────────


def test_registry_module_has_no_routing_imports() -> None:
    """The registry module must not import create_engine or tenant_session (routing-agnostic)."""
    import ast
    import pathlib

    registry_path = pathlib.Path(registry.__file__)
    source = registry_path.read_text()
    tree = ast.parse(source)

    banned_names = {
        "create_engine",
        "tenant_session",
        "build_engine",
        "invalidate_dsn_cache",
    }
    found = set()
    for node in ast.walk(tree):
        if isinstance(node, (ast.Import, ast.ImportFrom)):
            if isinstance(node, ast.ImportFrom):
                for alias in node.names:
                    if alias.name in banned_names:
                        found.add(alias.name)
            else:
                for alias in node.names:
                    if alias.name in banned_names:
                        found.add(alias.name)
        elif isinstance(node, ast.Name):
            if node.id in banned_names:
                found.add(node.id)
        elif isinstance(node, ast.Attribute):
            if node.attr in banned_names:
                found.add(node.attr)

    # Also check repository
    repo_path = pathlib.Path(control_repo.__file__)
    source2 = repo_path.read_text()
    tree2 = ast.parse(source2)
    for node in ast.walk(tree2):
        if isinstance(node, ast.Attribute):
            if node.attr in banned_names:
                found.add(node.attr)

    assert not found, f"routing imports found in registry/repository: {found}"
