    with Session(registry_engine) as s:
        row = s.get(m.Tenant, tid)
        assert row is not None
        assert row.status == "provisioning"


def test_register_tenant_does_not_connect_to_dsn(registry_engine: Engine) -> None:
    """register_tenant must never connect to the tenant dsn (routing-agnostic)."""
    # An unroutable dsn: if any connection is attempted this will fail.
    unroutable_dsn = "postgresql+psycopg://x:x@127.0.0.1:1/unreachable"
    with Session(registry_engine) as s:
        # If this raises a connection error, the registry is not routing-agnostic.
        t = registry.register_tenant(
            s,
            name="NoConnect Corp",
            slug="no-connect",
            dsn=unroutable_dsn,
        )
        s.commit()
        tid = t.id

    # Verify the dsn is stored as-is (opaque string, never dialed)
    with Session(registry_engine) as s:
        row = s.get(m.Tenant, tid)
        assert row is not None
        assert row.dsn == unroutable_dsn


