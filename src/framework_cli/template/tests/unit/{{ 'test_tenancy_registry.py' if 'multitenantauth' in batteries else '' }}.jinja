def test_rename_slug_moves_old_to_history(registry_engine: Engine) -> None:
    """rename_slug must: set the new slug, insert the old slug to TenantSlugHistory
    with a future reserved_until cooling window."""
    with Session(registry_engine) as s:
        t = registry.register_tenant(
            s, name="Zeta Inc", slug="zeta-old", dsn="postgresql+psycopg://x/z"
        )
        s.commit()
        tid = t.id

    with Session(registry_engine) as s:
        registry.rename_slug(s, tid, "zeta-new")
        s.commit()

    with Session(registry_engine) as s:
        # New slug is live
        row = s.get(m.Tenant, tid)
        assert row is not None
        assert row.slug == "zeta-new"

        # Old slug is in history with future reserved_until
        hist = s.get(m.TenantSlugHistory, "zeta-old")
        assert hist is not None
        assert hist.tenant_id == tid
        assert hist.reserved_until is not None
        assert hist.reserved_until > datetime.now(timezone.utc)


def test_rename_slug_rejects_still_cooling_target(registry_engine: Engine) -> None:
    """rename_slug must raise ValueError if the new slug is still in its cooling window
    (reserved_until in the future) from a previous tenant's rename."""
    with Session(registry_engine) as s:
        t1 = registry.register_tenant(
            s, name="T1", slug="t1-slug", dsn="postgresql+psycopg://x/t1"
        )
        t2 = registry.register_tenant(
            s, name="T2", slug="t2-slug", dsn="postgresql+psycopg://x/t2"
        )
        s.commit()
        t1_id = t1.id
        t2_id = t2.id

    # T1 renames away from "t1-slug" — it goes into a cooling window.
    with Session(registry_engine) as s:
        registry.rename_slug(s, t1_id, "t1-new")
        s.commit()

    # T2 must NOT be able to claim "t1-slug" while it is still cooling.
    with Session(registry_engine) as s:
        with pytest.raises(ValueError, match="cooling|reserved|not.*claimable|slug"):
            registry.rename_slug(s, t2_id, "t1-slug")


