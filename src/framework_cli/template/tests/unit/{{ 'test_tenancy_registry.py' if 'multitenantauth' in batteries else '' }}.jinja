def test_register_tenant_rejects_cooling_slug(registry_engine: Engine) -> None:
    """register_tenant must raise if the slug is in a cooling TenantSlugHistory row."""
    # Manually insert a cooling history row for a slug
    with Session(registry_engine) as s:
        # First create a tenant so the FK is valid
        t = registry.register_tenant(
            s, name="Owner", slug="owner", dsn="postgresql+psycopg://x/x"
        )
        s.commit()
        tenant_id = t.id

    with Session(registry_engine) as s:
        hist = m.TenantSlugHistory(
            slug="cooling-slug",
            tenant_id=tenant_id,
            reserved_until=datetime.now(timezone.utc) + timedelta(days=30),
        )
        s.add(hist)
        s.commit()

    with Session(registry_engine) as s:
        with pytest.raises(ValueError, match="cooling|reserved|not.*claimable|slug"):
            registry.register_tenant(
                s, name="Squatter", slug="cooling-slug", dsn="postgresql+psycopg://x/y"
            )


