def test_validate_tenant_id_invalid_charset_raises() -> None:
    """_validate_tenant_id must raise ValueError for unsafe charset strings."""
    for bad in ['a"b', "A", "a;drop", "a b", "tenant-id"]:
        with pytest.raises(ValueError, match="invalid.*tenant_id|must match"):
            registry._validate_tenant_id(bad)


def test_validate_tenant_id_valid_charset_passes() -> None:
    """_validate_tenant_id must accept valid [a-z0-9_]+ strings."""
    for good in ["abc", "a1b2c3", "tenant_id_01", "abc_123"]:
        registry._validate_tenant_id(good)  # must not raise


