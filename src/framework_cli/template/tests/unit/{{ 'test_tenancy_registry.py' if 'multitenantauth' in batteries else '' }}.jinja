@pytest.fixture(scope="module")
def registry_engine(pg_url: str) -> Engine:  # type: ignore[return]
    """Control-plane engine for registry tests."""
    _ctrl_db = "{{ package_name }}_registry_unit_test"
    base = make_url(pg_url)
    ctrl_url = base.set(database=_ctrl_db).render_as_string(hide_password=False)
    maint_url = base.set(database="postgres").render_as_string(hide_password=False)
    maint = create_engine(maint_url, isolation_level="AUTOCOMMIT")
    with maint.connect() as c:
        if not c.execute(
            text(f"SELECT 1 FROM pg_database WHERE datname='{_ctrl_db}'")
        ).scalar():
            c.execute(text(f'CREATE DATABASE "{_ctrl_db}"'))
    maint.dispose()

    engine = create_engine(ctrl_url)
    ControlBase.metadata.create_all(
        engine,
        tables=[
            m.Tenant.__table__,
            m.TenantSlugHistory.__table__,
        ],
    )
    yield engine
    engine.dispose()


@pytest.fixture(autouse=True)
def _clean(registry_engine: Engine) -> None:  # type: ignore[return]
    """Truncate tenancy tables after each test."""
    yield
    with registry_engine.begin() as conn:
        conn.execute(text("TRUNCATE TABLE tenant_slug_history, tenant CASCADE"))


