def test_register_tenant_mints_opaque_id_not_from_slug(registry_engine: Engine) -> None:
    """register_tenant must generate an id that is NOT equal to or derived from the slug."""
    with Session(registry_engine) as s:
        t = registry.register_tenant(
            s,
            name="Acme Inc",
            slug="acme",
            dsn="postgresql+psycopg://x:x@127.0.0.1:1/none",
        )
        s.commit()
        tid = t.id
        tslug = t.slug

    assert tid != tslug, "id must not equal slug"
    assert tslug not in tid, "id must not contain slug as substring"
    assert re.fullmatch(r"[a-z0-9_]+", tid), f"id charset violation: {tid!r}"


