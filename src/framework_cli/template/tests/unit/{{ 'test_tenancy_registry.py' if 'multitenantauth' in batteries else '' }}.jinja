"""Unit tests for the tenancy registry service.

Key invariants:
- register_tenant mints an opaque id NOT equal to / derived from the slug.
- register_tenant writes a 'provisioning' row and opens NO connection to the dsn.
- activate_tenant flips status to 'active'.
- invalid opaque-id charset raises ValueError.
- non-DNS-safe slug raises ValueError.
- rename_slug moves old slug to history with future reserved_until.
- rename_slug rejects a still-cooling (reserved_until in future) slug.
- resolve_slug: live slug → (id, False); retired cooling slug → (id, True); expired/unknown → None.
- get_tenant_dsn returns the stored opaque string.
"""

from __future__ import annotations

import re
from datetime import datetime, timedelta, timezone

import pytest
from sqlalchemy import Engine, create_engine, make_url, text
from sqlalchemy.orm import Session

from {{ package_name }}.db.control import models as m
from {{ package_name }}.db.control.base import ControlBase
from {{ package_name }}.db.control import repository as control_repo
from {{ package_name }}.multitenantauth.tenancy import registry


