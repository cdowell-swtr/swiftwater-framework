def test_reclaim_then_rename_does_not_collide_on_history_pk(
    registry_engine: Engine,
) -> None:
    """Full reclaim cycle must not hit a TenantSlugHistory PK collision.

    slug history rows are keyed on slug (sole PK). When a slug is retired,
    its cooling window expires, a NEW tenant reclaims it, and THAT tenant
    later retires it again, the second history write for the same slug must
    upsert (not blind-insert → IntegrityError). The row must end up pointing
    at the most-recent owner with a fresh future reserved_until.
    """
    with Session(registry_engine) as s:
        t1 = registry.register_tenant(
            s, name="R1", slug="alpha", dsn="postgresql+psycopg://x/r1"
        )
        t2 = registry.register_tenant(
            s, name="R2", slug="r2-home", dsn="postgresql+psycopg://x/r2"
        )
        s.commit()
        t1_id = t1.id
        t2_id = t2.id

    # T1 renames alpha → beta: history row slug=alpha now cooling, owner=T1.
    with Session(registry_engine) as s:
        registry.rename_slug(s, t1_id, "beta")
        s.commit()

    # Force the alpha cooling window to expire so T2 may reclaim it.
    with Session(registry_engine) as s:
        hist = s.get(m.TenantSlugHistory, "alpha")
        assert hist is not None
        hist.reserved_until = datetime.now(timezone.utc) - timedelta(days=1)
        s.commit()

    # T2 reclaims alpha (rename r2-home → alpha) — the slug is live again.
    with Session(registry_engine) as s:
        registry.rename_slug(s, t2_id, "alpha")
        s.commit()

    # T2 now retires alpha (alpha → gamma). This is the SECOND history write
    # for slug=alpha — must upsert, not collide.
    before = datetime.now(timezone.utc)
    with Session(registry_engine) as s:
        registry.rename_slug(s, t2_id, "gamma")  # must NOT raise IntegrityError
        s.commit()

    # The alpha history row now points at T2 with a fresh future window.
    with Session(registry_engine) as s:
        hist = s.get(m.TenantSlugHistory, "alpha")
        assert hist is not None
        assert hist.tenant_id == t2_id
        assert hist.reserved_until is not None
        assert hist.reserved_until > before


