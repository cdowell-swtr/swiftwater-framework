# FRAMEWORK:BEGIN
# Managed by the framework. Add your own config below the closing marker; the framework will not overwrite it.
# Copy to .env (gitignored) and adjust. All vars are read via config/settings.py.
# Application environment: dev | test | staging | prod (drives log level + config).
APP_ENVIRONMENT=dev
# Optional explicit log level (DEBUG/INFO/WARNING/ERROR). Unset = derived from APP_ENVIRONMENT.
# APP_LOG_LEVEL=
# SLO thresholds (drive /health evaluation and, in Plan 3b, dashboards + alerts).
APP_SLO_REQUEST_LATENCY_P99_MS=200
APP_SLO_ERROR_RATE_PCT=1.0
# Database. Host-side tooling (alembic, tests) uses localhost; the Compose stack
# injects the in-network URL (postgres / postgres-test).
APP_DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/app
# ── backups (core; see infra/backup/README.md) ───────────────────────────────
# Destination for encrypted dumps. Local dir by default; on this box point at a
# Google-Drive-synced folder under /mnt to survive WSL-VM and host loss.
BACKUP_DEST=./backups
# age recipient PUBLIC key (safe to commit). Generate a keypair with `age-keygen`.
BACKUP_PUBKEY=
# Path to the age PRIVATE identity on this box (read by restore + the drill). ALSO custody a
# copy OFF the box (password manager) — losing it makes the off-box backups unrecoverable.
BACKUP_IDENTITY=~/.config/{{ project_slug }}/backup-identity.txt
# GFS-lite retention.
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
{% if "multitenantauth" in batteries %}# ── multitenantauth: control-plane + auth ────────────────────────────────────
# Control-plane database (co-located on database_url by default — no need to set this).
# Set to a separate Postgres DSN to isolate the control-plane (target DB must pre-exist).
# Note (OPS-F4): the co-located default runs TWO SQLAlchemy QueuePools on one Postgres — the
# app engine AND the control engine, each pool_size=5 + max_overflow=10 = up to 15 connections,
# so ~30 per process at peak. Size Postgres max_connections accordingly (≈ 30 × app processes +
# headroom) so the control and data planes can't correlate-exhaust the connection pool.
# APP_CONTROL_DATABASE_URL=postgresql+psycopg://ctrl:ctrl@ctrl-host:5432/ctrl
#
# Pepper secrets — REQUIRED in prod/staging (verify_runtime raises at startup if empty).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Never reuse between session_pepper and password_pepper; never commit real values.
APP_SESSION_PEPPER=
APP_PASSWORD_PEPPER=
APP_PEPPER_VERSION=1
#
# Session cookie. session_cookie_secure defaults True (safe); never disable in prod/staging.
# Set session_cookie_domain only for multi-subdomain deployments (e.g. ".example.com").
# APP_SESSION_COOKIE_NAME={{ project_slug }}_session
# APP_SESSION_COOKIE_SECURE=true
# APP_SESSION_COOKIE_DOMAIN=
#
# CSRF defence: exact origin allowlist (no wildcards). Empty = same-origin only (safe default).
# APP_CSRF_ALLOWED_ORIGINS=["https://app.example.com","https://admin.example.com"]
#
# Signup policy (FAIL-CLOSED by default):
#   prod: signup off (404). staging + empty allowlist: DENY (403).
#   dev: open. Opt into signups by setting a non-empty allowlist:
# APP_SIGNUP_ALLOWLIST=["@yourcompany.com","founder@example.com"]
#
# B-F11 — credential-change session invalidation: /auth/set-password already deletes ALL of
# the user's sessions (a credential reset must not leave old sessions live). If you add a
# logged-in change-password or account-disable flow, it MUST replicate that step
# (delete Session WHERE user_id = …) or stale sessions survive the credential change.
#
# Argon2id cost params (floor-validated; defaults are the minimum security floor).
# APP_ARGON2_TIME_COST=3
# APP_ARGON2_MEMORY_COST=65536
# APP_ARGON2_PARALLELISM=4
#
# Rate limiting (login / set-password): NOT enforced at the app layer. argon2id makes each
# attempt costly, but bounding online password-guessing + request concurrency is an infra
# concern — enforce per-IP/per-account rate limits and a connection cap at the reverse proxy /
# load balancer (e.g. a Traefik rate-limit middleware), not in the app.
#
# Resource-grant resolver timeout. If you register an async resource_grant resolver, a timeout
# denies that resource leaf fail-closed and logs only the static resource_type from guard(...).
# APP_AUTHZ_RESOURCE_GRANT_TIMEOUT_MS=250
#
# Tenant DB first-touch connect timeout. Bounds engine validation against an unreachable tenant
# endpoint so one dead tenant database cannot occupy request threads for the OS TCP timeout.
# APP_TENANT_CONNECT_TIMEOUT_SECONDS=5
{% endif %}{% if "webhooks" in batteries %}# Webhook signing secret — HMAC-SHA256 verification of inbound webhooks (set per environment).
APP_WEBHOOK_SIGNING_SECRET=
{% endif %}{% if "workers" in batteries %}# Celery workers: Redis broker + result backend (in-network defaults; override per environment).
APP_REDIS_URL=redis://redis:6379/0
APP_CELERY_BROKER_URL=redis://redis:6379/0
APP_CELERY_RESULT_BACKEND=redis://redis:6379/1
{% endif %}{% if "mongodb" in batteries %}# MongoDB connection (in-network default; override per environment).
APP_MONGO_URL=mongodb://mongo:27017/app
{% endif %}# Observability (the stack runs in all environments). Grafana admin password (prod/staging);
# alert-channel secrets — Alertmanager delivers SLO breaches here (each materialized as a mounted
# file on deploy). Configured channels: {{ alert_channels | join(", ") }}.
GRAFANA_ADMIN_PASSWORD=
{% if "webhook" in alert_channels %}APP_ALERT_WEBHOOK_URL=
{% endif %}{% if "slack" in alert_channels %}APP_ALERT_SLACK_API_URL=
{% endif %}{% if "pagerduty" in alert_channels %}APP_ALERT_PAGERDUTY_ROUTING_KEY=
{% endif %}{% if "email" in alert_channels %}APP_ALERT_SMTP_SMARTHOST=
APP_ALERT_SMTP_FROM=
APP_ALERT_SMTP_TO=
APP_ALERT_SMTP_AUTH_USERNAME=
APP_ALERT_SMTP_AUTH_PASSWORD=
{% endif %}# --- Instance identity (FWK88 seam) ---
# STACK_INSTANCE namespaces this stack's containers/volumes/network (it drives
# COMPOSE_PROJECT_NAME via scripts/compose.sh). Leave it UNSET for the single-stack default
# (the project slug); a worktree-aware tool sets it per instance to run several stacks at once.
# Must match ^[a-z0-9-]+$ (a single DNS label). Do not assign it here — a committed value
# would collide across worktrees that share this file.
# STACK_INSTANCE=
# --- Local dev host ports (FWK31) ---
# Each dev/observability service publishes on these host ports. Override any of them, or
# set PORT_OFFSET to shift ALL of them at once, to run a second stack alongside this one.
# (These are read by `docker compose`, NOT by the app — do not prefix them APP_.)
PORT_OFFSET=0
HTTP_HOST_PORT=8000
POSTGRES_HOST_PORT=5432
TRAEFIK_HTTPS_PORT=443
TRAEFIK_HTTP_PORT=80
{% if "mongodb" in batteries %}MONGO_HOST_PORT=27017
{% endif %}{% if "redis" in batteries or "workers" in batteries %}REDIS_HOST_PORT=6379
{% endif %}{% if "react" in batteries %}FRONTEND_HOST_PORT=5173
{% endif %}PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3000
ALERTMANAGER_HOST_PORT=9093
LOKI_HOST_PORT=3100
TEMPO_HOST_PORT=3200
POSTGRES_EXPORTER_HOST_PORT=9187
{% if "mongodb" in batteries %}MONGODB_EXPORTER_HOST_PORT=9216
{% endif %}{% if "workers" in batteries %}CELERY_EXPORTER_HOST_PORT=9808
{% endif %}{% if "redis" in batteries or "workers" in batteries %}REDIS_EXPORTER_HOST_PORT=9121
{% endif %}# --- Reverse-proxy / edge trust (FWK98) ---
# Behind a TLS-terminating edge (the per-stack Traefik or a shared edge), the app trusts the
# X-Forwarded-Proto / X-Forwarded-For headers ONLY from the docker-net source so it builds https
# URLs + sets Secure cookies correctly. The scope is LOCKED to the RFC1918 superset + 127.0.0.1
# via a uvicorn `--forwarded-allow-ips` flag baked into the server command (infra/docker/Dockerfile
# CMD + infra/compose/dev.yml). It is a CLI flag on purpose: it beats the FORWARDED_ALLOW_IPS env
# var, so this trust cannot be silently widened to `*` from the environment. There is therefore no
# FORWARDED_ALLOW_IPS knob to set here. To TIGHTEN it in prod (trust only your load balancer's IP),
# override the app `command` in infra/compose/prod.yml with a narrower CIDR.
# --- Data-store & backend runtime (FWK6) ---
# Leave unset to use the co-located containers; set to point at managed / external instances.
# Each value is an opaque DSN — failover hosts and TLS params allowed.
# Managed deploy: omit/edit infra/compose/services.yml (remove the store block) and set the
# matching vars here.
# APP_DATABASE_URL=postgresql+psycopg://USER:PASS@managed-host:5432/db?sslmode=verify-full&sslrootcert=/etc/ssl/app-ca/ca.pem
{% if "workers" in batteries or "redis" in batteries %}# APP_REDIS_URL=redis://managed-host:6379/0
{% endif %}{% if "mongodb" in batteries %}# APP_MONGO_URL=mongodb://managed-host:27017/app
{% endif %}# Prometheus store-exporters (point at the same managed instances if you keep the exporters):
# POSTGRES_EXPORTER_DSN=postgresql://USER:PASS@managed-host:5432/db?sslmode=require
{% if "mongodb" in batteries %}# MONGODB_EXPORTER_URI=mongodb://managed-host:27017
{% endif %}{% if "workers" in batteries %}# CELERY_EXPORTER_BROKER_URL=redis://managed-host:6379/0
{% endif %}{% if "workers" in batteries or "redis" in batteries %}# REDIS_EXPORTER_ADDR=redis://managed-host:6379
{% endif %}# Observability egress (managed/SaaS OTLP, e.g. Grafana Cloud / Honeycomb):
# APP_OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.example:4317
# TLS verify-full to a managed store: also merge -f tls-ca.yml and drop your CA in infra/tls/ca/.
# FRAMEWORK:END

