version: '3'

tasks:
  dev:
    desc: Run the app locally with hot reload
    cmds:
      - uv run uvicorn {{ package_name }}.main:app --reload --port 8000

  test:
    desc: Run the test suite
    cmds:
      - uv run pytest -q

  test:cov:
    desc: Run tests with coverage and enforce the threshold
    cmds:
      - uv run pytest --cov --cov-context=test --cov-report=term-missing --cov-fail-under=70 -q

  hooks:
    desc: Install git pre-commit hooks
    cmds:
      - uv run pre-commit install

  hooks:run:
    desc: Run all pre-commit hooks against all files
    cmds:
      - uv run pre-commit run --all-files

  lint:
    desc: Lint and type-check
    cmds:
      - uv run ruff check .
      - uv run mypy src
