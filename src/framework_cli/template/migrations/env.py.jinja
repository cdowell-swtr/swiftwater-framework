from sqlalchemy import engine_from_config, pool

from alembic import context

from {{ package_name }}.config.settings import get_settings
from {{ package_name }}.db import models  # noqa: F401  (registers tables on Base.metadata)
{% if "webhooks" in batteries %}from {{ package_name }}.webhooks import models as _webhook_models  # noqa: F401
{% endif %}{% if "workers" in batteries %}from {{ package_name }}.tasks import dead_letter as _dead_letter_models  # noqa: F401
{% endif %}{% if "pgvector" in batteries %}from {{ package_name }}.vectors import models as _vector_models  # noqa: F401
{% endif %}{% if "timescaledb" in batteries %}from {{ package_name }}.timeseries import models as _timeseries_models  # noqa: F401
{% endif %}from {{ package_name }}.db.base import Base
{% if "multitenantauth" in batteries %}from {{ package_name }}.db.control.base import ControlBase  # noqa: F401
{% endif %}
config = context.config
if not config.get_main_option("sqlalchemy.url"):
    config.set_main_option("sqlalchemy.url", get_settings().database_url)
target_metadata = Base.metadata
{% if "multitenantauth" in batteries %}
_CONTROL_TABLES = set(ControlBase.metadata.tables.keys())


def _include_object(object, name, type_, reflected, compare_to):  # type: ignore[no-untyped-def]
    """Exclude control-plane tables and their version table from app autogenerate."""
    if type_ == "table":
        return name not in _CONTROL_TABLES and name != "alembic_version_multitenantauth"
    if hasattr(object, "table"):
        return object.table.name not in _CONTROL_TABLES
    return True
{% endif %}

def run_migrations_offline() -> None:
    context.configure(
        url=config.get_main_option("sqlalchemy.url"),
        target_metadata=target_metadata,
        literal_binds=True,
        dialect_opts={"paramstyle": "named"},
{%- if "multitenantauth" in batteries %}
        include_object=_include_object,
{%- endif %}
    )
    with context.begin_transaction():
        context.run_migrations()


def run_migrations_online() -> None:
    connectable = engine_from_config(
        config.get_section(config.config_ini_section, {}),
        prefix="sqlalchemy.",
        poolclass=pool.NullPool,
    )
    with connectable.connect() as connection:
        context.configure(
            connection=connection,
            target_metadata=target_metadata,
{%- if "multitenantauth" in batteries %}
            include_object=_include_object,
{%- endif %}
        )
        with context.begin_transaction():
            context.run_migrations()


if context.is_offline_mode():
    run_migrations_offline()
else:
    run_migrations_online()
