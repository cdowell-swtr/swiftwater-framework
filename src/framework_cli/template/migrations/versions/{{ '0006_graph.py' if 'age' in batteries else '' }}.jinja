from alembic import op

revision = "0006"
down_revision = "{{ down_revision_age }}"
branch_labels = None
depends_on = None


def upgrade() -> None:
    op.execute("CREATE EXTENSION IF NOT EXISTS age")
    # AGE graph functions live in ag_catalog; the server has shared_preload_libraries=age.
    op.execute("SELECT ag_catalog.create_graph('app_graph')")


def downgrade() -> None:
    # Drop the graph (and its vertices/edges); leave the age extension (dropping a shared extension is destructive).
    op.execute("SELECT ag_catalog.drop_graph('app_graph', true)")
