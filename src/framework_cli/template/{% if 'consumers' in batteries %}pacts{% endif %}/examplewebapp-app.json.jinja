{
  "consumer": {
    "name": "examplewebapp"
  },
  "interactions": [
    {
      "description": "a request for all items",
      "pending": false,
      "providerStates": [
        {
          "name": "items exist"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/items"
      },
      "response": {
        "body": {
          "content": [
            {
              "id": 1,
              "name": "alpha"
            }
          ],
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$[*].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      },
      "type": "Synchronous/HTTP"
    }
  ],
  "metadata": {
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "4.0"
    }
  },
  "provider": {
    "name": "app"
  }
}
