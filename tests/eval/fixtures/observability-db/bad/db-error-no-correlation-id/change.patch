+
+
+def delete_item_quietly(session: Session, item_id: int) -> bool:
+    """Delete an item, tolerating a failure.
+
+    BUG: a DB error is caught and logged through the stdlib ``logging`` module, NOT the
+    app's structlog ``get_logger()``. The stdlib path does not run the correlation_id /
+    trace processors, so the error record carries NO correlation_id and cannot be tied
+    back to the originating request — the failure is unobservable in the correlated logs.
+    """
+    try:
+        item = session.get(Item, item_id)
+        if item is None:
+            return False
+        session.delete(item)
+        session.commit()
+        return True
+    except Exception:
+        _audit_log.error("item delete failed for id=%s", item_id)  # no correlation_id
+        return False
