+def get_item_by_name(session: Session, name: str) -> "Item | None":
+    """Look up a single item by name — properly instrumented with a span."""
+    from opentelemetry import trace
+    tracer = trace.get_tracer(__name__)
+    with tracer.start_as_current_span("db.repository.get_item_by_name") as span:
+        span.set_attribute("item.name", name)
+        return session.scalars(select(Item).where(Item.name == name)).first()
