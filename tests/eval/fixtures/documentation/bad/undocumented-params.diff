--- a/src/app/config.py
+++ b/src/app/config.py
@@ -1,5 +1,21 @@
 import os


+def build_db_url(
+    host: str,
+    port: int,
+    database: str,
+    user: str,
+    password: str,
+    sslmode: str = "prefer",
+    connect_timeout: int = 5,
+    application_name: str = "",
+    options: str = "",
+) -> str:
+    parts = f"postgresql://{user}:{password}@{host}:{port}/{database}"
+    params = f"sslmode={sslmode}&connect_timeout={connect_timeout}"
+    if application_name:
+        params += f"&application_name={application_name}"
+    if options:
+        params += f"&options={options}"
+    return f"{parts}?{params}"
+
+
 def get_env(key: str, default: str = "") -> str:
     return os.environ.get(key, default)
