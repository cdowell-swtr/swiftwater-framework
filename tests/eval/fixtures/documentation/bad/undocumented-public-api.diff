--- a/src/app/client.py
+++ b/src/app/client.py
@@ -1,5 +1,26 @@
 import httpx


+class ServiceClient:
+    def __init__(self, base_url: str, token: str, timeout: float = 10.0, retries: int = 3):
+        self._base = base_url
+        self._token = token
+        self._timeout = timeout
+        self._retries = retries
+        self._session = httpx.Client(timeout=timeout)
+
+    def fetch(self, resource: str, params: dict | None = None, *, etag: str | None = None) -> httpx.Response:
+        headers = {"Authorization": f"Bearer {self._token}"}
+        if etag:
+            headers["If-None-Match"] = etag
+        for attempt in range(self._retries):
+            try:
+                resp = self._session.get(f"{self._base}/{resource}", params=params, headers=headers)
+                resp.raise_for_status()
+                return resp
+            except httpx.HTTPStatusError:
+                if attempt == self._retries - 1:
+                    raise
+        raise RuntimeError("unreachable")
+
+
 def ping(url: str) -> bool:
     return httpx.get(url).status_code == 200
