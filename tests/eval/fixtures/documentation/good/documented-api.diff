--- a/src/app/client.py
+++ b/src/app/client.py
@@ -1,5 +1,34 @@
+"""HTTP client helpers for interacting with upstream services."""
+
 import httpx


+class ServiceClient:
+    """Thin wrapper around httpx providing retry logic and auth headers.
+
+    Args:
+        base_url: Root URL of the upstream service (no trailing slash).
+        token: Bearer token used for all requests.
+        timeout: Per-request timeout in seconds (default 10).
+        retries: Number of retry attempts on transient failures (default 3).
+    """
+
+    def __init__(self, base_url: str, token: str, timeout: float = 10.0, retries: int = 3) -> None:
+        self._base = base_url
+        self._token = token
+        self._timeout = timeout
+        self._retries = retries
+        self._session = httpx.Client(timeout=timeout)
+
+    def fetch(self, resource: str, params: dict | None = None, *, etag: str | None = None) -> httpx.Response:
+        """Fetch a resource, retrying on failure.
+
+        Args:
+            resource: Path segment appended to base_url.
+            params: Query parameters forwarded to the request.
+            etag: If provided, sent as ``If-None-Match`` for conditional GETs.
+
+        Returns:
+            The httpx.Response from the upstream service.
+
+        Raises:
+            httpx.HTTPStatusError: If all retries are exhausted with a non-2xx response.
+        """
+        headers = {"Authorization": f"Bearer {self._token}"}
+        if etag:
+            headers["If-None-Match"] = etag
+        for attempt in range(self._retries):
+            try:
+                resp = self._session.get(f"{self._base}/{resource}", params=params, headers=headers)
+                resp.raise_for_status()
+                return resp
+            except httpx.HTTPStatusError:
+                if attempt == self._retries - 1:
+                    raise
+        raise RuntimeError("unreachable")
+
+
 def ping(url: str) -> bool:
+    """Return True if the given URL responds with HTTP 200."""
     return httpx.get(url).status_code == 200
