+"""add owner_email PII column to items
+
+Revision ID: 0002
+Revises: 0001
+Create Date: 2026-05-30
+"""
+from alembic import op
+import sqlalchemy as sa
+
+revision = "0002"
+down_revision = "0001"
+branch_labels = None
+depends_on = None
+
+
+def upgrade() -> None:
+    # PII column — nullable so existing rows are unaffected. The application
+    # layer (routes + ItemRead) intentionally excludes this from responses
+    # and logs; this column is for outreach only and must not be surfaced.
+    op.add_column("items", sa.Column("owner_email", sa.String(length=254), nullable=True))
+
+
+def downgrade() -> None:
+    op.drop_column("items", "owner_email")
