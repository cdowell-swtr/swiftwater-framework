+import { useEffect, useState } from "react";
+
+// New dashboard view: fetches metrics summary and renders it. No error handling,
+// no error boundary — a failed fetch is silently unobserved (no RUM signal).
+export function Dashboard() {
+  const [data, setData] = useState<unknown>(null);
+  useEffect(() => {
+    fetch("/internal/summary")
+      .then((r) => r.json())
+      .then(setData);
+  }, []);
+  return <section>{JSON.stringify(data)}</section>;
+}
