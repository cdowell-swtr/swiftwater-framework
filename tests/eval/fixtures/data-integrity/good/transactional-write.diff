 from app.db import session
-from app.models import Order, OrderItem, InventoryReservation
+from app.exceptions import InsufficientStockError
+from app.models import Inventory, InventoryReservation, Order, OrderItem


+def place_order(user_id: int, cart: list[dict]) -> Order:
+    """Create order and reserve inventory items atomically."""
+    with session.begin():
+        order = Order(user_id=user_id, status="pending")
+        session.add(order)
+
+        for item in cart:
+            stock = (
+                session.query(Inventory)
+                .filter_by(product_id=item["product_id"])
+                .with_for_update()
+                .one()
+            )
+            if item["quantity"] > stock.available:
+                raise InsufficientStockError(
+                    product_id=item["product_id"],
+                    requested=item["quantity"],
+                    available=stock.available,
+                )
+            line = OrderItem(
+                order=order,
+                product_id=item["product_id"],
+                quantity=item["quantity"],
+                unit_price=item["price"],
+            )
+            session.add(line)
+            reservation = InventoryReservation(product_id=item["product_id"], qty=item["quantity"])
+            session.add(reservation)
+
+    return order
+
+
 def cancel_order(order_id: int) -> None:
     order = session.get(Order, order_id)
     order.status = "cancelled"
