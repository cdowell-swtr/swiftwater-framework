     return item
+
+
+def rename_item(session: Session, item_id: int, name: str) -> Item | None:
+    """Rename an item atomically.
+
+    A single ``get`` + ``commit`` in one transaction — the whole change commits together
+    or not at all (no in-loop commit, no partial-write window). Returns None if the item
+    does not exist.
+    """
+    item = session.get(Item, item_id)
+    if item is None:
+        return None
+    item.name = name
+    session.commit()
+    session.refresh(item)
+    return item
