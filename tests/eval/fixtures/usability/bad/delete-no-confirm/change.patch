+
+// Bug: DeleteButton performs a destructive action (removing an item) with no
+// confirmation step. Users who misclick cannot recover; there is also no
+// loading or error feedback while the DELETE request is in flight.
+export function DeleteButton({ itemId }: { itemId: number }) {
+  const handleDelete = useCallback(async () => {
+    await fetch(`/items/${itemId}`, { method: "DELETE" });
+    window.location.reload();
+  }, [itemId]);
+
+  return (
+    <button onClick={handleDelete}>Delete</button>
+  );
+}
