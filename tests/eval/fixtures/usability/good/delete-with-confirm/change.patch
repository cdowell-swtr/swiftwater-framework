+
+// Good: DeleteButton asks for confirmation before the destructive action,
+// shows a loading state while the request is in flight, and surfaces errors
+// to the user instead of failing silently.
+export function DeleteButton({ itemId, onDeleted }: { itemId: number; onDeleted: () => void }) {
+  const [pending, setPending] = useState(false);
+  const [error, setError] = useState<string | null>(null);
+
+  const handleDelete = useCallback(async () => {
+    if (!window.confirm("Delete this item? This cannot be undone.")) return;
+    setPending(true);
+    setError(null);
+    try {
+      const res = await fetch(`/items/${itemId}`, { method: "DELETE" });
+      if (!res.ok) {
+        throw new Error(`Delete failed (HTTP ${res.status})`);
+      }
+      onDeleted();
+    } catch (e) {
+      setError(e instanceof Error ? e.message : "Delete failed. Please try again.");
+    } finally {
+      setPending(false);
+    }
+  }, [itemId, onDeleted]);
+
+  return (
+    <>
+      <button onClick={handleDelete} disabled={pending} aria-busy={pending}>
+        {pending ? "Deleting…" : "Delete"}
+      </button>
+      {error && <p role="alert" style={{ color: "crimson" }}>{error}</p>}
+    </>
+  );
+}
