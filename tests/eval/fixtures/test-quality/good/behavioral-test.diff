--- a/tests/test_orders.py
+++ b/tests/test_orders.py
@@ -1,6 +1,38 @@
 import pytest
 from decimal import Decimal

+from app.orders import calculate_shipping_cost, place_order
+from app.exceptions import InsufficientStockError
 from app.models import Order


+def test_calculate_shipping_cost_standard_zone3():
+    """Compute expected shipping cost for a 2.5 kg standard shipment to zone 3."""
+    order = Order(weight_kg=2.5, destination_zone=3)
+    cost = calculate_shipping_cost(order, method="standard")
+    assert cost == Decimal("8.75")
+
+
+def test_calculate_shipping_cost_express_zone1():
+    """Express shipping for a 1 kg parcel to zone 1 should cost more than standard."""
+    order = Order(weight_kg=1.0, destination_zone=1)
+    express = calculate_shipping_cost(order, method="express")
+    standard = calculate_shipping_cost(order, method="standard")
+    assert express > standard
+    assert express == Decimal("12.00")
+
+
+def test_place_order_raises_on_insufficient_stock():
+    """Placing an order for more units than available raises InsufficientStockError."""
+    cart = [{"product_id": 42, "quantity": 9999, "price": Decimal("9.99")}]
+    with pytest.raises(InsufficientStockError) as exc_info:
+        place_order(user_id=1, cart=cart)
+    assert exc_info.value.product_id == 42
+    assert exc_info.value.requested == 9999
+
+
+def test_place_order_returns_pending_status():
+    """A successful order is created with status 'pending'."""
+    cart = [{"product_id": 1, "quantity": 1, "price": Decimal("20.00")}]
+    order = place_order(user_id=7, cart=cart)
+    assert order.status == "pending"
+    assert order.user_id == 7
+

 def test_order_creation():
     order = Order(weight_kg=1.5, destination_zone=2)
     assert order.weight_kg == 1.5
