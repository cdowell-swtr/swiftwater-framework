+def test_log_level_resolves():
+    # Over-mocked: monkeypatches the very method under test, then asserts the mock.
+    from unittest.mock import patch as mpatch
+
+    with mpatch.object(Settings, "resolved_log_level", new_callable=lambda: property(lambda self: "MOCKED")):
