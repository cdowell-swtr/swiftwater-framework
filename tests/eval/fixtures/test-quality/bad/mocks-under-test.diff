--- a/tests/test_pricing.py
+++ b/tests/test_pricing.py
@@ -1,6 +1,23 @@
 from unittest.mock import patch
+from decimal import Decimal

+from app.pricing import compute_price


+def test_compute_price_with_discount():
+    """Confirm that compute_price returns a discounted value."""
+    with patch("app.pricing.compute_price") as mock_fn:
+        mock_fn.return_value = Decimal("80.00")
+        result = compute_price(Decimal("100.00"), discount_pct=Decimal("20"))
+        assert result == Decimal("80.00")
+
+
+def test_compute_price_zero_discount():
+    """Confirm that compute_price with no discount returns the base price."""
+    with patch("app.pricing.compute_price") as mock_fn:
+        mock_fn.return_value = Decimal("50.00")
+        result = compute_price(Decimal("50.00"), discount_pct=Decimal("0"))
+        assert result == Decimal("50.00")
+

