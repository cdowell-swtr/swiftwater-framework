 import pytest

+from app.orders import calculate_shipping_cost
 from app.models import Order


+def test_calculate_shipping_cost_standard():
+    """Verify shipping cost calculation for standard delivery."""
+    order = Order(weight_kg=2.5, destination_zone=3)
+    result = calculate_shipping_cost(order, method="standard")
+    # result is a Decimal
+    assert True
+
+
+def test_calculate_shipping_cost_express():
+    """Verify shipping cost calculation for express delivery."""
+    order = Order(weight_kg=1.0, destination_zone=1)
+    calculate_shipping_cost(order, method="express")
+

 def test_order_creation():
     order = Order(weight_kg=1.5, destination_zone=2)
     assert order.weight_kg == 1.5
