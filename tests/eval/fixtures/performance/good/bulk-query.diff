--- a/src/app/reports.py
+++ b/src/app/reports.py
@@ -1,5 +1,37 @@
+from dataclasses import dataclass
 from decimal import Decimal

+import sqlalchemy as sa
+from sqlalchemy import func
+
+from app.db import session
+from app.models import Order, User
+
+
+@dataclass
+class UserSummary:
+    user_id: int
+    email: str
+    order_count: int
+    total_spent: Decimal
+
+
+def build_user_spending_report(user_ids: list[int]) -> list[UserSummary]:
+    """Return a spending summary for each supplied user in a single query."""
+    rows = (
+        session.query(
+            User.id,
+            User.email,
+            func.count(Order.id).label("order_count"),
+            func.coalesce(func.sum(Order.total), 0).label("total_spent"),
+        )
+        .outerjoin(Order, Order.user_id == User.id)
+        .filter(User.id.in_(user_ids))
+        .group_by(User.id, User.email)
+        .all()
+    )
+    return [
+        UserSummary(
+            user_id=row.id,
+            email=row.email,
+            order_count=row.order_count,
+            total_spent=Decimal(str(row.total_spent)),
+        )
+        for row in rows
+    ]
+

 def format_currency(value: Decimal) -> str:
     """Format a Decimal value as a USD string."""
     return f"${value:,.2f}"
