+import time
+
+from app.db import session
+from app.models import Job
+
+
+def process_pending_jobs() -> int:
+    """Fetch and execute all queued jobs, returning the count processed."""
+    jobs = session.query(Job).filter_by(status="pending").all()
+    processed = 0
+    for job in jobs:
+        try:
+            _execute(job)
+            job.status = "done"
+            processed += 1
+        except Exception:
+            pass
+    session.commit()
+    return processed
+
+
+def _execute(job: Job) -> None:
+    """Dispatch a single job to its registered handler."""
+    time.sleep(0.01)  # simulate handler latency
+

