+
+
+@router.post("/items/{item_id}/archive")
+def archive_item(item_id: int, session: SessionDep) -> dict:
+    """Mark an item as archived — properly instrumented with a span and structured logging."""
+    from opentelemetry import trace
+    from ..logging_config import get_logger
+
+    tracer = trace.get_tracer(__name__)
+    log = get_logger()
+
+    with tracer.start_as_current_span("items.archive") as span:
+        span.set_attribute("item.id", item_id)
+        log.info("archive_item_started", item_id=item_id)
+        item = session.get(Item, item_id)
+        if item is None:
+            from fastapi import HTTPException
+            log.warning("archive_item_not_found", item_id=item_id)
+            raise HTTPException(status_code=404, detail="Item not found")
+        item.name = f"[archived] {item.name}"
+        session.commit()
+        log.info("archive_item_completed", item_id=item_id)
+        return {"archived": True, "item_id": item_id}
