+@router.post("/items/{item_id}/archive", response_model=ItemRead)
+def archive_item(item_id: int, session: SessionDep) -> Item:
+    """Archive an item by id.
+
+    Relies on FastAPI auto-instrumentation for the request span (no manual
+    tracer) and emits a structured completion event via structlog.
+    """
+    item = session.get(Item, item_id)
+    if item is None:
+        _log.warning("archive_item_not_found", item_id=item_id)
+        raise HTTPException(status_code=404, detail="Item not found")
+    item.name = f"[archived] {item.name}"
+    session.commit()
+    session.refresh(item)
+    _log.info("archive_item_completed", item_id=item_id)
+    return item
