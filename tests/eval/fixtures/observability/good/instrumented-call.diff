--- a/src/app/payments.py
+++ b/src/app/payments.py
@@ -1,8 +1,40 @@
+import httpx
 from decimal import Decimal

+from opentelemetry import trace
+
+from app.models import Payment, PaymentResult
+from app.observability import get_structured_logger
+
+tracer = trace.get_tracer(__name__)
+log = get_structured_logger(__name__)
+
+
+_GATEWAY_URL = "https://payments.example.com/v2/charge"
+
+
+def charge_card(user_id: int, amount: Decimal, token: str) -> PaymentResult:
+    """Submit a card charge to the payment gateway and persist the result."""
+    with tracer.start_as_current_span("payments.charge_card") as span:
+        span.set_attribute("user.id", user_id)
+        span.set_attribute("charge.amount", str(amount))
+        log.info("initiating card charge", user_id=user_id, amount=str(amount))
+        payload = {
+            "amount": str(amount),
+            "currency": "USD",
+            "token": token,
+            "idempotency_key": f"user-{user_id}-{amount}",
+        }
+        try:
+            response = httpx.post(_GATEWAY_URL, json=payload, timeout=10.0)
+            response.raise_for_status()
+        except httpx.HTTPError as exc:
+            log.error("gateway request failed", user_id=user_id, error=str(exc))
+            span.record_exception(exc)
+            raise
+        data = response.json()
+        result = PaymentResult(
+            user_id=user_id,
+            charge_id=data["charge_id"],
+            amount=amount,
+            status=data["status"],
+        )
+        log.info("card charge accepted", user_id=user_id, charge_id=data["charge_id"])
+        return result
+

