+
+
+from ..logging_config import correlation_id_var, get_logger
+
+_log = get_logger()
+
+
+@router.delete("/items/{item_id}", status_code=204)
+def delete_item(item_id: int, session: SessionDep) -> None:
+    """Delete an item by id — logs errors with the request correlation id per the obs contract."""
+    from fastapi import HTTPException
+    item = session.get(Item, item_id)
+    if item is None:
+        _log.warning(
+            "delete_item_not_found",
+            item_id=item_id,
+            correlation_id=correlation_id_var.get(),
+        )
+        raise HTTPException(status_code=404, detail="Item not found")
+    try:
+        session.delete(item)
+        session.commit()
+        _log.info("delete_item_ok", item_id=item_id)
+    except Exception:
+        _log.error(
+            "delete_item_failed",
+            item_id=item_id,
+            correlation_id=correlation_id_var.get(),
+        )
+        raise
