+@router.delete("/items/{item_id}", status_code=204)
+def delete_item(item_id: int, session: SessionDep) -> None:
+    """Delete an item by id.
+
+    The request correlation id is injected automatically by the
+    ``add_correlation_id`` structlog processor — events are emitted without a
+    manual ``correlation_id`` kwarg.
+    """
+    item = session.get(Item, item_id)
+    if item is None:
+        _log.warning("delete_item_not_found", item_id=item_id)
+        raise HTTPException(status_code=404, detail="Item not found")
+    try:
+        session.delete(item)
+        session.commit()
+        _log.info("delete_item_ok", item_id=item_id)
+    except Exception:
+        _log.error("delete_item_failed", item_id=item_id)
+        raise
