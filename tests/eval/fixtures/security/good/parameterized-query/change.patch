+def find_items_by_name(session: Session, name: str) -> list[Item]:
+    """Look up items with an exact-match name filter.
+
+    ``name`` is bound as a query parameter via SQLAlchemy's ``==`` operator (never
+    string-interpolated into SQL), so the lookup is injection-safe. The result set is
+    bounded by ``MAX_PAGE_SIZE``.
+    """
+    stmt = select(Item).where(Item.name == name).order_by(Item.id).limit(MAX_PAGE_SIZE)
+    return list(session.scalars(stmt))
