+@router.delete("/admin/items/{item_id}", status_code=204)
+def admin_delete_item(
+    item_id: int,
+    session: SessionDep,
+) -> None:
+    """Permanently delete an item — a privileged, destructive admin operation.
+
+    Bug: this destructive operation on stored records writes NO audit-log entry, so
+    there is no trace of who deleted what or when. A privileged deletion must leave an
+    audit trail (GDPR Art. 30 record of processing / SOC2 CC). The delete itself is
+    atomic; the compliance gap is the missing audit record.
+    """
+    item = session.get(Item, item_id)
+    if item is not None:
+        session.delete(item)
+        session.commit()
