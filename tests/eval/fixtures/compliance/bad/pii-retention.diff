 from app.db import session
 from app.models import UserProfile


+def register_user(
+    email: str,
+    full_name: str,
+    national_id: str,
+    date_of_birth: str,
+    address: str,
+) -> UserProfile:
+    profile = UserProfile(
+        email=email,
+        full_name=full_name,
+        national_id=national_id,
+        date_of_birth=date_of_birth,
+        address=address,
+    )
+    session.add(profile)
+    session.commit()
+    return profile
+
+
 def get_profile(user_id: int) -> UserProfile:
     return session.query(UserProfile).filter_by(id=user_id).one()
