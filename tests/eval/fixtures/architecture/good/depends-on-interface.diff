+        ...
+
+
+class OrderService:
+    """Core order management logic, independent of persistence technology."""
+
+    def __init__(self, repo: OrderRepository) -> None:
+        self._repo = repo
+
+    def place_order(self, user_id: int, items: list[dict]) -> Order:
+        """Validate item data, compute totals, and persist a new order."""
+        if not items:
+            raise ValueError("order must contain at least one item")
+        order = Order(user_id=user_id, status="pending", total=Decimal("0"))
+        for item in items:
+            line = OrderItem(
+                product_id=item["product_id"],
+                quantity=item["quantity"],
+                unit_price=Decimal(str(item["price"])),
+            )
+            order.items.append(line)
+            order.total += line.unit_price * line.quantity
+        return self._repo.save(order)
+
+    def cancel_order(self, order_id: int) -> Order:
+        """Mark an existing order as cancelled."""
+        order = self._repo.get(order_id)
+        if order is None:
+            raise ValueError(f"order {order_id} not found")
+        order.status = "cancelled"
+        return self._repo.save(order)
+

