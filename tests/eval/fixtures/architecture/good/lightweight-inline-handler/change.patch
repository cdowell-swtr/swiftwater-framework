+
+class ItemCreate(BaseModel):
+    name: str = Field(min_length=1, max_length=255)
+
+
+@router.post("/items", response_model=ItemRead, status_code=201)
+def post_item(payload: ItemCreate, session: SessionDep) -> Item:
+    """Create an item via the repository, then emit ONE lightweight structured log.
+
+    A single structured log call is lightweight inline work (not heavy/blocking I/O),
+    so keeping it in the handler is correct — no background worker is warranted.
+    """
+    item = create_item(session, payload.name)
+    get_logger().info("item_created", item_id=item.id)
+    return item
