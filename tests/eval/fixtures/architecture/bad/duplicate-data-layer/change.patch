@@ -0,0 +1,16 @@
+from sqlalchemy.orm import Session
+
+from .models import Item
+
+
+def fetch_all_items(session: Session) -> list[Item]:
+    """Fetch all items from the database."""
+    return session.query(Item).order_by(Item.id).all()
+
+
+def add_item(session: Session, name: str) -> Item:
+    """Persist a new item and return it."""
+    item = Item(name=name)
+    session.add(item)
+    session.flush()
+    return item
