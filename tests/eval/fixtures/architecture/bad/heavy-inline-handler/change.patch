+
+
+class ImportRequest(BaseModel):
+    urls: list[str]
+
+
+@router.post("/items/import")
+def import_items(payload: ImportRequest, session: SessionDep) -> dict[str, int]:
+    """BUG: heavy synchronous work runs inline in the request handler.
+
+    A blocking external HTTP call PER url, in a loop, fetches each remote payload
+    before the response can return — the request thread is held for the full batch.
+    This belongs in a background worker (the workers battery), dispatched from the
+    handler seam, not executed inline.
+    """
+    created = 0
+    for url in payload.urls:
+        resp = httpx.get(url, timeout=30.0)
+        create_item(session, resp.json()["name"])
+        created += 1
+    return {"imported": created}
