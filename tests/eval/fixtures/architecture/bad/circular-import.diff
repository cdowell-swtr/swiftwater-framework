--- a/src/app/services/billing.py
+++ b/src/app/services/billing.py
@@ -1,5 +1,23 @@
 from decimal import Decimal

+from app.services.notifications import send_invoice_email
+from app.models import Invoice
+from app.db import session
+
+
+def issue_invoice(user_id: int, amount: Decimal) -> Invoice:
+    """Create an invoice record and dispatch a notification email."""
+    inv = Invoice(user_id=user_id, amount=amount, status="issued")
+    session.add(inv)
+    session.commit()
+    send_invoice_email(user_id=user_id, invoice_id=inv.id, amount=amount)
+    return inv
+

 def compute_tax(amount: Decimal, rate: Decimal) -> Decimal:
     """Apply tax rate to the given amount."""
     return (amount * rate).quantize(Decimal("0.01"))
--- a/src/app/services/notifications.py
+++ b/src/app/services/notifications.py
@@ -1,4 +1,14 @@
+from app.services.billing import compute_tax
+from app.models import User
+from app.mailer import send_email
+
+
+def send_invoice_email(user_id: int, invoice_id: int, amount: float) -> None:
+    """Deliver an invoice notification to the user's email address."""
+    user = User.get(user_id)
+    tax = compute_tax(amount, rate=0.08)
+    body = f"Invoice #{invoice_id}: ${amount:.2f} + ${tax:.2f} tax"
+    send_email(to=user.email, subject="Your invoice", body=body)
+

