@@ -1,8 +1,22 @@
 from decimal import Decimal


+def calculate_total(price: Decimal, tax_rate: Decimal) -> Decimal:
+    """Compute the total price including tax.
+
+    Args:
+        price: pre-tax unit price (must be >= 0).
+        tax_rate: fractional tax rate, e.g. 0.08 for 8% (must be in [0, 1]).
+
+    Returns:
+        Total amount: price * (1 + tax_rate), rounded to 2 decimal places.
+    """
+    if price < 0 or not (0 <= tax_rate <= 1):
+        raise ValueError(f"Invalid price={price!r} or tax_rate={tax_rate!r}")
+    return (price * (1 + tax_rate)).quantize(Decimal("0.01"))
+
+
 def apply_discount(price: Decimal, discount_pct: Decimal) -> Decimal:
     """Reduce price by the given percentage (0–100)."""
+    if not (0 <= discount_pct <= 100):
+        raise ValueError(f"discount_pct must be 0–100, got {discount_pct!r}")
     return price * (1 - discount_pct / 100)
