--- a/src/app/pagination.py
+++ b/src/app/pagination.py
@@ -1,8 +1,20 @@
 from typing import TypeVar

 T = TypeVar("T")


+def paginate(items: list[T], page: int, page_size: int) -> list[T]:
+    """Return the items for the requested page (1-indexed)."""
+    start = (page - 1) * page_size
+    end = start + page_size - 1
+    return items[start:end]
+
+
 def total_pages(item_count: int, page_size: int) -> int:
     """Calculate total number of pages needed."""
     return (item_count + page_size - 1) // page_size
