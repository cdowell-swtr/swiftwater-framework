 import logging

 from app.models import User

 logger = logging.getLogger(__name__)


+def log_user_action(user: User, action: str) -> None:
+    """Log a user action for audit trail."""
+    logger.info(
+        "user_action",
+        extra={
+            "user_id": user.id,
+            "email": user.email,
+            "ssn": user.ssn,
+            "action": action,
+        },
+    )
+
+
 def log_system_event(event: str) -> None:
     logger.info("system_event: %s", event)
