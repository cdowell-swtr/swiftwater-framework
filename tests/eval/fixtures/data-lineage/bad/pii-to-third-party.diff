@@ -1,6 +1,22 @@
 import httpx

 from app.config import settings
 from app.models import User


+def sync_user_to_crm(user: User) -> None:
+    """Push user profile to the external CRM."""
+    client = httpx.Client(base_url=settings.CRM_API_URL)
+    client.post(
+        "/contacts",
+        headers={"Authorization": f"Bearer {settings.CRM_API_KEY}"},
+        json={
+            "email": user.email,
+            "ssn": user.ssn,
+            "full_name": user.name,
+            "phone": user.phone,
+        },
+    )
+
+
 def get_crm_contact(email: str) -> dict:
     client = httpx.Client(base_url=settings.CRM_API_URL)
     response = client.get(f"/contacts?email={email}")
