     return list(session.scalars(stmt))
 
 
+def _make_slug(name: str) -> str:
+    """Derive the canonical slug from a name value."""
+    return name.strip().lower().replace(" ", "-")
+
+
 def create_item(session: Session, name: str) -> Item:
-    item = Item(name=name)
+    item = Item(name=name, slug=_make_slug(name))
     session.add(item)
     session.commit()
     session.refresh(item)
     return item
+
+
+def update_item_name(session: Session, item_id: int, name: str) -> Item | None:
+    """Rename an item, keeping slug in sync with the new name."""
+    item = session.get(Item, item_id)
+    if item is None:
+        return None
+    item.name = name
+    item.slug = _make_slug(name)
+    session.commit()
+    session.refresh(item)
+    return item
