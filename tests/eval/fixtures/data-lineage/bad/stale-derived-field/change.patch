+def update_item_name(session: Session, item_id: int, name: str) -> Item | None:
+    """Rename an item, keeping slug in sync with the new name."""
+    item = session.get(Item, item_id)
+    if item is None:
+        return None
+    item.name = name
+    item.slug = _make_slug(name)
+    session.commit()
+    session.refresh(item)
+    return item
