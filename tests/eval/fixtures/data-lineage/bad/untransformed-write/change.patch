 def create_item(session: Session, name: str) -> Item:
+    """Persist an item.  Use create_item_normalized for user-supplied input."""
     item = Item(name=name)
     session.add(item)
     session.commit()
     session.refresh(item)
     return item
+
+
+def create_item_normalized(session: Session, name: str) -> Item:
+    """Canonical entry-point for user-supplied names.
+
+    Strips surrounding whitespace and lowercases the value so that all stored
+    names follow a consistent casing convention.  Callers that accept user
+    input MUST go through this function, not the bare create_item().
+    """
+    normalized = name.strip().lower()
+    item = Item(name=normalized)
+    session.add(item)
+    session.commit()
+    session.refresh(item)
+    return item
