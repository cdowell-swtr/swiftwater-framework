@@ -1,6 +1,24 @@
 from app.db import session
 from app.models import User
+from app.repositories.user_repo import UserRepository


+def record_signup_event(user_id: int) -> None:
+    """Write an anonymised signup event to the analytics store.
+
+    Lineage: reads from users via UserRepository (approved PII accessor).
+    Sink: analytics_events table — stores only user_id (non-PII reference).
+    No raw PII fields (email, name, ssn) are written here.
+    Approved in data-lineage review 2026-03-11 (see docs/lineage/signup-flow.md).
+    """
+    from app.models import AnalyticsEvent

+    repo = UserRepository(session)
+    user = repo.get(user_id)  # raises if not found
+    event = AnalyticsEvent(
+        event_type="signup",
+        user_id=user.id,        # non-PII foreign key only
+        timestamp=user.created_at,
+    )
+    session.add(event)
+    session.commit()
+
+
